"enum\": [\n          \"herrscher_elite\",\n          \"macht_ausuebend\",\n          \"wohlhabende_buergerschaft\",\n          \"aussen_zeitgenoessisch\",\n          \"betroffen_sus\",\n          \"alltag_unterschicht\",\n          \"frauenperspektive\",\n          \"kinder_jugendliche\",\n          \"randstaendig_regional\",\n          \"opposition_widerstand\"\n        ]\n      },\n      \"description\": \"Perspektiv-Tags pro perspektiv_enum.json. Min 1, max 3. Validation gegen Enum-Pool. coverage-report.sh aggregiert daraus QG-06.\"\n    },\n    \"kontextualisierung\": {\n      \"type\": \"object\",\n      \"description\": \"Pflicht wenn is_original_zitat=true (siehe required-Allof). Setzt das Zitat in einen R7-konformen Rahmen.\",\n      \"required\": [\n        \"vorwort\",\n        \"glossar\",\n        \"kritische_einordnung\"\n      ],\n      \"properties\": {\n        \"vorwort\": {\n          \"type\": \"string\",\n          \"minLength\": 30,\n          \"description\": \"Kontextualisierungs-Kopfzeile in R7-Sprache. Markiert die Quellensprache als historisch und ordnet die abweichenden Register ein.\"\n        },\n        \"glossar\": {\n          \"type\": \"array\",\n          \"items\": {\n            \"$ref\": \"glossar_template.json\"\n          },\n          \"description\": \"Glossar-Eintraege fuer Begriffe, die R7-fern sind oder kolonialsprachlich (Pflicht bei Blacklist-Treffer).\"\n        },\n        \"kritische_einordnung\": {\n          \"type\": \"string\",\n          \"minLength\": 30,\n          \"description\": \"Kurze didaktische Einordnung: warum ist diese Quelle relevant, was zeigt sie ueber die Sicht der Verfasser, welche Begriffe sind heute problematisch.\"\n        }\n      }\n    }\n  },\n  \"allOf\": [\n    {\n      \"if\": {\n        \"properties\": {\n          \"is_original_zitat\": {\n            \"const\": true\n          }\n        },\n        \"required\": [\n          \"is_original_zitat\"\n        ]\n      },\n      \"then\": {\n        \"required\": [\n          \"kontextualisierung\"\n        ]\n      }\n    }\n  ]\n}\n","structuredPatch":[],"originalFile":null,"userModified":false}}
