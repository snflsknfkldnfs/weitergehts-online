{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NjJoeiVnNqVFGKCHxrefGD","type":"tool_result","content":"The file /Users/paulad/escape-game-generator/tools/coverage-report.sh has been updated successfully. (file state is current in your context — no need to Read it back)"}]},"parent_tool_use_id":null,"session_id":"7b48050f-9a71-4508-a0e9-cf74193b5dd7","uuid":"c567302b-a85b-4c04-a251-b54a68d8301f","timestamp":"2026-04-19T20:02:04.617Z","tool_use_result":{"filePath":"/Users/paulad/escape-game-generator/tools/coverage-report.sh","oldString":"        'erzeugt': datetime.datetime.utcnow().isoformat(timespec='seconds') + 'Z',","newString":"        'erzeugt': datetime.datetime.now(datetime.timezone.utc).isoformat(timespec='seconds').replace('+00:00','Z'),","originalFile":"#!/usr/bin/env bash\n# tools/coverage-report.sh — F0b A1.5 (V15)\n#\n# Aggregiert material.perspektiv_tags[] pro Mappe aus\n# escape-games/<scope>/materialien/*.json (oder analoger Source-Ablage).\n#\n# Output:\n#   - JSON-Bericht auf stdout (pro Mappe Zaehlung dominant/nicht_dominant)\n#   - Erzeugt registry/perspektiv_inventar(_mappe_N).json pro Mappe\n#   - Bei aktiver Trigger-Kategorie (INHALTSBASIS.trigger_categories): QG-06-Check\n#     (>=2 Materialien aus pool=nicht_dominant pro Mappe)\n#\n# Kontrakt: F0B_PRIMING_INCLUDE.md §2/§5, perspektiv_enum.json, V15.\n#\n# Usage:\n#   tools/coverage-report.sh <scope>\n#\n#   <scope> = Slug, der entweder\n#     (a) escape-games/<scope> im weitergehts-online-Repo bezeichnet, oder\n#     (b) docs/agents/artefakte/<scope> im weitergehts-online-Repo bezeichnet.\n#\n# Exit-Codes:\n#   0 = PASS (QG-06 erfuellt oder Trigger nicht aktiv)\n#   1 = FAIL (QG-06 verletzt)\n#   2 = Script-Bug\n\nset -u\n\nerr() { echo \"ERROR: $*\" >&2; }\n\nif [[ $# -lt 1 ]]; then\n  err \"usage: $0 <scope>\"\n  exit 2\nfi\n\nSCOPE=\"$1\"\n\nSCRIPT_DIR=\"$(cd -- \"$(dirname -- \"${BASH_SOURCE[0]}\")\" &> /dev/null && pwd)\"\nGEN_ROOT=\"$(cd -- \"$SCRIPT_DIR/..\" &> /dev/null && pwd)\"\nENUM_FILE=\"$GEN_ROOT/architektur/perspektiv_enum.json\"\n\nWO_ROOT_CANDIDATES=(\n  \"${WEITERGEHTS_ONLINE_ROOT:-}\"\n  \"$GEN_ROOT/../weitergehts.online/weitergehts-online\"\n  \"$GEN_ROOT/../weitergehts-online\"\n  \"$HOME/weitergehts.online/weitergehts-online\"\n)\nWO_ROOT=\"\"\nfor c in \"${WO_ROOT_CANDIDATES[@]}\"; do\n  if [[ -n \"$c\" && -d \"$c\" ]]; then WO_ROOT=\"$(cd -- \"$c\" && pwd)\"; break; fi\ndone\nif [[ -z \"$WO_ROOT\" ]]; then\n  err \"weitergehts-online-Repo nicht gefunden.\"\n  exit 2\nfi\n\nif ! command -v python3 >/dev/null 2>&1; then\n  err \"python3 nicht verfuegbar.\"; exit 2\nfi\n\npython3 - \"$SCOPE\" \"$WO_ROOT\" \"$ENUM_FILE\" <<'PY'\nimport json, os, sys, glob, re, datetime\n\nscope, wo_root, enum_file = sys.argv[1], sys.argv[2], sys.argv[3]\n\nwith open(enum_file, 'r', encoding='utf-8') as f:\n    enum_data = json.load(f)\npool_of = {e['id']: e['pool'] for e in enum_data.get('enum', [])}\ntrigger_active_kategorien = enum_data.get('coverage_regel_qg06', {}).get('bei_trigger_kategorie', [])\nmin_required = enum_data.get('coverage_regel_qg06', {}).get('min_materialien_aus_pool_nicht_dominant_pro_mappe', 2)\n\n# --- Scope-Pfade ermitteln ---\ncandidates = [\n    os.path.join(wo_root, 'escape-games', scope),\n    os.path.join(wo_root, 'docs', 'agents', 'artefakte', scope),\n]\nscope_roots = [c for c in candidates if os.path.isdir(c)]\nif not scope_roots:\n    print(json.dumps({'scope': scope, 'error': 'Scope-Verzeichnis nicht gefunden', 'candidates': candidates}, ensure_ascii=False, indent=2), file=sys.stderr)\n    sys.exit(2)\n\n# --- INHALTSBASIS aufspueren (fuer trigger_categories) ---\ntrigger_categories = []\nib_paths = []\nfor sr in scope_roots:\n    for p in glob.glob(os.path.join(sr, 'INHALTSBASIS*'), recursive=False):\n        ib_paths.append(p)\n    for p in glob.glob(os.path.join(sr, '**', 'INHALTSBASIS*'), recursive=True):\n        ib_paths.append(p)\nfor ib in ib_paths:\n    if not os.path.isfile(ib):\n        continue\n    try:\n        if ib.endswith('.json'):\n            with open(ib, 'r', encoding='utf-8') as f:\n                d = json.load(f)\n            tc = (d.get('header') or {}).get('trigger_categories') or d.get('trigger_categories')\n            if isinstance(tc, list):\n                trigger_categories = tc\n                break\n        else:\n            with open(ib, 'r', encoding='utf-8') as f:\n                txt = f.read()\n            m = re.search(r'trigger_categories\\s*[:=]\\s*\\[([^\\]]*)\\]', txt, re.IGNORECASE)\n            if m:\n                items = re.findall(r'[a-z_]+', m.group(1).lower())\n                trigger_categories = items\n                break\n    except Exception:\n        continue\ntrigger_relevant = any(t in trigger_active_kategorien for t in trigger_categories)\n\n# --- Materialien pro Mappe sammeln ---\ndef find_mappe_dirs(roots):\n    mappes = {}  # mappe_n -> dir\n    for sr in roots:\n        for entry in os.listdir(sr):\n            mpath = os.path.join(sr, entry)\n            if not os.path.isdir(mpath):\n                continue\n            m = re.match(r'^mappe[-_]?([0-9]+)$', entry, re.IGNORECASE)\n            if m:\n                mappes.setdefault(int(m.group(1)), []).append(mpath)\n    return mappes\n\nmappe_map = find_mappe_dirs(scope_roots)\nresults = []\noverall_fail = False\n\nfor mappe_n in sorted(mappe_map.keys()):\n    dirs = mappe_map[mappe_n]\n    materialien = []\n    for d in dirs:\n        for jp in glob.glob(os.path.join(d, '**', '*.json'), recursive=True):\n            base = os.path.basename(jp).lower()\n            if not (base.startswith('mat-') or 'material' in base):\n                continue\n            try:\n                with open(jp, 'r', encoding='utf-8') as f:\n                    obj = json.load(f)\n            except Exception:\n                continue\n            if not isinstance(obj, dict):\n                continue\n            tags = obj.get('perspektiv_tags')\n            if tags is None:\n                # Legacy: _meta.perspektive single-string -> map to enum if known\n                meta = obj.get('_meta') or {}\n                persp = meta.get('perspektive') or obj.get('perspektive')\n                if isinstance(persp, str):\n                    if persp in pool_of:\n                        tags = [persp]\n            mat_id = obj.get('id') or os.path.basename(jp)\n            materialien.append({'id': mat_id, 'file': jp, 'perspektiv_tags': tags or []})\n\n    # Aggregat\n    tag_to_mats = {}\n    for m in materialien:\n        for t in m['perspektiv_tags']:\n            if t not in pool_of:\n                continue\n            tag_to_mats.setdefault(t, []).append(m['id'])\n    tags_aggregiert = []\n    for t in sorted(tag_to_mats.keys()):\n        tags_aggregiert.append({'enum_id': t, 'pool': pool_of[t], 'material_ids': sorted(set(tag_to_mats[t]))})\n\n    nicht_dominant_mats = set()\n    for m in materialien:\n        for t in m['perspektiv_tags']:\n            if pool_of.get(t) == 'nicht_dominant':\n                nicht_dominant_mats.add(m['id'])\n                break\n\n    qg06_pass = (len(nicht_dominant_mats) >= min_required) or (not trigger_relevant)\n    if not qg06_pass:\n        overall_fail = True\n\n    inventar = {\n        'scope_id': scope,\n        'mappe_n': mappe_n,\n        'schema_version': '1.0',\n        'trigger_kategorie_aktiv': trigger_relevant,\n        'tags_aggregiert': tags_aggregiert,\n        'nicht_dominant_count': len(nicht_dominant_mats),\n        'qg06_pass': qg06_pass,\n        'erzeugt': datetime.datetime.utcnow().isoformat(timespec='seconds') + 'Z',\n    }\n\n    # Schreibe registry/perspektiv_inventar(_mappe_N).json\n    target_dir = dirs[0]\n    out_dir = os.path.join(target_dir, 'registry')\n    os.makedirs(out_dir, exist_ok=True)\n    out_file = os.path.join(out_dir, f'perspektiv_inventar_mappe_{mappe_n}.json')\n    try:\n        with open(out_file, 'w', encoding='utf-8') as f:\n            json.dump(inventar, f, ensure_ascii=False, indent=2)\n            f.write('\\n')\n    except Exception as e:\n        print(f'WARN inventar-write fehlgeschlagen ({out_file}): {e}', file=sys.stderr)\n\n    results.append({\n        'mappe_n': mappe_n,\n        'materialien_total': len(materialien),\n        'nicht_dominant_count': len(nicht_dominant_mats),\n        'qg06_pass': qg06_pass,\n        'inventar_file': out_file,\n        'tags_aggregiert': tags_aggregiert,\n    })\n\nreport = {\n    'scope': scope,\n    'trigger_categories': trigger_categories,\n    'trigger_relevant': trigger_relevant,\n    'min_required_nicht_dominant': min_required,\n    'mappe_count': len(results),\n    'overall_pass': not overall_fail,\n    'mappen': results,\n}\nprint(json.dumps(report, ensure_ascii=False, indent=2))\nsys.exit(1 if overall_fail else 0)\nPY\n","structuredPatch":[{"oldStart":183,"oldLines":7,"newStart":183,"newLines":7,"lines":["         'tags_aggregiert': tags_aggregiert,","         'nicht_dominant_count': len(nicht_dominant_mats),","         'qg06_pass': qg06_pass,","-        'erzeugt': datetime.datetime.utcnow().isoformat(timespec='seconds') + 'Z',","+        'erzeugt': datetime.datetime.now(datetime.timezone.utc).isoformat(timespec='seconds').replace('+00:00','Z'),","     }"," ","     # Schreibe registry/perspektiv_inventar(_mappe_N).json"]}],"userModified":false,"replaceAll":false}}
