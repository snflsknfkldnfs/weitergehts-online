{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011EGvNU7EmyeiVqiDYCrSun","type":"tool_result","content":"1\t{\n2\t  \"$schema\": \"https://json-schema.org/draft/2020-12/schema\",\n3\t  \"version\": \"1.0\",\n4\t  \"erstellt\": \"2026-04-19\",\n5\t  \"zweck\": \"Linguistische Referenz fuer Sprachniveau-R7 (F0b M8'/QG-08). Nicht bindende Vollliste, sondern Heuristik-Fundament fuer scripts/sprachniveau-gate.js: (a) Fachwort-Dichte-Berechnung (Abgleich gegen r7_fachwoerter_lexikon), (b) Nominalstil-Detektion (Endungen), (c) Morphem-Schaetzung (Trennungs-Kandidaten). Keine inhaltliche Zensur — Worte ausserhalb der Liste sind nicht verboten; sie erhoehen aber den Fachwort-Dichte-Score und koennen die 12%-Grenze oder den 4-Morpheme-Schwellwert ausloesen.\",\n6\t  \"quellen_referenz\": [\n7\t    \"ISB Bayern LehrplanPLUS R7 GPG Wortliste (2025)\",\n8\t    \"Leichte Sprache Regelwerk Netzwerk (Grundwortschatz-Orientierung)\",\n9\t    \"DaZ-Wortschatz Mittelstufe A2-B1 (Standardlisten Mercator/BAMF)\"\n10\t  ],\n11\t  \"r7_grundwortschatz_marker\": {\n12\t    \"hinweis\": \"Worte des Grundwortschatzes erhoehen Fachwort-Dichte NICHT. Liste ist Sample, kein vollstaendiger Korpus — Scanner kombiniert mit Frequenz-Heuristik.\",\n13\t    \"beispiel_domaenen\": [\n14\t      \"alltag (haus, schule, freund, zeit)\",\n15\t      \"geographie_basis (land, stadt, meer, fluss, grenze)\",\n16\t      \"zeitliche_struktur (jahr, jahrhundert, frueher, spaeter)\",\n17\t      \"soziale_rollen_einfach (mensch, familie, arbeit, herrscher, volk)\",\n18\t      \"politische_grundbegriffe (recht, gesetz, staat, regierung)\"\n19\t    ]\n20\t  },\n21\t  \"r7_fachwoerter_lexikon\": {\n22\t    \"hinweis\": \"Fachbegriffe, die bei Erstnennung erklaert werden MUESSEN (Glossar-Pflicht). Diese Begriffe zaehlen zur Fachwort-Dichte; zweite und folgende Erwaehnungen nicht.\",\n23\t    \"lb1_demokratie_recht\": [\n24\t      \"Demokratie\", \"Diktatur\", \"Grundrechte\", \"Gewaltenteilung\", \"Opposition\",\n25\t      \"Verfassung\", \"Grundgesetz\", \"Wahl\", \"Parlament\", \"Regierung\",\n26\t      \"Gewerkschaft\", \"Partei\", \"Abgeordnete\"\n27\t    ],\n28\t    \"lb2_absolutismus_revolution\": [\n29\t      \"Absolutismus\", \"Alleinherrschaft\", \"Staende\", \"Privileg\",\n30\t      \"Aufklaerung\", \"Menschenrechte\", \"Revolution\", \"Verfassung\",\n31\t      \"Nationalversammlung\", \"Konstitution\", \"Bastille\"\n32\t    ],\n33\t    \"lb3_industrialisierung\": [\n34\t      \"Industrialisierung\", \"Manufaktur\", \"Fabrik\", \"Maschine\",\n35\t      \"Proletariat\", \"Soziale Frage\", \"Landflucht\", \"Urbanisierung\",\n36\t      \"Arbeiterbewegung\", \"Gewerkschaft\", \"Kapitalismus\",\n37\t      \"Sozialgesetze\"\n38\t    ],\n39\t    \"lb4_imperialismus_kolonialismus\": [\n40\t      \"Imperialismus\", \"Kolonialherrschaft\", \"Kolonie\", \"Metropole\",\n41\t      \"Weltmacht\", \"Weltwirtschaft\",\n42\t      \"Rassismus\", \"Mission\", \"Widerstand\",\n43\t      \"Unabhaengigkeit\", \"Dekolonisation\"\n44\t    ]\n45\t  },\n46\t  \"morphem_heuristik\": {\n47\t    \"hinweis\": \"Schaetzung der Morphemzahl ueber Silbenkerne + Bindeelemente. Grenze: 4 Morpheme pro Wort (Fachbegriffe zaehlen als 1 bei Glossar-Eintrag; sonst nach Teilung).\",\n48\t    \"trennungs_signale\": [\"-ung\", \"-keit\", \"-heit\", \"-tion\", \"-ismus\", \"-lich\", \"-bar\", \"-los\", \"-haft\"],\n49\t    \"kompositionsgrenzen\": [\"Fugen-s\", \"Bindestrich\", \"Gross-in-der-Mitte (Binnenmajuskel ungewoehnlich)\"]\n50\t  },\n51\t  \"nominalstil_endungen\": {\n52\t    \"hinweis\": \"Endungen, die Nominalstil indizieren. Scanner zaehlt Anteil von Woertern mit diesen Endungen an Gesamt-Wortzahl pro Satz. Grenze: 20%.\",\n53\t    \"marker\": [\"-ung\", \"-heit\", \"-keit\", \"-tion\", \"-tum\", \"-nis\", \"-schaft\", \"-ismus\"]\n54\t  },\n55\t  \"konjunktiv_marker\": {\n56\t    \"hinweis\": \"Hilfsverb-Konjunktivformen + -wuerde-Konstruktion. Grenze: 5% der Saetze.\",\n57\t    \"formen\": [\"waere\", \"waeren\", \"haette\", \"haetten\", \"koennte\", \"koennten\", \"muesste\", \"muessten\", \"wuerde\", \"wuerden\", \"sei\", \"seien\", \"habe\", \"gebe\"]\n58\t  },\n59\t  \"satzlaenge_regel\": {\n60\t    \"einheit\": \"Wortzahl pro Satz (trennung an . ! ?). Ø ≤ 15, max ≤ 25. Ueberschreitung in einem Satz = FAIL-flag mit Zeile; Durchschnittsgrenze = Post-Gen-Gate.\",\n61\t    \"ausnahme\": \"Zitate aus Primaerquellen werden markiert und nicht mitberechnet.\"\n62\t  },\n63\t  \"daz_regeln\": {\n64\t    \"hinweis\": \"DaZ-Sensitivitaet: aktive Formulierung bevorzugen, Negation vermeiden wenn moeglich, Pronomen-Referenten eindeutig.\",\n65\t    \"signale_vermeiden\": [\n66\t      \"doppelte Negation (nicht un-)\",\n67\t      \"Passivkonstruktion ohne Nennung des Akteurs\",\n68\t      \"Verschachtelung von mehr als 1 Nebensatz\",\n69\t      \"Pronomen ohne klaren Bezug (es, dies, jenes)\",\n70\t      \"Funktionsverbgefuege ohne aktives Verb (zur Durchfuehrung bringen)\"\n71\t    ]\n72\t  },\n73\t  \"pragmatische_grenzen\": {\n74\t    \"metrik_toleranz\": \"Ein einzelnes Wort/Satz ausserhalb der Grenze = Warning, kein FAIL. FAIL nur bei Ueberschreitung der Durchschnitts-/Anteils-Grenzen auf Material- oder Mappe-Ebene.\",\n75\t    \"ausnahme_scope\": [\n76\t      \"Primaerquellen-Zitate (eigene Regel §1 F0B_PRIMING_INCLUDE)\",\n77\t      \"Glossar-Eintraege selbst (sind Definitions-Saetze, anderer Scope)\"\n78\t    ]\n79\t  },\n80\t  \"wartungs_hinweis\": \"Fachwort-Listen pro LB aktualisieren bei LP-QM-Rev. Grundwortschatz-Marker nicht haendisch pflegen, stattdessen durch externe Korpora anreichern (Pull-Request mit Quellenangabe).\"\n81\t}\n82\t"}]},"parent_tool_use_id":null,"session_id":"7b48050f-9a71-4508-a0e9-cf74193b5dd7","uuid":"ab24c9cd-7b6f-4692-b621-ae5fb7ed1809","timestamp":"2026-04-19T19:50:48.083Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/paulad/escape-game-generator/architektur/wortschatz_r7_core.json","conten