{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0178tSTXa3EaSLuFcJd5Ccfr","type":"tool_result","content":"1\t#!/usr/bin/env bash\n2\t#\n3\t# source-deploy-parity.sh — Q-SOURCE-DEPLOY-PARITY-Check\n4\t#\n5\t# Prüft für ein Game, ob alle Caption-Felder in Source-JSONs (mat-*.json)\n6\t# mit den entsprechenden Einträgen in data.json übereinstimmen.\n7\t#\n8\t# Usage: ./tools/source-deploy-parity.sh <game-id>\n9\t#\n10\t# Exit-Codes:\n11\t#   0 = PASS (alle Captions/Quellen synchron)\n12\t#   1 = FAIL (Drift erkannt)\n13\t#   2 = Fehler (Game nicht gefunden, jq nicht installiert, etc.)\n14\t#\n15\t# Empfohlen als Regression-Guard bei Re-Assembly-Operationen.\n16\t\n17\tset -euo pipefail\n18\t\n19\tGAME_ID=\"${1:-}\"\n20\t\n21\tif [[ -z \"$GAME_ID\" ]]; then\n22\t  echo \"❌ Usage: $0 <game-id>\" >&2\n23\t  exit 2\n24\tfi\n25\t\n26\t# Pfade\n27\tSCRIPT_DIR=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd)\"\n28\tREPO_ROOT=\"$(cd \"$SCRIPT_DIR/..\" && pwd)\"\n29\tSOURCE_DIR=\"$REPO_ROOT/docs/agents/artefakte/$GAME_ID\"\n30\tDATA_JSON=\"$REPO_ROOT/escape-games/$GAME_ID/data.json\"\n31\t\n32\t# Checks\n33\tif ! command -v jq >/dev/null 2>&1; then\n34\t  echo \"❌ jq nicht installiert. brew install jq\" >&2\n35\t  exit 2\n36\tfi\n37\t\n38\tif [[ ! -d \"$SOURCE_DIR\" ]]; then\n39\t  echo \"❌ Source-Verzeichnis nicht gefunden: $SOURCE_DIR\" >&2\n40\t  exit 2\n41\tfi\n42\t\n43\tif [[ ! -f \"$DATA_JSON\" ]]; then\n44\t  echo \"❌ data.json nicht gefunden: $DATA_JSON\" >&2\n45\t  exit 2\n46\tfi\n47\t\n48\techo \"🔍 Source-Deploy-Parity-Check für Game: $GAME_ID\"\n49\techo \"   Source: $SOURCE_DIR\"\n50\techo \"   Deploy: $DATA_JSON\"\n51\techo \"\"\n52\t\n53\tFAIL_COUNT=0\n54\t\n55\t# Alle mat-*.json in allen Mappen durchlaufen\n56\twhile IFS= read -r -d '' MAT_JSON; do\n57\t  MAT_ID=\"$(jq -r '.id // empty' \"$MAT_JSON\")\"\n58\t\n59\t  if [[ -z \"$MAT_ID\" ]]; then\n60\t    echo \"⚠️  SKIP: $MAT_JSON (kein .id Feld)\"\n61\t    continue\n62\t  fi\n63\t\n64\t  # Relevante Felder aus Source extrahieren\n65\t  SOURCE_CAPTION=\"$(jq -r '.bildunterschrift // empty' \"$MAT_JSON\")\"\n66\t  SOURCE_QUELLE=\"$(jq -r '.quelle // empty' \"$MAT_JSON\")\"\n67\t  SOURCE_TITEL=\"$(jq -r '.titel // empty' \"$MAT_JSON\")\"\n68\t\n69\t  # Nur prüfen, wenn es Caption-Felder gibt\n70\t  if [[ -z \"$SOURCE_CAPTION\" && -z \"$SOURCE_QUELLE\" ]]; then\n71\t    # Kein bildunterschrift oder quelle → nicht relevant für diesen Check\n72\t    continue\n73\t  fi\n74\t\n75\t  # Entsprechenden Eintrag in data.json suchen (mit robuster Fehlerbehandlung)\n76\t  DEPLOY_CAPTION=\"$(jq -r --arg id \"$MAT_ID\" '\n77\t    recurse | objects | select(.id == $id) | .bildunterschrift // empty\n78\t  ' \"$DATA_JSON\" 2>/dev/null | head -n 1)\"\n79\t\n80\t  DEPLOY_QUELLE=\"$(jq -r --arg id \"$MAT_ID\" '\n81\t    recurse | objects | select(.id == $id) | .quelle // empty\n82\t  ' \"$DATA_JSON\" 2>/dev/null | head -n 1)\"\n83\t\n84\t  DEPLOY_TITEL=\"$(jq -r --arg id \"$MAT_ID\" '\n85\t    recurse | objects | select(.id == $id) | .titel // empty\n86\t  ' \"$DATA_JSON\" 2>/dev/null | head -n 1)\"\n87\t\n88\t  if [[ -z \"$DEPLOY_CAPTION\" && -z \"$DEPLOY_QUELLE\" && -z \"$DEPLOY_TITEL\" ]]; then\n89\t    echo \"⚠️  SKIP: $MAT_ID (nicht in data.json gefunden)\"\n90\t    continue\n91\t  fi\n92\t\n93\t  # Vergleich\n94\t  MISMATCH=\"\"\n95\t\n96\t  if [[ \"$SOURCE_CAPTION\" != \"$DEPLOY_CAPTION\" ]]; then\n97\t    MISMATCH=\"caption\"\n98\t  fi\n99\t\n100\t  if [[ \"$SOURCE_QUELLE\" != \"$DEPLOY_QUELLE\" ]]; then\n101\t    if [[ -n \"$MISMATCH\" ]]; then\n102\t      MISMATCH=\"$MISMATCH+quelle\"\n103\t    else\n104\t      MISMATCH=\"quelle\"\n105\t    fi\n106\t  fi\n107\t\n108\t  if [[ \"$SOURCE_TITEL\" != \"$DEPLOY_TITEL\" ]]; then\n109\t    if [[ -n \"$MISMATCH\" ]]; then\n110\t      MISMATCH=\"$MISMATCH+titel\"\n111\t    else\n112\t      MISMATCH=\"titel\"\n113\t    fi\n114\t  fi\n115\t\n116\t  if [[ -n \"$MISMATCH\" ]]; then\n117\t    echo \"❌ DRIFT: $MAT_ID ($MISMATCH)\"\n118\t    echo \"   Source: $(basename \"$MAT_JSON\")\"\n119\t    echo \"   Deploy: data.json\"\n120\t    FAIL_COUNT=$((FAIL_COUNT + 1))\n121\t  else\n122\t    echo \"✅ SYNC:  $MAT_ID\"\n123\t  fi\n124\t\n125\tdone < <(find \"$SOURCE_DIR\" -type f -name \"mat-*.json\" -print0)\n126\t\n127\techo \"\"\n128\tif [[ $FAIL_COUNT -eq 0 ]]; then\n129\t  echo \"✅ PASS: Alle Source-JSONs synchron mit data.json\"\n130\t  exit 0\n131\telse\n132\t  echo \"❌ FAIL: $FAIL_COUNT Drift(s) erkannt\"\n133\t  exit 1\n134\tfi\n135\t"}]},"parent_tool_use_id":null,"session_id":"7b48050f-9a71-4508-a0e9-cf74193b5dd7","uuid":"7d149bef-7b4f-466b-aa1f-11db595a0a23","timestamp":"2026-04-19T19:51:05.024Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/paulad/weitergehts.online/weitergehts-online/tools/source-deploy-parity.sh","content":"#!/usr/bin/env bash\n#\n# source-deploy-parity.sh — Q-SOURCE-DEPLOY-PARITY-Check\n#\n# Prüft für ein Game, ob alle Caption-Felder in Source-JSONs (mat-*.json)\n# mit den entsprechenden Einträgen in data.json übereinstimmen.\n#\n# Usage: ./tools/source-deploy-parity.sh <game-id>\n#\n# Exit-Codes:\n#   0 = PASS (alle Captions/Quellen synchron)\n#   1 = FAIL (Drift erkannt)\n#   2 = Fehler (Game nicht gefunden, jq nicht installiert, etc.)\n#\n# Empfohlen als Regression-Guard bei Re-Assembly-Operationen.\n\nset -euo pipefail\n\nGAME_ID=\"${1:-}\"\n\nif [[ -z \"$GAME_ID\" ]]; then\n  echo \"❌ Usage: $0 <game-id>\" >&2\n  exit 2\nfi\n\n# Pfade\nSCRIPT_DIR=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd)\"\nREPO_ROOT=\"$(cd \"$SCRIPT_DIR/..\" && pwd)\"\nSOURCE_DIR=\"$REPO_ROOT/docs/agents/artefakte/$GAME_ID\"\nDATA_JSON=\"$REPO_ROOT/escape-games/$GAME_ID/data.json\"\n\n# Checks\nif ! command -v jq >/dev/null 2>&1; then\n  echo \"❌ jq nicht installiert. brew install jq\" >&2\n  exit 2\nfi\n\nif [[ ! -d \"$SOURCE_DIR\" ]]; then\n  echo \"❌ Source-Verzeichnis nicht gefunden: $SOURCE_DIR\" >&2\n  exit 2\nfi\n\nif [[ ! -f \"$DATA_JSON\" ]]; then\n  echo \"❌ data.json nicht gefunden: $DATA_JSON\" >&2\n  exit 2\nfi\n\necho \"🔍 Source-Deploy-Parity-Check für Game: $GAME_ID\"\necho \"   Source: $SOURCE_DIR\"\necho \"   Deploy: $DATA_JSON\"\necho \"\"\n\nFAIL_COUNT=0\n\n# Alle mat-*.json in allen Mappen durchlaufen\nwhile IFS= read -r -d '' MAT_JSON; do\n  MAT_ID=\"$(jq -r '.id // empty' \"$MAT_JSON\")\"\n\n  if [[ -z \"$MAT_ID\" ]]; then\n    echo \"⚠️  SKIP: $MAT_JSON (kein .id Feld)\"\n    continue\n  fi\n\n  # Relevante Felder aus Source extrahieren\n  SOURCE_CAPTION=\"$(jq -r '.bildunterschrift // empty' \"$MAT_JSON\")\"\n  SOURCE_QUELLE=\"$(jq -r '.quelle // empty' \"$MAT_JSON\")\"\n  SOURCE_TITEL=\"$(jq -r '.titel // empty' \"$MAT_JSON\")\"\n\n  # Nur prüfen, wenn es Caption-Felder gibt\n  if [[ -z \"$SOURCE_CAPTION\" && -z \"$SOURCE_QUELLE\" ]]; then\n    # Kein bildunterschrift oder quelle → nicht relevant für diesen Check\n    continue\n  fi\n\n  # Entsprechenden Eintrag in data.json suchen (mit robuster Fehlerbehandlung)\n  DEPLOY_CAPTION=\"$(jq -r --arg id \"$MAT_ID\" '\n    recurse | objects | select(.id == $id) | .bildunterschrift // empty\n  ' \"$DATA_JSON\" 2>/dev/null | head -n 1)\"\n\n  DEPLOY_QUELLE=\"$(jq -r --arg id \"$MAT_ID\" '\n    recurse | objects | select(.id == $id) | .quelle // empty\n  ' \"$DATA_JSON\" 2>/dev/null | head -n 1)\"\n\n  DEPLOY_TITEL=\"$(jq -r --arg id \"$MAT_ID\" '\n    recurse | objects | select(.id == $id) | .titel // empty\n  ' \"$DATA_JSON\" 2>/dev/null | head -n 1)\"\n\n  if [[ -z \"$DEPLOY_CAPTION\" && -z \"$DEPLOY_QUELLE\" && -z \"$DEPLOY_TITEL\" ]]; then\n    echo \"⚠️  SKIP: $MAT_ID (nicht in data.json gefunden)\"\n    continue\n  fi\n\n  # Vergleich\n  MISMATCH=\"\"\n\n  if [[ \"$SOURCE_CAPTION\" != \"$DEPLOY_CAPTION\" ]]; then\n    MISMATCH=\"caption\"\n  fi\n\n  if [[ \"$SOURCE_QUELLE\" != \"$DEPLOY_QUELLE\" ]]; then\n    if [[ -n \"$MISMATCH\" ]]; then\n      MISMATCH=\"$MISMATCH+quelle\"\n    else\n      MISMATCH=\"quelle\"\n    fi\n  fi\n\n  if [[ \"$SOURCE_TITEL\" != \"$DEPLOY_TITEL\" ]]; then\n    if [[ -n \"$MISMATCH\" ]]; then\n      MISMATCH=\"$MISMATCH+titel\"\n    else\n      MISMATCH=\"titel\"\n    fi\n  fi\n\n  if [[ -n \"$MISMATCH\" ]]; then\n    echo \"❌ DRIFT: $MAT_ID ($MISMATCH)\"\n    echo \"   Source: $(basename \"$MAT_JSON\")\"\n    echo \"   Deploy: data.json\"\n    FAIL_COUNT=$((FAIL_COUNT + 1))\n  else\n    echo \"✅ SYNC:  $MAT_ID\"\n  fi\n\ndone < <(find \"$SOURCE_DIR\" -type f -name \"mat-*.json\" -print0)\n\necho \"\"\nif [[ $FAIL_COUNT -eq 0 ]]; then\n  echo \"✅ PASS: Alle Source-JSONs synchron mit data.json\"\n  exit 0\nelse\n  echo \"❌ FAIL: $FAIL_COUNT Drift(s) erkannt\"\n  exit 1\nfi\n","numLines":135,"startLine":1,"totalLines":135}}}
