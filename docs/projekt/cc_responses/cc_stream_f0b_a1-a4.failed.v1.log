{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016qkSxBsFavwsQ4s3h15pkf","type":"tool_result","content":"1\t#!/usr/bin/env bash\n2\t# tools/deploy-check.sh\n3\t# Phase 3.1 Deploy-Preparation Q-Gate (v3.11)\n4\t# Prueft DEPLOY-01..DEPLOY-05 gegen das TARGET-Repo-Arbeitsverzeichnis.\n5\t#\n6\t# Aufruf:  ./tools/deploy-check.sh <game-id>\n7\t# Exit:    0 = alle PASS, 1 = mindestens ein FAIL, 2 = infrastruktureller Fehler\n8\t#\n9\t# Q-Gate-Katalog: architektur/Q-GATE-MECHANIK.md §7.7 (escape-game-generator Repo)\n10\t# Vertrag:        architektur/vertraege/VERTRAG_PHASE_3-1_DEPLOY.md\n11\t#\n12\t# Voraussetzungen: bash, python3 (>=3.8), grep, find, awk\n13\t\n14\tset -u\n15\t\n16\tGAME_ID=\"${1:-}\"\n17\tMAPPE_SCOPE=\"${2:-ALL}\"   # optional zweites Argument: konkrete Mappe-Nummer oder ALL (Default)\n18\tif [ -z \"$GAME_ID\" ]; then\n19\t  echo \"usage: $0 <game-id> [mappe-n|ALL]\" >&2\n20\t  exit 2\n21\tfi\n22\t\n23\t# Repo-Root relativ zum Script (Script liegt in tools/)\n24\tSCRIPT_DIR=\"$(cd -- \"$(dirname -- \"${BASH_SOURCE[0]}\")\" &> /dev/null && pwd)\"\n25\tREPO_ROOT=\"$(cd -- \"$SCRIPT_DIR/..\" &> /dev/null && pwd)\"\n26\tcd \"$REPO_ROOT\" || { echo \"cannot cd to repo root: $REPO_ROOT\" >&2; exit 2; }\n27\t\n28\tGAME_DIR=\"escape-games/$GAME_ID\"\n29\tDATA_JSON=\"$GAME_DIR/data.json\"\n30\tGAME_INDEX_HTML=\"$GAME_DIR/index.html\"\n31\tLANDING_HTML=\"index.html\"\n32\t\n33\t# Q-GATE-LOG Infrastruktur (P0-A1 / F-RA1-05)\n34\tQ_GATE_LOG_DIR=\"$SCRIPT_DIR/q-gate-log\"\n35\tQ_GATE_LOG_FILE=\"$Q_GATE_LOG_DIR/$GAME_ID.log\"\n36\tmkdir -p \"$Q_GATE_LOG_DIR\"\n37\tSCRIPT_VERSION=\"$(git -C \"$REPO_ROOT\" rev-parse --short HEAD 2>/dev/null || echo 'unknown')\"\n38\t\n39\tFAIL=0\n40\tdeclare -a RESULTS\n41\tdeclare -a FAILED_GATES\n42\t\n43\treport() {\n44\t  # $1 = ID, $2 = PASS|FAIL, $3 = diagnose\n45\t  local line=\"$1: $2 $3\"\n46\t  RESULTS+=(\"$line\")\n47\t  echo \"$line\"\n48\t  if [ \"$2\" = \"FAIL\" ]; then\n49\t    FAIL=1\n50\t    FAILED_GATES+=(\"$1\")\n51\t  fi\n52\t}\n53\t\n54\t# ------------------------------------------------------------------\n55\t# DEPLOY-01: data.json existiert, JSON-valide, Pflichtfelder vorhanden\n56\t# ------------------------------------------------------------------\n57\tif [ ! -f \"$DATA_JSON\" ]; then\n58\t  report \"DEPLOY-01\" \"FAIL\" \"$DATA_JSON fehlt\"\n59\telse\n60\t  DEPLOY_01_OUT=\"$(python3 - \"$DATA_JSON\" <<'PY' 2>&1\n61\timport json, sys\n62\tp = sys.argv[1]\n63\ttry:\n64\t    with open(p, 'r', encoding='utf-8') as f:\n65\t        d = json.load(f)\n66\texcept json.JSONDecodeError as e:\n67\t    print(f\"FAIL JSON-Parse-Fehler: {e}\")\n68\t    sys.exit(1)\n69\texcept Exception as e:\n70\t    print(f\"FAIL Lese-Fehler: {e}\")\n71\t    sys.exit(1)\n72\tmeta = d.get(\"meta\", {})\n73\ttitel = meta.get(\"titel\")\n74\tmappen = d.get(\"mappen\", [])\n75\tif not isinstance(titel, str) or not titel.strip():\n76\t    print(\"FAIL meta.titel fehlt oder leer\")\n77\t    sys.exit(1)\n78\tif not isinstance(mappen, list) or len(mappen) == 0:\n79\t    print(\"FAIL mappen[] fehlt oder leer\")\n80\t    sys.exit(1)\n81\tprint(f\"PASS titel=\\\"{titel}\\\" mappen.len={len(mappen)}\")\n82\tPY\n83\t  )\"\n84\t  DEPLOY_01_RC=$?\n85\t  if [ \"$DEPLOY_01_RC\" -eq 0 ]; then\n86\t    report \"DEPLOY-01\" \"PASS\" \"${DEPLOY_01_OUT#PASS }\"\n87\t  else\n88\t    report \"DEPLOY-01\" \"FAIL\" \"${DEPLOY_01_OUT#FAIL }\"\n89\t  fi\n90\tfi\n91\t\n92\t# ------------------------------------------------------------------\n93\t# DEPLOY-02: Alle referenzierten Asset-Pfade existieren\n94\t# ------------------------------------------------------------------\n95\tif [ ! -f \"$DATA_JSON\" ]; then\n96\t  report \"DEPLOY-02\" \"FAIL\" \"data.json fehlt (vgl. DEPLOY-01)\"\n97\telse\n98\t  DEPLOY_02_OUT=\"$(python3 - \"$DATA_JSON\" \"$REPO_ROOT\" \"$GAME_DIR\" <<'PY' 2>&1\n99\timport json, os, sys, re\n100\t\n101\tdata_json_path = sys.argv[1]\n102\trepo_root = sys.argv[2]\n103\tgame_dir = sys.argv[3]  # escape-games/<game-id>\n104\t\n105\ttry:\n106\t    with open(data_json_path, 'r', encoding='utf-8') as f:\n107\t        d = json.load(f)\n108\texcept Exception as e:\n109\t    print(f\"FAIL data.json nicht lesbar: {e}\")\n110\t    sys.exit(1)\n111\t\n112\t# Heuristik: rekursiv alle String-Werte, die wie Bild/Asset-Pfade aussehen\n113\t# (nicht auf Feldnamen basierend, sondern auf Dateiendung + Pfad-Praefix)\n114\tasset_ext = re.compile(r\"\\.(jpg|jpeg|png|webp|svg|gif)$\", re.IGNORECASE)\n115\t# Praefix: relative Pfade, die auf assets/ oder auf ../../assets/ usw. zeigen\n116\t# Absolute URLs (http://, https://) werden ignoriert\n117\tabs_url = re.compile(r\"^https?://\")\n118\t\n119\tfound = []\n120\t\n121\tdef walk(obj, path=\"\"):\n122\t    if isinstance(obj, dict):\n123\t        for k, v in obj.items():\n124\t            walk(v, f\"{path}.{k}\" if path else k)\n125\t    elif isinstance(obj, list):\n126\t        for i, v in enumerate(obj):\n127\t            walk(v, f\"{path}[{i}]\")\n128\t    elif isinstance(obj, str):\n129\t        if abs_url.match(obj):\n130\t            return\n131\t        if asset_ext.search(obj):\n132\t            # Exkludiere _meta.wikimedia_dateiname und aehnliche reine Metadaten\n133\t            # Diese enthalten meist \"File:\" als Praefix oder sind keine echten Pfade\n134\t            if obj.startswith(\"File:\"):\n135\t                return\n136\t            found.append((path, obj))\n137\t\n138\twalk(d)\n139\t\n140\tmissing = []\n141\tdedup = {}\n142\tfor path, rel in found:\n143\t    # Aufloesung: relative Pfade ab dem Spielverzeichnis\n144\t    # (weil Game-HTML aus escape-games/<game-id>/ lae1dt)\n145\t    if rel.startswith(\"../../\"):\n146\t        # ../../assets/... -> repo_root/assets/...\n147\t        clean = rel[6:].lstrip(\"/\")\n148\t    elif rel.startswith(\"./\"):\n149\t        clean = rel[2:]\n150\t        clean = os.path.join(game_dir, clean)\n151\t    elif rel.startswith(\"/\"):\n152\t        clean = rel.lstrip(\"/\")\n153\t    else:\n154\t        # Interpretation: relativ zum game_dir\n155\t        clean = os.path.join(game_dir, rel)\n156\t    abs_p = os.path.join(repo_root, clean)\n157\t    if abs_p not in dedup:\n158\t        dedup[abs_p] = (path, rel)\n159\t        if not os.path.isfile(abs_p):\n160\t            missing.append(f\"{path}={rel}\")\n161\t\n162\ttotal = len(dedup)\n163\tif missing:\n164\t    print(f\"FAIL fehlende Assets: {len(missing)}/{total} - \" + \"; \".join(missing[:5]))\n165\t    sys.exit(1)\n166\t\n167\tprint(f\"PASS {total} Asset-Refs geprueft, alle vorhanden\")\n168\tPY\n169\t  )\"\n170\t  DEPLOY_02_RC=$?\n171\t  if [ \"$DEPLOY_02_RC\" -eq 0 ]; then\n172\t    report \"DEPLOY-02\" \"PASS\" \"${DEPLOY_02_OUT#PASS }\"\n173\t  else\n174\t    report \"DEPLOY-02\" \"FAIL\" \"${DEPLOY_02_OUT#FAIL }\"\n175\t  fi\n176\tfi\n177\t\n178\t# ------------------------------------------------------------------\n179\t# DEPLOY-03: Titel-Byte-Identitaet data.json.meta.titel vs. Landing-Page <li>\n180\t# ------------------------------------------------------------------\n181\tif [ ! -f \"$DATA_JSON\" ] || [ ! -f \"$LANDING_HTML\" ]; then\n182\t  report \"DEPLOY-03\" \"FAIL\" \"data.json oder Landing-HTML fehlt\"\n183\telse\n184\t  DEPLOY_03_OUT=\"$(python3 - \"$DATA_JSON\" \"$LANDING_HTML\" \"$GAME_ID\" <<'PY' 2>&1\n185\timport json, re, sys\n186\t\n187\tdata_json_path, landing_html_path, game_id = sys.argv[1], sys.argv[2], sys.argv[3]\n188\t\n189\ttry:\n190\t    with open(data_json_path, 'r', encoding='utf-8') as f:\n191\t        d = json.load(f)\n192\t    titel_soll = d.get(\"meta\", {}).get(\"titel\", \"\")\n193\texcept Exception as e:\n194\t    print(f\"FAIL data.json unlesbar: {e}\")\n195\t    sys.exit(1)\n196\t\n197\tif not titel_soll:\n198\t    print(\"FAIL data.json.meta.titel leer\")\n199\t    sys.exit(1)\n200\t\n201\ttry:\n202\t    with open(landing_html_path, 'r', encoding='utf-8') as f:\n203\t        html_raw = f.read()\n204\texcept Exception as e:\n205\t    print(f\"FAIL Landing-HTML unlesbar: {e}\")\n206\t    sys.exit(1)\n207\t\n208\t# Preprocessing: HTML-Kommentare und <style>/<script>-Bloecke entfernen,\n209\t# damit li-Regex nicht in Nicht-Content-Bereiche greift\n210\thtml = re.sub(r'<!--.*?-->', '', html_raw, flags=re.DOTALL)\n211\thtml = re.sub(r'<style\\b[^>]*>.*?</style>', '', html, flags=re.DOTALL | re.IGNORECASE)\n212\thtml = re.sub(r'<script\\b[^>]*>.*?</script>', '', html, flags=re.DOTALL | re.IGNORECASE)\n213\t\n214\t# Finde <li> das den game_id enthaelt (entweder via id=\"game-<game-id>\" oder href)\n215\tli_candidates = re.findall(r'<li\\b[^>]*>.*?</li>', html, re.DOTALL)\n216\ttarget_li = None\n217\tfor cand in li_candidates:\n218\t    if f\"escape-games/{game_id}\" in cand or f'id=\"game-{game_id}\"' in cand:\n219\t        target_li = cand\n220\t        break\n221\t\n222\tif not target_li:\n223\t    print(f\"FAIL <li> fuer {game_id} nicht im Landing-HTML\")\n224\t    sys.exit(1)\n225\t\n226\t# Extrahiere sichtbaren Text: entferne alle Tags\n227\tvisible_text = re.sub(r'<[^>]+>', ' ', target_li)\n228\t# Whitespace-Normalisierung\n229\tvisible_norm = re.sub(r'\\s+', ' ', visible_text).strip()\n230\ttitel_norm = re.sub(r'\\s+', ' ', titel_soll).strip()\n231\t\n232\tif titel_norm in visible_norm:\n233\t    print(f\"PASS Titel '{titel_norm}' im <li> enthalten\")\n234\telse:\n235\t    print(f\"FAIL Titel-Drift: data.json='{titel_norm}' vs. <li>='{visible_norm[:200]}'\")\n236\t    sys.exit(1)\n237\tPY\n238\t  )\"\n239\t  DEPLOY_03_RC=$?\n240\t  if [ \"$DEPLOY_03_RC\" -eq 0 ]; then\n241\t    report \"DEPLOY-03\" \"PASS\" \"${DEPLOY_03_OUT#PASS }\"\n242\t  else\n243\t    report \"DEPLOY-03\" \"FAIL\" \"${DEPLOY_03_OUT#FAIL }\"\n244\t  fi\n245\tfi\n246\t\n247\t# ------------------------------------------------------------------\n248\t# DEPLOY-04: mappen[].length == Anzahl mappe-*.html\n249\t# ------------------------------------------------------------------\n250\tif [ ! -f \"$DATA_JSON\" ] || [ ! -d \"$GAME_DIR\" ]; then\n251\t  report \"DEPLOY-04\" \"FAIL\" \"data.json oder Game-Dir fehlt\"\n252\telse\n253\t  DEPLOY_04_OUT=\"$(python3 - \"$DATA_JSON\" \"$GAME_DIR\" <<'PY' 2>&1\n254\timport json, os, re, sys\n255\tdata_json_path, game_dir = sys.argv[1], sys.argv[2]\n256\ttry:\n257\t    with open(data_json_path, 'r', encoding='utf-8') as f:\n258\t        d = json.load(f)\n259\texcept Exception as e:\n260\t    print(f\"FAIL data.json unlesbar: {e}\")\n261\t    sys.exit(1)\n262\tmappen = d.get(\"mappen\", [])\n263\tjson_count = len(mappen)\n264\thtml_files = [f for f in os.listdir(game_dir) if re.match(r'^mappe-\\d+\\.html$', f)]\n265\thtml_count = len(html_files)\n266\tif json_count == html_count:\n267\t    print(f\"PASS data.json.mappen={json_count}, mappe-*.html={html_count}\")\n268\telse:\n269\t    print(f\"FAIL data.json.mappen={json_count} aber mappe-*.html={html_count} ({sorted(html_files)})\")\n270\t    sys.exit(1)\n271\tPY\n272\t  )\"\n273\t  DEPLOY_04_RC=$?\n274\t  if [ \"$DEPLOY_04_RC\" -eq 0 ]; then\n275\t    report \"DEPLOY-04\" \"PASS\" \"${DEPLOY_04_OUT#PASS }\"\n276\t  else\n277\t    report \"DEPLOY-04\" \"FAIL\" \"${DEPLOY_04_OUT#FAIL }\"\n278\t  fi\n279\tfi\n280\t\n281\t# ------------------------------------------------------------------\n282\t# DEPLOY-05: Game-index.html existiert + Engine + data.json-Verweis\n283\t# ------------------------------------------------------------------\n284\tif [ ! -f \"$GAME_INDEX_HTML\" ]; then\n285\t  report \"DEPLOY-05\" \"FAIL\" \"$GAME_INDEX_HTML fehlt\"\n286\telse\n287\t  if grep -q 'escape-engine' \"$GAME_INDEX_HTML\" && grep -q 'data\\.json' \"$GAME_INDEX_HTML\"; then\n288\t    report \"DEPLOY-05\" \"PASS\" \"index.html referenziert escape-engine + data.json\"\n289\t  else\n290\t    missing=\"\"\n291\t    if ! grep -q 'escape-engine' \"$GAME_INDEX_HTML\"; then missing=\"${missing}escape-engine \"; fi\n292\t    if ! grep -q 'data\\.json' \"$GAME_INDEX_HTML\"; then missing=\"${missing}data.json\"; fi\n293\t    report \"DEPLOY-05\" \"FAIL\" \"fehlende Verweise: $missing\"\n294\t  fi\n295\tfi\n296\t\n297\t# ------------------------------------------------------------------\n298\t# DEPLOY-06: Mappe-Struktur-Vollstaendigkeit (sicherung.hefteintrag)\n299\t# Prueft, dass jede Mappe die Engine-kritischen Substrukturen enthaelt.\n300\t# Eingefuehrt nach Assembly-Defekt: hefteintrag fehlte in sicherung.\n301\t# ------------------------------------------------------------------\n302\tif [ ! -f \"$DATA_JSON\" ]; then\n303\t  report \"DEPLOY-06\" \"FAIL\" \"data.json fehlt (vgl. DEPLOY-01)\"\n304\telse\n305\t  DEPLOY_06_OUT=\"$(python3 - \"$DATA_JSON\" <<'PY' 2>&1\n306\timport json, sys\n307\t\n308\tdata_json_path = sys.argv[1]\n309\ttry:\n310\t    with open(data_json_path, 'r', encoding='utf-8') as f:\n311\t        d = json.load(f)\n312\texcept Exception as e:\n313\t    print(f\"FAIL data.json unlesbar: {e}\")\n314\t    sys.exit(1)\n315\t\n316\terrors = []\n317\tmappen = d.get(\"mappen\", [])\n318\tfor i, mappe in enumerate(mappen):\n319\t    m_id = mappe.get(\"id\", f\"mappen[{i}]\")\n320\t\n321\t    # 1. einstieg vorhanden\n322\t    if not isinstance(mappe.get(\"einstieg\"), dict):\n323\t        errors.append(f\"{m_id}: einstieg fehlt oder kein Objekt\")\n324\t\n325\t    # 2. materialien vorhanden und nicht leer\n326\t    mats = mappe.get(\"materialien\", [])\n327\t    if not isinstance(mats, list) or len(mats) == 0:\n328\t        errors.append(f\"{m_id}: materialien fehlt oder leer\")\n329\t\n330\t    # 3. aufgaben vorhanden und nicht leer\n331\t    aufs = mappe.get(\"aufgaben\", [])\n332\t    if not isinstance(aufs, list) or len(aufs) == 0:\n333\t        errors.append(f\"{m_id}: aufgaben fehlt oder leer\")\n334\t\n335\t    # 4. sicherung.hefteintrag als Objekt mit knoten[] und stundenfrage\n336\t    sich = mappe.get(\"sicherung\", {})\n337\t    if not isinstance(sich, dict):\n338\t        errors.append(f\"{m_id}: sicherung fehlt oder kein Objekt\")\n339\t        continue\n340\t\n341\t    he = sich.get(\"hefteintrag\")\n342\t    if not isinstance(he, dict):\n343\t        errors.append(f\"{m_id}: sicherung.hefteintrag fehlt oder kein Objekt\")\n344\t        continue\n345\t\n346\t    knoten = he.get(\"knoten\", [])\n347\t    if not isinstance(knoten, list) or len(knoten) == 0:\n348\t        errors.append(f\"{m_id}: sicherung.hefteintrag.knoten fehlt oder leer\")\n349\t\n350\t    sf = he.get(\"stundenfrage\", \"\")\n351\t    if not isinstance(sf, str) or not sf.strip():\n352\t        errors.append(f\"{m_id}: sicherung.hefteintrag.stundenfrage fehlt oder leer\")\n353\t\n354\t    scpl = he.get(\"scpl\")\n355\t    if scpl is None:\n356\t        errors.append(f\"{m_id}: sicherung.hefteintrag.scpl fehlt\")\n357\t\n358\tif errors:\n359\t    print(\"FAIL \" + \"; \".join(errors[:5]))\n360\t    sys.exit(1)\n361\t\n362\tprint(f\"PASS {len(mappen)} Mappe(n) strukturell vollstaendig (einstieg, materialien, aufgaben, sicherung.hefteintrag)\")\n363\tPY\n364\t  )\"\n365\t  DEPLOY_06_RC=$?\n366\t  if [ \"$DEPLOY_06_RC\" -eq 0 ]; then\n367\t    report \"DEPLOY-06\" \"PASS\" \"${DEPLOY_06_OUT#PASS }\"\n368\t  else\n369\t    report \"DEPLOY-06\" \"FAIL\" \"${DEPLOY_06_OUT#FAIL }\"\n370\t  fi\n371\tfi\n372\t\n373\t# ------------------------------------------------------------------\n374\t# Gesamt-Urteil + Q-GATE-LOG (P0-A1 / F-RA1-05)\n375\t# ------------------------------------------------------------------\n376\techo \"---\"\n377\tTS_UTC=\"$(date -u +%Y-%m-%dT%H:%M:%SZ)\"\n378\t\n379\tif [ \"$FAIL\" -eq 0 ]; then\n380\t  echo \"GESAMT: PASS\"\n381\t  Q_LINE=\"[Q-GATE-LOG] DEPLOY_CHECK=PASS GAME=$GAME_ID MAPPE=$MAPPE_SCOPE TS=$TS_UTC SCRIPT_VERSION=$SCRIPT_VERSION\"\n382\t  echo \"$Q_LINE\"\n383\t  echo \"$Q_LINE\" >> \"$Q_GATE_LOG_FILE\"\n384\t  exit 0\n385\telse\n386\t  echo \"GESAMT: FAIL\"\n387\t  FAILED_STR=\"$(IFS=,; echo \"${FAILED_GATES[*]}\")\"\n388\t  Q_LINE=\"[Q-GATE-LOG] DEPLOY_CHECK=FAIL GAME=$GAME_ID MAPPE=$MAPPE_SCOPE TS=$TS_UTC SCRIPT_VERSION=$SCRIPT_VERSION FAILED_GATES=$FAILED_STR\"\n389\t  echo \"$Q_LINE\"\n390\t  echo \"$Q_LINE\" >> \"$Q_GATE_LOG_FILE\"\n391\t  exit 1\n392\tfi\n393\t"}]},"parent_tool_use_id":null,"session_id":"7b48050f-9a71-4508-a0e9-cf74193b5dd7","uuid":"e5b778c9-a0ab-4e30-9ff8-4b9dc756316e","timestamp":"2026-04-19T19:51:09.899Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/paulad/weitergehts.online/weitergehts-online/tools/deploy-check.sh","content":"#!/usr/bin/env bash\n# tools/deploy-check.sh\n# Phase 3.1 Deploy-Preparation Q-Gate (v3.11)\n# Prueft DEPLOY-01..DEPLOY-05 gegen das TARGET-Repo-Arbeitsverzeichnis.\n#\n# Aufruf:  ./tools/deploy-check.sh <game-id>\n# Exit:    0 = alle PASS, 1 = mindestens ein FAIL, 2 = infrastruktureller Fehler\n#\n# Q-Gate-Katalog: architektur/Q-GATE-MECHANIK.md §7.7 (escape-game-generator Repo)\n# Vertrag:        architektur/vertraege/VERTRAG_PHASE_3-1_DEPLOY.md\n#\n# Voraussetzungen: bash, python3 (>=3.8), grep, find, awk\n\nset -u\n\nGAME_ID=\"${1:-}\"\nMAPPE_SCOPE=\"${2:-ALL}\"   # optional zweites Argument: konkrete Mappe-Nummer oder ALL (Default)\nif [ -z \"$GAME_ID\" ]; then\n  echo \"usage: $0 <game-id> [mappe-n|ALL]\" >&2\n  exit 2\nfi\n\n# Repo-Root relativ zum Script (Script liegt in tools/)\nSCRIPT_DIR=\"$(cd -- \"$(dirname -- \"${BASH_SOURCE[0]}\")\" &> /dev/null && pwd)\"\nREPO_ROOT=\"$(cd -- \"$SCRIPT_DIR/..\" &> /dev/null && pwd)\"\ncd \"$REPO_ROOT\" || { echo \"cannot cd to repo root: $REPO_ROOT\" >&2; exit 2; }\n\nGAME_DIR=\"escape-games/$GAME_ID\"\nDATA_JSON=\"$GAME_DIR/data.json\"\nGAME_INDEX_HTML=\"$GAME_DIR/index.html\"\nLANDING_HTML=\"index.html\"\n\n# Q-GATE-LOG Infrastruktur (P0-A1 / F-RA1-05)\nQ_GATE_LOG_DIR=\"$SCRIPT_DIR/q-gate-log\"\nQ_GATE_LOG_FILE=\"$Q_GATE_LOG_DIR/$GAME_ID.log\"\nmkdir -p \"$Q_GATE_LOG_DIR\"\nSCRIPT_VERSION=\"$(git -C \"$REPO_ROOT\" rev-parse --short HEAD 2>/dev/null || echo 'unknown')\"\n\nFAIL=0\ndeclare -a RESULTS\ndeclare -a FAILED_GATES\n\nreport() {\n  # $1 = ID, $2 = PASS|FAIL, $3 = diagnose\n  local line=\"$1: $2 $3\"\n  RESULTS+=(\"$line\")\n  echo \"$line\"\n  if [ \"$2\" = \"FAIL\" ]; then\n    FAIL=1\n    FAILED_GATES+=(\"$1\")\n  fi\n}\n\n# ------------------------------------------------------------------\n# DEPLOY-01: data.json existiert, JSON-valide, Pflichtfelder vorhanden\n# ------------------------------------------------------------------\nif [ ! -f \"$DATA_JSON\" ]; then\n  report \"DEPLOY-01\" \"FAIL\" \"$DATA_JSON fehlt\"\nelse\n  DEPLOY_01_OUT=\"$(python3 - \"$DATA_JSON\" <<'PY' 2>&1\nimport json, sys\np = sys.argv[1]\ntry:\n    with open(p, 'r', encoding='utf-8') as f:\n        d = json.load(f)\nexcept json.JSONDecodeError as e:\n    print(f\"FAIL JSON-Parse-Fehler: {e}\")\n    sys.exit(1)\nexcept Exception as e:\n    print(f\"FAIL Lese-Fehler: {e}\")\n    sys.exit(1)\nmeta = d.get(\"meta\", {})\ntitel = meta.get(\"titel\")\nmappen = d.get(\"mappen\", [])\nif not isinstance(titel, str) or not titel.strip():\n    print(\"FAIL meta.titel fehlt oder leer\")\n    sys.exit(1)\nif not isinstance(mappen, list) or len(mappen) == 0:\n    print(\"FAIL mappen[] fehlt oder leer\")\n    sys.exit(1)\nprint(f\"PASS titel=\\\"{titel}\\\" mappen.len={len(mappen)}\")\nPY\n  )\"\n  DEPLOY_01_RC=$?\n  if [ \"$DEPLOY_01_RC\" -eq 0 ]; then\n    report \"DEPLOY-01\" \"PASS\" \"${DEPLOY_01_OUT#PASS }\"\n  else\n    report \"DEPLOY-01\" \"FAIL\" \"${DEPLOY_01_OUT#FAIL }\"\n  fi\nfi\n\n# ------------------------------------------------------------------\n# DEPLOY-02: Alle referenzierten Asset-Pfade existieren\n# ------------------------------------------------------------------\nif [ ! -f \"$DATA_JSON\" ]; then\n  report \"DEPLOY-02\" \"FAIL\" \"data.json fehlt (vgl. DEPLOY-01)\"\nelse\n  DEPLOY_02_OUT=\"$(python3 - \"$DATA_JSON\" \"$REPO_ROOT\" \"$GAME_DIR\" <<'PY' 2>&1\nimport json, os, sys, re\n\ndata_json_path = sys.argv[1]\nrepo_root = sys.argv[2]\ngame_dir = sys.argv[3]  # escape-games/<game-id>\n\ntry:\n    with open(data_json_path, 'r', encoding='utf-8') as f:\n        d = json.load(f)\nexcept Exception as e:\n    print(f\"FAIL data.json nicht lesbar: {e}\")\n    sys.exit(1)\n\n# Heuristik: rekursiv alle String-Werte, die wie Bild/Asset-Pfade aussehen\n# (nicht auf Feldnamen basierend, sondern auf Dateiendung + Pfad-Praefix)\nasset_ext = re.compile(r\"\\.(jpg|jpeg|png|webp|svg|gif)$\", re.IGNORECASE)\n# Praefix: relative Pfade, die auf assets/ oder auf ../../assets/ usw. zeigen\n# Absolute URLs (http://, https://) werden ignoriert\nabs_url = re.compile(r\"^https?://\")\n\nfound = []\n\ndef walk(obj, path=\"\"):\n    if isinstance(obj, dict):\n        for k, v in obj.items():\n            walk(v, f\"{path}.{k}\" if path else k)\n    elif isinstance(obj, list):\n        for i, v in enumerate(obj):\n            walk(v, f\"{path}[{i}]\")\n    elif isinstance(obj, str):\n        if abs_url.match(obj):\n            return\n        if asset_ext.search(obj):\n            # Exkludiere _meta.wikimedia_dateiname und aehnliche reine Metadaten\n            # Diese enthalten meist \"File:\" als Praefix oder sind keine echten Pfade\n            if obj.startswith(\"File:\"):\n                return\n            found.append((path, obj))\n\nwalk(d)\n\nmissing = []\ndedup = {}\nfor path, rel in found:\n    # Aufloesung: relative Pfade ab dem Spielverzeichnis\n    # (weil Game-HTML aus escape-games/<game-id>/ lae1dt)\n    if rel.startswith(\"../../\"):\n        # ../../assets/... -> repo_root/assets/...\n        clean = rel[6:].lstrip(\"/\")\n    elif rel.startswith(\"./\"):\n        clean = rel[2:]\n        clean = os.path.join(game_dir, clean)\n    elif rel.startswith(\"/\"):\n        clean = rel.lstrip(\"/\")\n    else:\n        # Interpretation: relativ zum game_dir\n        clean = os.path.join(game_dir, rel)\n    abs_p = os.path.join(repo_root, clean)\n    if abs_p not in dedup:\n        dedup[abs_p] = (path, rel)\n        if not os.path.isfile(abs_p):\n            missing.append(f\"{path}={rel}\")\n\ntotal = len(dedup)\nif missing:\n    print(f\"FAIL fehlende Assets: {len(missing)}/{total} - \" + \"; \".join(missing[:5]))\n    sys.exit(1)\n\nprint(f\"PASS {total} Asset-Refs geprueft, alle vorhanden\")\nPY\n  )\"\n  DEPLOY_02_RC=$?\n  if [ \"$DEPLOY_02_RC\" -eq 0 ]; then\n    report \"DEPLOY-02\" \"PASS\" \"${DEPLOY_02_OUT#PASS }\"\n  else\n    report \"DEPLOY-02\" \"FAIL\" \"${DEPLOY_02_OUT#FAIL }\"\n  fi\nfi\n\n# ------------------------------------------------------------------\n# DEPLOY-03: Titel-Byte-Identitaet data.json.meta.titel vs. Landing-Page <li>\n# ------------------------------------------------------------------\nif [ ! -f \"$DATA_JSON\" ] || [ ! -f \"$LANDING_HTML\" ]; then\n  report \"DEPLOY-03\" \"FAIL\" \"data.json oder Landing-HTML fehlt\"\nelse\n  DEPLOY_03_OUT=\"$(python3 - \"$DATA_JSON\" \"$LANDING_HTML\" \"$GAME_ID\" <<'PY' 2>&1\nimport json, re, sys\n\ndata_json_path, landing_html_path, game_id = sys.argv[1], sys.argv[2], sys.argv[3]\n\ntry:\n    with open(data_json_path, 'r', encoding='utf-8') as f:\n        d = json.load(f)\n    titel_soll = d.get(\"meta\", {}).get(\"titel\", \"\")\nexcept Exception as e:\n    print(f\"FAIL data.json unlesbar: {e}\")\n    sys.exit(1)\n\nif not titel_soll:\n    print(\"FAIL data.json.meta.titel leer\")\n    sys.exit(1)\n\ntry:\n    with open(landing_html_path, 'r', encoding='utf-8') as f:\n        html_raw = f.read()\nexcept Exception as e:\n    print(f\"FAIL Landing-HTML unlesbar: {e}\")\n    sys.exit(1)\n\n# Preprocessing: HTML-Kommentare und <style>/<script>-Bloecke entfernen,\n# damit li-Regex nicht in Nicht-Content-Bereiche greift\nhtml = re.sub(r'<!--.*?-->', '', html_raw, flags=re.DOTALL)\nhtml = re.sub(r'<style\\b[^>]*>.*?</style>', '', html, flags=re.DOTALL | re.IGNORECASE)\nhtml = re.sub(r'<script\\b[^>]*>.*?</script>', '', html, flags=re.DOTALL | re.IGNORECASE)\n\n# Finde <li> das den game_id enthaelt (entweder via id=\"game-<game-id>\" oder href)\nli_candidates = re.findall(r'<li\\b[^>]*>.*?</li>', html, re.DOTALL)\ntarget_li = None\nfor cand in li_candidates:\n    if f\"escape-games/{game_id}\" in cand or f'id=\"game-{game_id}\"' in cand:\n        target_li = cand\n        break\n\nif not target_li:\n    print(f\"FAIL <li> fuer {game_id} nicht im Landing-HTML\")\n    sys.exit(1)\n\n# Extrahiere sichtbaren Text: entferne alle Tags\nvisible_text = re.sub(r'<[^>]+>', ' ', target_li)\n# Whitespace-Normalisierung\nvisible_norm = re.sub(r'\\s+', ' ', visible_text).strip()\ntitel_norm = re.sub(r'\\s+', ' ', titel_soll).strip()\n\nif titel_norm in visible_norm:\n    print(f\"PASS Titel '{titel_norm}' im <li> enthalten\")\nelse:\n    print(f\"FAIL Titel-Drift: data.json='{titel_norm}' vs. <li>='{visible_norm[:200]}'\")\n    sys.exit(1)\nPY\n  )\"\n  DEPLOY_03_RC=$?\n  if [ \"$DEPLOY_03_RC\" -eq 0 ]; then\n    report \"DEPLOY-03\" \"PASS\" \"${DEPLOY_03_OUT#PASS }\"\n  else\n    report \"DEPLOY-03\" \"FAIL\" \"${DEPLOY_03_OUT#FAIL }\"\n  fi\nfi\n\n# ------------------------------------------------------------------\n# DEPLOY-04: mappen[].length == Anzahl mappe-*.html\n# ------------------------------------------------------------------\nif [ ! -f \"$DATA_JSON\" ] || [ ! -d \"$GAME_DIR\" ]; then\n  report \"DEPLOY-04\" \"FAIL\" \"data.json oder Game-Dir fehlt\"\nelse\n  DEPLOY_04_OUT=\"$(python3 - \"$DATA_JSON\" \"$GAME_DIR\" <<'PY' 2>&1\nimport json, os, re, sys\ndata_json_path, game_dir = sys.argv[1], sys.argv[2]\ntry:\n    with open(data_json_path, 'r', encoding='utf-8') as f:\n        d = json.load(f)\nexcept Exception as e:\n    print(f\"FAIL data.json unlesbar: {e}\")\n    sys.exit(1)\nmappen = d.get(\"mappen\", [])\njson_count = len(mappen)\nhtml_files = [f for f in os.listdir(game_dir) if re.match(r'^mappe-\\d+\\.html$', f)]\nhtml_count = len(html_files)\nif json_count == html_count:\n    print(f\"PASS data.json.mappen={json_count}, mappe-*.html={html_count}\")\nelse:\n    print(f\"FAIL data.json.mappen={json_count} aber mappe-*.html={html_count} ({sorted(html_files)})\")\n    sys.exit(1)\nPY\n  )\"\n  DEPLOY_04_RC=$?\n  if [ \"$DEPLOY_04_RC\" -eq 0 ]; then\n    report \"DEPLOY-04\" \"PASS\" \"${DEPLOY_04_OUT#PASS }\"\n  else\n    report \"DEPLOY-04\" \"FAIL\" \"${DEPLOY_04_OUT#FAIL }\"\n  fi\nfi\n\n# ------------------------------------------------------------------\n# DEPLOY-05: Game-index.html existiert + Engine + data.json-Verweis\n# ------------------------------------------------------------------\nif [ ! -f \"$GAME_INDEX_HTML\" ]; then\n  report \"DEPLOY-05\" \"FAIL\" \"$GAME_INDEX_HTML fehlt\"\nelse\n  if grep -q 'escape-engine' \"$GAME_INDEX_HTML\" && grep -q 'data\\.json' \"$GAME_INDEX_HTML\"; then\n    report \"DEPLOY-05\" \"PASS\" \"index.html referenziert escape-engine + data.json\"\n  else\n    missing=\"\"\n    if ! grep -q 'escape-engine' \"$GAME_INDEX_HTML\"; then missing=\"${missing}escape-engine \"; fi\n    if ! grep -q 'data\\.json' \"$GAME_INDEX_HTML\"; then missing=\"${missing}data.json\"; fi\n    report \"DEPLOY-05\" \"FAIL\" \"fehlende Verweise: $missing\"\n  fi\nfi\n\n# ------------------------------------------------------------------\n# DEPLOY-06: Mappe-Struktur-Vollstaendigkeit (sicherung.hefteintrag)\n# Prueft, dass jede Mappe die Engine-kritischen Substrukturen enthaelt.\n# Eingefuehrt nach Assembly-Defekt: hefteintrag fehlte in sicherung.\n# ------------------------------------------------------------------\nif [ ! -f \"$DATA_JSON\" ]; then\n  report \"DEPLOY-06\" \"FAIL\" \"data.json fehlt (vgl. DEPLOY-01)\"\nelse\n  DEPLOY_06_OUT=\"$(python3 - \"$DATA_JSON\" <<'PY' 2>&1\nimport json, sys\n\ndata_json_path = sys.argv[1]\ntry:\n    with open(data_json_path, 'r', encoding='utf-8') as f:\n        d = json.load(f)\nexcept Exception as e:\n    print(f\"FAIL data.json unlesbar: {e}\")\n    sys.exit(1)\n\nerrors = []\nmappen = d.get(\"mappen\", [])\nfor i, mappe in enumerate(mappen):\n    m_id = mappe.get(\"id\", f\"mappen[{i}]\")\n\n    # 1. einstieg vorhanden\n    if not isinstance(mappe.get(\"einstieg\"), dict):\n        errors.append(f\"{m_id}: einstieg fehlt oder kein Objekt\")\n\n    # 2. materialien vorhanden und nicht leer\n    mats = mappe.get(\"materialien\", [])\n    if not isinstance(mats, list) or len(mats) == 0:\n        errors.append(f\"{m_id}: materialien fehlt oder leer\")\n\n    # 3. aufgaben vorhanden und nicht leer\n    aufs = mappe.get(\"aufgaben\", [])\n    if not isinstance(aufs, list) or len(aufs) == 0:\n        errors.append(f\"{m_id}: aufgaben fehlt oder leer\")\n\n    # 4. sicherung.hefteintrag als Objekt mit knoten[] und stundenfrage\n    sich = mappe.get(\"sicherung\", {})\n    if not isinstance(sich, dict):\n        errors.append(f\"{m_id}: sicherung fehlt oder kein Objekt\")\n        continue\n\n    he = sich.get(\"hefteintrag\")\n    if not isinstance(he, dict):\n        errors.append(f\"{m_id}: sicherung.hefteintrag fehlt oder kein Objekt\")\n        continue\n\n    knoten = he.get(\"knoten\", [])\n    if not isinstance(knoten, list) or len(knoten) == 0:\n        errors.append(f\"{m_id}: sicherung.hefteintrag.knoten fehlt oder leer\")\n\n    sf = he.get(\"stundenfrage\", \"\")\n    if not isinstance(sf, str) or not sf.strip():\n        errors.append(f\"{m_id}: sicherung.hefteintrag.stundenfrage fehlt oder leer\")\n\n    scpl = he.get(\"scpl\")\n    if scpl is None:\n        errors.append(f\"{m_id}: sicherung.hefteintrag.scpl fehlt\")\n\nif errors:\n    print(\"FAIL \" + \"; \".join(errors[:5]))\n    sys.exit(1)\n\nprint(f\"PASS {len(mappen)} Mappe(n) strukturell vollstaendig (einstieg, materialien, aufgaben, sicherung.hefteintrag)\")\nPY\n  )\"\n  DEPLOY_06_RC=$?\n  if [ \"$DEPLOY_06_RC\" -eq 0 ]; then\n    report \"DEPLOY-06\" \"PASS\" \"${DEPLOY_06_OUT#PASS }\"\n  else\n    report \"DEPLOY-06\" \"FAIL\" \"${DEPLOY_06_OUT#FAIL }\"\n  fi\nfi\n\n# ------------------------------------------------------------------\n# Gesamt-Urteil + Q-GATE-LOG (P0-A1 / F-RA1-05)\n# ------------------------------------------------------------------\necho \"---\"\nTS_UTC=\"$(date -u +%Y-%m-%dT%H:%M:%SZ)\"\n\nif [ \"$FAIL\" -eq 0 ]; then\n  echo \"GESAMT: PASS\"\n  Q_LINE=\"[Q-GATE-LOG] DEPLOY_CHECK=PASS GAME=$GAME_ID MAPPE=$MAPPE_SCOPE TS=$TS_UTC SCRIPT_VERSION=$SCRIPT_VERSION\"\n  echo \"$Q_LINE\"\n  echo \"$Q_LINE\" >> \"$Q_GATE_LOG_FILE\"\n  exit 0\nelse\n  echo \"GESAMT: FAIL\"\n  FAILED_STR=\"$(IFS=,; echo \"${FAILED_GATES[*]}\")\"\n  Q_LINE=\"[Q-GATE-LOG] DEPLOY_CHECK=FAIL GAME=$GAME_ID MAPPE=$MAPPE_SCOPE TS=$TS_UTC SCRIPT_VERSION=$SCRIPT_VERSION FAILED_GATES=$FAILED_STR\"\n  echo \"$Q_LINE\"\n  echo \"$Q_LINE\" >> \"$Q_GATE_LOG_FILE\"\n  exit 1\nfi\n","numLines":393,"startLine":1,"totalLines":393}}}
