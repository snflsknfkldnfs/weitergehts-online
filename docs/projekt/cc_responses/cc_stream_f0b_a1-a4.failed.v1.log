tar(_mappe_[0-9]+)?\\\\.json$\",\n      \"description\": \"Relativer Pfad zu perspektiv_inventar.json dieser Mappe (z.B. 'mappe-3/registry/perspektiv_inventar.json'). Wird durch coverage-report.sh erzeugt.\"\n    }\n  },\n  \"allOf\": [\n    {\n      \"if\": {\n        \"properties\": {\n          \"trigger_categories_active\": {\n            \"type\": \"array\",\n            \"minItems\": 1\n          }\n        },\n        \"required\": [\n          \"trigger_categories_active\"\n        ]\n      },\n      \"then\": {\n        \"required\": [\n          \"perspektiv_inventar_ref\"\n        ]\n      }\n    }\n  ]\n}\n","structuredPatch":[],"originalFile":null,"userModified":false}}
{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_012SYqyN6huC1jRAzyrQyPnp","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01FyWNYWEaPqDJyiuvUmKi5f","name":"Write","input":{"file_path":"/Users/paulad/escape-game-generator/architektur/schemata/glossar_template.json","content":"{\n  \"$schema\": \"https://json-schema.org/draft/2020-12/schema\",\n  \"$id\": \"glossar_template.json\",\n  \"title\": \"Glossar-Eintrag (Material-Glossar, insb. Primaerquellen)\",\n  \"description\": \"Schema fuer einzelne Glossar-Eintraege in Materialien. Pflicht innerhalb material_source.kontextualisierung.glossar bei Primaerquellen, optional in anderen Materialien zur Erstnennung-Erklaerung. Erklaerungs-Text muss R7-konform sein (max 25 Wort/Satz, vgl. F0B_PRIMING_INCLUDE §1). Bei kolonialsprachlichen Begriffen ist alternative_begriffe Pflicht — Alternativen MUESSEN aus kolonial_terminologie_blacklist.json[*].alternativen referenziert werden.\",\n  \"type\": \"object\",\n  \"required\": [\n    \"begriff\",\n    \"erklaerung_r7\"\n  ],\n  \"properties\": {\n    \"begriff\": {\n      \"type\": \"string\",\n      \"minLength\": 1,\n      \"description\": \"Der Begriff im Originaltext (Quellensprache oder Fachterminus).\"\n    },\n    \"erklaerung_r7\": {\n      \"type\": \"string\",\n      \"minLength\": 5,\n      \"maxLength\": 250,\n      \"description\": \"Kurzerklaerung in R7-Sprache (max ~25 Woerter pro Satz, max 2 Saetze). sprachniveau-gate.js prueft dieses Feld separat (Glossar-Scope, eigener Schwellwert).\"\n    },\n    \"alternative_begriffe\": {\n      \"type\": \"array\",\n      \"items\": {\n        \"type\": \"string\"\n      },\n      \"description\": \"R7-konforme Alternativen, die im SuS-sichtbaren Begleittext statt des Originalbegriffs verwendet werden. Pflicht bei Treffern aus kolonial_terminologie_blacklist.json — Werte MUESSEN aus blacklist.alternativen-Liste stammen.\"\n    },\n    \"kategorie\": {\n      \"type\": \"string\",\n      \"enum\": [\n        \"kolonial_entmenschlichung\",\n        \"kolonial_hierarchisierung\",\n        \"kolonial_rechtfertigung\",\n        \"kolonial_eurozentrismus\",\n        \"rassistische_bezeichnung\",\n        \"kolonial_pauschalisierung\",\n        \"kolonial_euphemismus\",\n        \"fachbegriff_lp_qm\",\n        \"historische_bezeichnung_neutral\",\n        \"sonstiges\"\n      ],\n      \"description\": \"Klassifikation des Begriffs. Steuert Pflichtfelder (kolonial_* triggert alternative_begriffe-Pflicht).\"\n    },\n    \"quelle_blacklist_id\": {\n      \"type\": \"string\",\n      \"description\": \"Optional: Verweis auf kolonial_terminologie_blacklist.json[*].id wenn der Begriff dort gelistet ist.\"\n    }\n  },\n  \"allOf\": [\n    {\n      \"if\": {\n        \"properties\": {\n          \"kategorie\": {\n            \"enum\": [\n              \"kolonial_entmenschlichung\",\n              \"kolonial_hierarchisierung\",\n              \"kolonial_rechtfertigung\",\n              \"kolonial_eurozentrismus\",\n              \"rassistische_bezeichnung\",\n              \"kolonial_pauschalisierung\",\n              \"kolonial_euphemismus\"\n            ]\n          }\n        },\n        \"required\": [\n          \"kategorie\"\n        ]\n      },\n      \"then\": {\n        \"required\": [\n          \"alternative_begriffe\"\n        ],\n        \"properties\": {\n          \"alternative_begriffe\": {\n            \"minItems\": 1\n          }\n        }\n      }\n    }\n  ]\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1007,"cache_read_input_tokens":118527,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1007},"output_tokens":64,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"7b48050f-9a71-4508-a0e9-cf74193b5dd7","uuid":"d756d9b2-13b9-4db