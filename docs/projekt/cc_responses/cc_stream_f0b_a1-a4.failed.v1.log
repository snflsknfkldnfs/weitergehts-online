n2816\t      _saveFehlversuch(_state.mappeId);\n2817\t    }\n2818\t\n2819\t    _updateFortschritt(_getMappe(_state.mappeId), loadProgress(_state.mappeId));\n2820\t  }\n2821\t\n2822\t  // --- Reihenfolge -------------------------------------------------------\n2823\t\n2824\t  /**\n2825\t   * Rendert eine Reihenfolge-Aufgabe mit Hoch/Runter-Buttons.\n2826\t   * Erwartet optionen als Array (die korrekte Reihenfolge steht in loesung).\n2827\t   * @private\n2828\t   */\n2829\t  function _renderReihenfolge(container, aufgabe, index, geloest) {\n2830\t    var listeDiv = document.createElement('div');\n2831\t    listeDiv.className = 'aufgabe__reihenfolge';\n2832\t    listeDiv.id = aufgabe.id + '-reihenfolge';\n2833\t\n2834\t    // v3.5g: Bei geloest korrekte Reihenfolge anzeigen, sonst mischen\n2835\t    var state = geloest ? _loadAntwortState(_state.mappeId, index) : null;\n2836\t    var items;\n2837\t    if (geloest && state && state.order) {\n2838\t      items = state.order;\n2839\t    } else if (geloest) {\n2840\t      // Fallback: Loesung als Reihenfolge\n2841\t      items = Array.isArray(aufgabe.loesung) ? aufgabe.loesung : (aufgabe.optionen || []);\n2842\t    } else {\n2843\t      items = Core.utils.shuffleArray(aufgabe.optionen || aufgabe.elemente_ungeordnet || []);\n2844\t    }\n2845\t\n2846\t    for (var i = 0; i < items.length; i++) {\n2847\t      var itemEl = _createReihenfolgeItem(items[i], i, items.length, aufgabe.id, geloest);\n2848\t      listeDiv.appendChild(itemEl);\n2849\t    }\n2850\t\n2851\t    container.appendChild(listeDiv);\n2852\t\n2853\t    if (!geloest) {\n2854\t      var btn = document.createElement('button');\n2855\t      btn.className = 'aufgabe__submit';\n2856\t      btn.type = 'button';\n2857\t      btn.textContent = 'Reihenfolge prüfen';\n2858\t      btn.setAttribute('aria-label', 'Reihenfolge für Aufgabe ' + (index + 1) + ' prüfen');\n2859\t      btn.addEventListener('click', function () {\n2860\t        _checkReihenfolge(container.parentEl