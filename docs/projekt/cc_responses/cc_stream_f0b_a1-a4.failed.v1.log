{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01UxFjKgMUa8beqMvaW6GZsn","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01RJJhY56Tv14rH1Jg4ypzRg","name":"Write","input":{"file_path":"/Users/paulad/escape-game-generator/tools/priming-hash-check.sh","content":"#!/usr/bin/env bash\n# tools/priming-hash-check.sh — F0b A1.10 (V16)\n#\n# Liest architektur/sprachniveau_include_registry.json. Berechnet sha256 von\n# agents/_includes/F0B_PRIMING_INCLUDE.md und vergleicht mit\n# canonical_hash_sha256. Optional --strict prueft, dass alle Konsumenten-Prompts\n# die Marker-Tags [F0B_PRIMING_v1 BEGIN ... END] enthalten.\n#\n# Kontrakt: F0B_PRIMING_INCLUDE.md §0, sprachniveau_include_registry.json,\n# Assembly-Validator V16, QG-08 Teil b.\n#\n# Usage:\n#   tools/priming-hash-check.sh [--strict] [--json]\n#\n# Exit-Codes:\n#   0 = PASS\n#   1 = FAIL (Hash-Drift oder fehlende Marker)\n#   2 = Script-Bug\n\nset -u\n\nerr() { echo \"ERROR: $*\" >&2; }\n\nSTRICT=\"no\"\nJSON_OUT=\"no\"\nwhile [[ $# -gt 0 ]]; do\n  case \"$1\" in\n    --strict) STRICT=\"yes\"; shift ;;\n    --json)   JSON_OUT=\"yes\"; shift ;;\n    -h|--help)\n      echo \"usage: $0 [--strict] [--json]\"; exit 0 ;;\n    *) err \"unbekannter Arg: $1\"; exit 2 ;;\n  esac\ndone\n\nSCRIPT_DIR=\"$(cd -- \"$(dirname -- \"${BASH_SOURCE[0]}\")\" &> /dev/null && pwd)\"\nGEN_ROOT=\"$(cd -- \"$SCRIPT_DIR/..\" &> /dev/null && pwd)\"\nREG_FILE=\"$GEN_ROOT/architektur/sprachniveau_include_registry.json\"\nif [[ ! -f \"$REG_FILE\" ]]; then\n  err \"Registry nicht gefunden: $REG_FILE\"; exit 2\nfi\n\nif ! command -v python3 >/dev/null 2>&1; then\n  err \"python3 nicht verfuegbar.\"; exit 2\nfi\n\npython3 - \"$GEN_ROOT\" \"$REG_FILE\" \"$STRICT\" \"$JSON_OUT\" <<'PY'\nimport json, os, sys, hashlib\n\ngen_root, reg_file, strict, json_out = sys.argv[1], sys.argv[2], sys.argv[3] == 'yes', sys.argv[4] == 'yes'\n\nwith open(reg_file, 'r', encoding='utf-8') as f:\n    reg = json.load(f)\n\nresults = []\noverall_pass = True\n\nfor inc in reg.get('includes', []):\n    inc_id = inc.get('id', '?')\n    inc_path = os.path.join(gen_root, inc.get('file', ''))\n    canonical = inc.get('canonical_hash_sha256', '')\n    marker_begin = inc.get('marker_begin', '')\n    marker_end = inc.get('marker_end', '')\n    konsumenten = inc.get('konsumenten', [])\n\n    entry = {\n        'id': inc_id,\n        'file': inc_path,\n        'canonical_hash_sha256': canonical,\n        'computed_hash_sha256': None,\n        'hash_match': False,\n        'strict_check': strict,\n        'consumer_results': [],\n        'consumers_with_marker': 0,\n        'consumers_without_marker': [],\n    }\n\n    if not os.path.isfile(inc_path):\n        entry['error'] = f'Include-File nicht gefunden: {inc_path}'\n        overall_pass = False\n        results.append(entry)\n        continue\n\n    h = hashlib.sha256()\n    with open(inc_path, 'rb') as f:\n        h.update(f.read())\n    computed = h.hexdigest()\n    entry['computed_hash_sha256'] = computed\n    entry['hash_match'] = (computed == canonical)\n    if not entry['hash_match']:\n        overall_pass = False\n\n    if strict:\n        for kons in konsumenten:\n            kons_path = os.path.join(gen_root, kons)\n            r = {'consumer': kons, 'exists': False, 'has_begin': False, 'has_end': False}\n            if not os.path.isfile(kons_path):\n                entry['consumers_without_marker'].append({**r, 'reason': 'file-missing'})\n                overall_pass = False\n                continue\n            r['exists'] = True\n            with open(kons_path, 'r', encoding='utf-8') as f:\n                txt = f.read()\n            r['has_begin'] = (marker_begin and marker_begin in txt) or False\n            r['has_end'] = (marker_end and marker_end in txt) or False\n            if r['has_begin'] and r['has_end']:\n                entry['consumers_with_marker'] += 1\n            else:\n                entry['consumers_without_marker'].append({**r, 'reason': 'marker-missing'})\n                overall_pass = False\n            entry['consumer_results'].append(r)\n\n    results.append(entry)\n\nreport = {\n    'pass': overall_pass,\n    'strict': strict,\n    'includes': results,\n}\n\nif json_out:\n    print(json.dumps(report, ensure_ascii=False, indent=2))\nelse:\n    for inc in results:\n        print(f\"INCLUDE: {inc['id']}\")\n        print(f\"  file:     {inc['file']}\")\n        print(f\"  canonical: {inc['canonical_hash_sha256']}\")\n        print(f\"  computed:  {inc.get('computed_hash_sha256')}\")\n        print(f\"  hash_match: {inc.get('hash_match')}\")\n        if 'error' in inc:\n            print(f\"  ERROR: {inc['error']}\")\n        if strict:\n            print(f\"  consumers_with_marker: {inc.get('consumers_with_marker')}\")\n            for w in inc.get('consumers_without_marker', []):\n                print(f\"  MISSING_MARKER: {w}\")\n    print(f\"OVERALL: {'PASS' if overall_pass else 'FAIL'}\")\n\nsys.exit(0 if overall_pass else 1)\nPY\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":3163,"cache_read_input_tokens":150495,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":3163},"output_tokens":3,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"7b48050f-9a71-4508-a0e9-cf74193b5dd7","uuid":"de063542-510a-4d99-9043-ff7d6c2c636b"}
