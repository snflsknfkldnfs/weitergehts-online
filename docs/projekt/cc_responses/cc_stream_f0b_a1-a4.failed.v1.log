ch (e) { die(2, 'blacklist laden: ' + e.message); }\ntry { wortschatz = JSON.parse(fs.readFileSync(WORTSCHATZ_FILE, 'utf8')); } catch (e) { die(2, 'wortschatz laden: ' + e.message); }\n\n// --- Inhaltsbasis laden (JSON oder Markdown) ---\nconst raw = fs.readFileSync(ibPath, 'utf8');\nlet ib = null;\nlet format = 'md';\ntry {\n  ib = JSON.parse(raw);\n  format = 'json';\n} catch (_) {\n  // Fallback Markdown\n  const lines = raw.split(/\\r?\\n/);\n  let title = '';\n  for (const l of lines) {\n    if (l.trim().startsWith('#')) { title = l.replace(/^#+\\s*/, '').trim(); break; }\n  }\n  ib = { title: title, lp_anker: raw, sachanalyse: { text: raw } };\n}\n\nconst title = (ib.title || '').trim();\nconst lp_anker = typeof ib.lp_anker === 'string' ? ib.lp_anker : JSON.stringify(ib.lp_anker || '');\nconst findings = [];\n\n// --- R-TITEL-1: Praezision ---\nconst MARKETING_BLACKLIST = ['spannend', 'cool', 'super', 'mega', 'krass', 'unglaublich', 'episch', 'awesome', 'fantastisch', 'aufregend'];\nconst titleLow = title.toLowerCase();\nfor (const m of MARKETING_BLACKLIST) {\n  if (new RegExp('\\\\b' + m + '\\\\w*', 'i').test(titleLow)) {\n    findings.push({ rule: 'R-TITEL-1', severity: 'FAIL', detail: 'Marketing-Keyword im Titel: \"' + m + '\"' });\n  }\n}\n\n// LB-kanonischer Terminus: Pruefe Praesenz mind. eines Fachbegriffs aus r7_fachwoerter_lexikon\nconst fachLex = wortschatz.r7_fachwoerter_lexikon || {};\nlet allFach = [];\nfor (const lb of Object.keys(fachLex)) {\n  if (lb === 'hinweis') continue;\n  const arr = fachLex[lb];\n  if (Array.isArray(arr)) allFach = allFach.concat(arr);\n}\nconst titleHasFach = allFach.some(f => titleLow.includes(f.toLowerCase()));\nif (!titleHasFach) {\n  findings.push({ rule: 'R-TITEL-1', severity: 'WARN', detail: 'Kein LB-kanonischer Terminus im Titel gefunden. Pruefe LP-QM-Anbindung.' });\n}\n\n// --- R-TITEL-2: LP-Anbindung ---\n// Mindestens 1 LB-ID-Referenz (z.B. \"LB1\", \"LB 4\", \"Lernbereich 7\")\n// + 1 Kompetenzerwartungs-Referenz (z.B. \"GPG7 6.X\", \"6.4.1\", \"Kompetenzerwartung\")\nconst lpaLow = lp_anker.toLowerCase();\nconst hasLbRef = /lb\\s*\\d|lernbereich\\s*\\d/i.test(lpaLow);\nconst hasKompRef = /kompetenz|gpg\\s*\\d|\\b\\d+\\.\\d+(\\.\\d+)?\\b/i.test(lpaLow);\nif (!hasLbRef) {\n  findings.push({ rule: 'R-TITEL-2', severity: 'FAIL', detail: 'lp_anker enthaelt keine LB-ID-Referenz (LBn / Lernbereich n).' });\n}\nif (!hasKompRef) {\n  findings.push({ rule: 'R-TITEL-2', severity: 'FAIL', detail: 'lp_anker enthaelt keine Kompetenzerwartungs-Referenz (z.B. GPG7 6.X.Y oder Kompetenzerwartung).' });\n}\n\n// --- R-TITEL-3: Perspektiv-Neutralitaet ---\n// (a) Blacklist-Match im Titel\nconst blEntries = blacklist.blacklist || [];\nfor (const entry of blEntries) {\n  for (const muster of entry.muster || []) {\n    if (titleLow.includes(muster.toLowerCase())) {\n      findings.push({\n        rule: 'R-TITEL-3',\n        severity: 'FAIL',\n        detail: 'Blacklist-Treffer im Titel: \"' + muster + '\" (Kategorie: ' + entry.kategorie + ', ID: ' + entry.id + ')',\n        alternativen: entry.alternativen,\n      });\n    }\n  }\n}\n// (b) Heuristische Herrscher-Vokabel-Dominanz: wenn Titel Herrscher-Wort enthaelt OHNE Gegenpol\nconst HERRSCHER = ['kaiser', 'koenig', 'fuerst', 'kanzler', 'general', 'gouverneur', 'herrscher'];\nconst GEGENPOL = ['volk', 'arbeiter', 'frauen', 'opfer', 'opposition', 'widerstand', 'kolonisierte', 'minderheit', 'kritik'];\nconst hasHerrscher = HERRSCHER.some(h => new RegExp('\\\\b' + h + '\\\\w*', 'i').test(titleLow));\nconst hasGegenpol = GEGENPOL.some(g => new RegExp('\\\\b' + g + '\\\\w*', 'i').test(titleLow));\nif (hasHerrscher && !hasGegenpol) {\n  findings.push({ rule: 'R-TITEL-3', severity: 'WARN', detail: 'Herrscher-Vokabel-Dominanz im Titel (kein erkennbarer Gegenpol).' });\n}\n\n// --- Ausgabe ---\nconst fails = findings.filter(f => f.severity === 'FAIL');\nconst warns = findings.filter(f => f.severity === 'WARN');\nconst report = {\n  inhaltsbasis: ibPath,\n  format: format,\n  title: title,\n  pass: fails.length === 0,\n  fail_count: fails.length,\n  warn_count: warns.length,\n  findings: findings,\n};\nconsole.log(JSON.stringify(report, null, 2));\nprocess.exit(fails.length === 0 ? 0 : 1);\n","structuredPatch":[],"originalFile":null,"userModified":false}}
{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_015rUSKNxbu6bHSgaifBUNPB","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01BpoVLYZ9a3h8pu56CarCCu","name":"Write","input":{"file_path":"/Users/paulad/escape-game-generator/tools/sprachniveau-gate.js","content":"#!/usr/bin/env node\n/*\n * tools/sprachniveau-gate.js — F0b A1.4 (M8'/QG-08 Teil a)\n *\n * Liest Text-Artefakte (materialien/*.json, aufgaben/*.json, hefteintrag/*.json,\n * skript/*.json|*.md) und berechnet pro Text-Feld:\n *\n *   - Ø Satzlaenge (Wortzahl/Satzanzahl) ≤ 15\n *   - max Satzlaenge ≤ 25 pro Satz\n *   - Fachwort-Dichte ≤ 12 % (Lexikon-Treffer / Gesamtwoerter, 2. Erwaehnung zaehlt nicht)\n *   - Morpheme/Wort ≤ 4 (Heuristik: Trennungs-Signale aus wortschatz_r7_core.morphem_heuristik)\n *   - Nominalstil-Quote ≤ 20 %\n *   - Konjunktiv-Quote ≤ 5 %\n *\n * Primaerquellen-Ausnahme: Felder mit is_original_zitat=true werden uebersprungen.\n *\n * Kontrakt: F0B_PRIMING_INCLUDE.md §1, VERTRAG_PHASE_3_ASSEMBLY V17, VERTRAG_SPRACHNIVEAU_R7.md.\n *\n * Usage:\n *   node tools/sprachniveau-gate.js <file-or-dir>\n *\n * Exit-Codes:\n *   0 = PASS\n *   1 = FAIL (Schwellenverletzung)\n *   2 = Script-Bug\n */\n'use strict';\n\nconst fs = require('fs');\nconst path = require('path');\n\nfunction die(code, msg) { console.error('ERROR:', msg); process.exit(code); }\n\nconst argv = process.argv.slice(2);\nif (argv.length < 1) die(2, 'usage: sprachniveau-gate.js <file-or-dir>');\nconst target = argv[0];\nif (!fs.existsSync(target)) die(2, 'Pfad nicht gefunden: ' + target);\n\nconst SCRIPT_DIR = __dirname;\nconst GEN_ROOT = path.resolve(SCRIPT_DIR, '..');\nconst WORTSCHATZ_FILE = path.join(GEN_ROOT, 'architektur', 'wortschatz_r7_core.json');\n\nlet wortschatz;\ntry { wortschatz = JSON.parse(fs.readFileSync(WORTSCHATZ_FILE, 'utf8')); } catch (e) { die(2, 'wortschatz laden: ' + e.message); }\n\n// --- Lexikon-Aufbau ---\nconst fachLex = wortschatz.r7_fachwoerter_lexikon || {};\nconst fachwoerter = new Set();\nfor (const lb of Object.keys(fachLex)) {\n  if (lb === 'hinweis') continue;\n  const arr = fachLex[lb];\n  if (Array.isArray(arr)) for (const w of arr) fachwoerter.add(w.toLowerCase());\n}\nconst morphSignale = (wortschatz.morphem_heuristik && wortschatz.morphem_heuristik.trennungs_signale) || [];\nconst nominalEnd = (wortschatz.nominalstil_endungen && wortschatz.nominalstil_endungen.marker) || [];\nconst konjForms = new Set(((wortschatz.konjunktiv_marker && wortschatz.konjunktiv_marker.formen) || []).map(s => s.toLowerCase()));\n\n// --- File-Sammlung ---\nfunction collectFiles(p) {\n  const st = fs.statSync(p);\n  if (st.isFile()) return [p];\n  const out = [];\n  function walk(d) {\n    for (const e of fs.readdirSync(d, { withFileTypes: true })) {\n      const fp = path.join(d, e.name);\n      if (e.isDirectory()) {\n        if (e.name === 'node_modules' || e.name.startsWith('.')) continue;\n        walk(fp);\n      } else if (e.isFile()) {\n        if (/\\.(json|md)$/i.test(e.name)) out.push(fp);\n      }\n    }\n  }\n  walk(p);\n  return out;\n}\n\n// --- Text-Felder aus Objekt extrahieren ---\nconst TEXT_FIELDS = new Set([\n  'text', 'inhalt', 'beschreibung', 'legende', 'bildunterschrift', 'kontext',\n  'kontextsatz', 'satz', 'frage', 'merksatz', 'stem', 'stundenfrage',\n  'erwartungshorizont', 'feedback', 'loesung', 'erklaerung', 'erklaerung_r7',\n  'titel', 'chunk_text', 'ueberleitungssatz', 'reflexion_frage',\n]);\n\nfunction isOriginalZitatScope(parent) {\n  return parent && typeof parent === 'object' && parent.is_original_zitat === true;\n}\n\nfunction collectTextFields(obj, parent, jsonPath, acc) {\n  if (typeof obj === 'string') return;\n  if (Array.isArray(obj)) {\n    for (let i = 0; i < obj.length; i++) {\n      collectTextFields(obj[i], parent, jsonPath + '[' + i + ']', acc);\n    }\n    return;\n  }\n  if (obj && typeof obj === 'object') {\n    const skip = isOriginalZitatScope(obj);\n    for (const k of Object.keys(obj)) {\n      const v = obj[k];\n      const np = jsonPath ? jsonPath + '.' + k : k;\n      if (typeof v === 'string') {\n        if (!TEXT_FIELDS.has(k)) continue;\n        if (skip) {\n          acc.push({ path: np, text: v, skipped: true, reason: 'is_original_zitat=true' });\n        } else {\n          acc.push({ path: np, text: v, skipped: false });\n        }\n      } else if (typeof v === 'object' && v !== null) {\n        collectTextFields(v, obj, np, acc);\n      }\n    }\n  }\n}\n\nfunction collectFromMd(content) {\n  // Markdown: Zerlege in Abschnitte, behandle nicht-codierte Zeilen als Text\n  const out = [];\n  const blocks = content.split(/\\n{2,}/);\n  for (let i = 0; i < blocks.length; i++) {\n    const b = blocks[i].trim();\n    if (!b) continue;\n    if (b.startsWith('```')) continue;\n    if (b.startsWith('|') || b.startsWith('---')) continue;\n    out.push({ path: 'md.block[' + i + ']', text: b, skipped: false });\n  }\n  return out;\n}\n\n// --- Metrik-Berechnung ---\nfunction splitSentences(text) {\n  return text.split(/(?<=[.!?])\\s+(?=[A-ZÄÖÜ])/).map(s => s.trim()).filter(Boolean);\n}\n\nfunction tokenize(text) {\n  return text.toLowerCase().replace(/[^a-zäöüß\\-\\s]/g, ' ').split(/\\s+/).filter(Boolean);\n}\n\nfunction morphemCount(word) {\n  // Basis: 1 + Anzahl Trennungs-Signale, die als Suffix vorkommen\n  let count = 1;\n  for (const sig of morphSignale) {\n    const s = sig.replace(/^-/, '');\n    if (word.endsWith(s) && word.length > s.length + 1) count += 1;\n  }\n  // Bindestrich-Komposita: jeder Bindestrich +1\n  count += (word.match(/-/g) || []).length;\n  return count;\n}\n\nfunction isNominalstilWord(word) {\n  for (const end of nominalEnd) {\n    const s = end.replace(/^-/, '');\n    if (word.endsWith(s) && word.length > s.length + 1) return true;\n  }\n  return false;\n}\n\nfunction isKonjSentence(s) {\n  const tokens = tokenize(s);\n  for (const t of tokens) if (konjForms.has(t)) return true;\n  return false;\n}\n\nfunction metrikFor(text) {\n  const sentences = splitSentences(text);\n  const sentenceLengths = sentences.map(s => tokenize(s).length);\n  const allTokens = tokenize(text);\n  const wordCount = allTokens.length;\n  const sentenceCount = Math.max(sentences.length, 1);\n\n  const avgLen = wordCount / sentenceCount;\n  const maxLen = sentenceLengths.length ? Math.max(...sentenceLengths) : 0;\n\n  // Fachwort-Dichte (Erstnennung pro Wort)\n  const seen = new Set();\n  let fachHits = 0;\n  for (const t of allTokens) {\n    if (fachwoerter.has(t) && !seen.has(t)) {\n      fachHits += 1;\n      seen.add(t);\n    }\n  }\n  const fachQuote = wordCount ? fachHits / wordCount : 0;\n\n  // Morpheme pro Wort (Maxima zaehlen)\n  let maxMorpheme = 0;\n  let avgMorpheme = 0;\n  if (wordCount) {\n    const morphs = allTokens.map(morphemCount);\n    maxMorpheme = Math.max(...morphs);\n    avgMorpheme = morphs.reduce((a, b) => a + b, 0) / wordCount;\n  }\n\n  // Nominalstil-Anteil\n  let nomCount = 0;\n  for (const t of allTokens) if (isNominalstilWord(t)) nomCount += 1;\n  const nomQuote = wordCount ? nomCount / wordCount : 0;\n\n  // Konjunktiv-Anteil\n  let konjCount = 0;\n  for (const s of sentences) if (isKonjSentence(s)) konjCount += 1;\n  const konjQuote = sentenceCount ? konjCount / sentenceCount : 0;\n\n  return {\n    word_count: wordCount,\n    sentence_count: sentences.length,\n    avg_sentence_length: round2(avgLen),\n    max_sentence_length: maxLen,\n    fachwort_quote: round3(fachQuote),\n    fachwort_hits_unique: fachHits,\n    morpheme_avg: round2(avgMorpheme),\n    morpheme_max: maxMorpheme,\n    nominalstil_quote: round3(nomQuote),\n    konjunktiv_quote: round3(konjQuote),\n  };\n}\n\nfunction round2(x) { return Math.round(x * 100) / 100; }\nfunction round3(x) { return Math.round(x * 1000) / 1000; }\n\n// --- Schwellen ---\nconst LIM = {\n  avg_sentence_length: 15,\n  max_sentence_length: 25,\n  fachwort_quote: 0.12,\n  morpheme_max: 4,\n  nominalstil_quote: 0.20,\n  konjunktiv_quote: 0.05,\n};\n\nfunction checkLimits(m) {\n  const fails = [];\n  if (m.avg_sentence_length > LIM.avg_sentence_length) fails.push({ metric: 'avg_sentence_length', value: m.avg_sentence_length, limit: LIM.avg_sentence_length });\n  if (m.max_sentence_length > LIM.max_sentence_length) fails.push({ metric: 'max_sentence_length', value: m.max_sentence_length, limit: LIM.max_sentence_length });\n  if (m.fachwort_quote > LIM.fachwort_quote) fails.push({ metric: 'fachwort_quote', value: m.fachwort_quote, limit: LIM.fachwort_quote });\n  if (m.morpheme_max > LIM.morpheme_max) fails.push({ metric: 'morpheme_max', value: m.morpheme_max, limit: LIM.morpheme_max });\n  if (m.nominalstil_quote > LIM.nominalstil_quote) fails.push({ metric: 'nominalstil_quote', value: m.nominalstil_quote, limit: LIM.nominalstil_quote });\n  if (m.konjunktiv_quote > LIM.konjunktiv_quote) fails.push({ metric: 'konjunktiv_quote', value: m.konjunktiv_quote, limit: LIM.konjunktiv_quote });\n  return fails;\n}\n\n// --- Run ---\nconst files = collectFiles(target);\nconst fileReports = [];\nlet aggFail = 0;\nlet aggChecked = 0;\n\nfor (const f of files) {\n  let raw;\n  try { raw = fs.readFileSync(f, 'utf8'); } catch (e) { continue; }\n  let fields = [];\n  if (f.toLowerCase().endsWith('.json')) {\n    let obj;\n    try { obj = JSON.parse(raw); } catch (e) { fileReports.push({ file: f, error: 'json-parse: ' + e.message }); continue; }\n    collectTextFields(obj, null, '', fields);\n  } else if (f.toLowerCase().endsWith('.md')) {\n    fields = collectFromMd(raw);\n  }\n  const fileFindings = [];\n  for (const fld of fields) {\n    if (fld.skipped) {\n      fileFindings.push({ path: fld.path, skipped: true, reason: fld.reason });\n      continue;\n    }\n    if (!fld.text || fld.text.trim().length < 10) continue;\n    const m = metrikFor(fld.text);\n    const fails = checkLimits(m);\n    aggChecked += 1;\n    if (fails.length) {\n      aggFail += 1;\n      fileFindings.push({ path: fld.path, metrik: m, fails: fails });\n    }\n  }\n  fileReports.push({ file: f, fields_total: fields.length, findings: fileFindings });\n}\n\nconst exitCode = aggFail > 0 ? 1 : 0;\nconsole.log(JSON.stringify({\n  scope: target,\n  files_total: files.length,\n  fields_checked: aggChecked,\n  fields_failed: aggFail,\n  pass: exitCode === 0,\n  reports: fileReports,\n  limits: LIM,\n}, null, 2));\nprocess.exit(exitCode);\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":3151,"cache_read_input_tokens":130520,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":3151},"output_tokens":57,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"7b48050f-9a71-4508-a0e9-cf74193b5dd7","uuid":"79df54e9-95be-40be-9a84-a478cb8f333f"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BpoVLYZ9a3h8pu56CarCCu","type":"tool_result","content":"File created successfully at: /Users/paulad/escape-game-generator/tools/sprachniveau-gate.js (file state is current in your context — no need to Read it back)"}]},"parent_tool_use_id":null,"session_id":"7b48050f-9a71-4508-a0e9-cf74193b5dd7","uuid":"d6a76b41-385a-4395-9de2-05c00491aaf0","timestamp":"2026-04-19T19:57:41.887Z","tool_use_result":{"type":"create","filePath":"/Users/paulad/escape-game-generator/tools/sprachniveau-gate.js","content":"#!/usr/bin/env node\n/*\n * tools/sprachniveau-gate.js — F0b A1.4 (M8'/QG-08 Teil a)\n *\n * Liest Text-Artefakte (materialien/*.json, aufgaben/*.json, hefteintrag/*.json,\n * skript/*.json|*.md) und berechnet pro Text-Feld:\n *\n *   - Ø Satzlaenge (Wortzahl/Satzanzahl) ≤ 15\n *   - max Satzlaenge ≤ 25 pro Satz\n *   - Fachwort-Dichte ≤ 12 % (Lexikon-Treffer / Gesamtwoerter, 2. Erwaehnung zaehlt nicht)\n *   - Morpheme/Wort ≤ 4 (Heuristik: Trennungs-Signale aus wortschatz_r7_core.morphem_heuristik)\n *   - Nominalstil-Quote ≤ 20 %\n *   - Konjunktiv-Quote ≤ 5 %\n *\n * Primaerquellen-Ausnahme: Felder mit is_original_zitat=true werden uebersprungen.\n *\n * Kontrakt: F0B_PRIMING_INCLUDE.md §1, VERTRAG_PHASE_3_ASSEMBLY V17, VERTRAG_SPRACHNIVEAU_R7.md.\n *\n * Usage:\n *   node tools/sprachniveau-gate.js <file-or-dir>\n *\n * Exit-Codes:\n *   0 = PASS\n *   1 = FAIL (Schwellenverletzung)\n *   2 = Script-Bug\n */\n'use strict';\n\nconst fs = require('fs');\nconst path = require('path');\n\nfunction die(code, msg) { console.error('ERROR:', msg); process.exit(code); }\n\nconst argv = process.argv.slice(2);\nif (argv.length < 1) die(2, 'usage: sprachniveau-gate.js <file-or-dir>');\nconst target = argv[0];\nif (!fs.existsSync(target)) die(2, 'Pfad nicht gefunden: ' + target);\n\nconst SCRIPT_DIR = __dirname;\nconst GEN_ROOT = path.resolve(SCRIPT_DIR, '..');\nconst WORTSCHATZ_FILE = path.join(GEN_ROOT, 'architektur', 'wortschatz_r7_core.json');\n\nlet wortschatz;\ntry { wortschatz = JSON.parse(fs.readFileSync(WORTSCHATZ_FILE, 'utf8')); } catch (e) { die(2, 'wortschatz laden: ' + e.message); }\n\n// --- Lexikon-Aufbau ---\nconst fachLex = wortschatz.r7_fachwoerter_lexikon || {};\nconst fachwoerter = new Set();\nfor (const lb of Object.keys(fachLex)) {\n  if (lb === 'hinweis') continue;\n  const arr = fachLex[lb];\n  if (Array.isArray(arr)) for (const w of arr) fachwoerter.add(w.toLowerCase());\n}\nconst morphSignale = (wortschatz.morphem_heuristik && wortschatz.morphem_heuristik.trennungs_signale) || [];\nconst nominalEnd = (wortschatz.nominalstil_endungen && wortschatz.nominalstil_endungen.marker) || [];\nconst konjForms = new Set(((wortschatz.konjunktiv_marker && wortschatz.konjunktiv_marker.formen) || []).map(s => s.toLowerCase()));\n\n// --- File-Sammlung ---\nfunction collectFiles(p) {\n  const st = fs.statSync(p);\n  if (st.isFile()) return [p];\n  const out = [];\n  function walk(d) {\n    for (const e of fs.readdirSync(d, { withFileTypes: true })) {\n      const fp = path.join(d, e.name);\n      if (e.isDirectory()) {\n        if (e.name === 'node_modules' || e.name.startsWith('.')) continue;\n        walk(fp);\n      } else if (e.isFile()) {\n        if (/\\.(json|md)$/i.test(e.name)) out.push(fp);\n      }\n    }\n  }\n  walk(p);\n  return out;\n}\n\n// --- Text-Felder aus Objekt extrahieren ---\nconst TEXT_FIELDS = new Set([\n  'text', 'inhalt', 'beschreibung', 'legende', 'bildunterschrift', 'kontext',\n  'kontextsatz', 'satz', 'frage', 'merksatz', 'stem', 'stundenfrage',\n  'erwartungshorizont', 'feedback', 'loesung', 'erklaerung', 'erklaerung_r7',\n  'titel', 'chunk_text', 'ueberleitungssatz', 'reflexion_frage',\n]);\n\nfunction isOriginalZitatScope(parent) {\n  return parent && typeof parent === 'object' && parent.is_original_zitat === true;\n}\n\nfunction collectTextFields(obj, parent, jsonPath, acc) {\n  if (typeof obj === 'string') return;\n  if (Array.isArray(obj)) {\n    for (let i = 0; i < obj.length; i++) {\n      collectTextFields(obj[i], parent, jsonPath + '[' + i + ']', acc);\n    }\n    return;\n  }\n  if (obj && typeof obj === 'object') {\n    const skip = isOriginalZitatScope(obj);\n    for (const k of Object.keys(obj)) {\n      const v = obj[k];\n      const np = jsonPath ? jsonPath + '.' + k : k;\n      if (typeof v === 'string') {\n        if (!TEXT_FIELDS.has(k)) continue;\n        if (skip) {\n          acc.push({ path: np, text: v, skipped: true, reason: 'is_original_zitat=true' });\n        } else {\n          acc.push({ path: np, text: v, skipped: false });\n        }\n      } else if (typeof v === 'object' && v !== null) {\n        collectTextFields(v, obj, np, acc);\n      }\n    }\n  }\n}\n\nfunction collectFromMd(content) {\n  // Markdown: Zerlege in Abschnitte, behandle nicht-codierte Zeilen als Text\n  const out = [];\n  const blocks = content.split(/\\n{2,}/);\n  for (let i = 0; i < blocks.length; i++) {\n    const b = blocks[i].trim();\n    if (!b) continue;\n    if (b.startsWith('```')) continue;\n    if (b.startsWith('|') || b.startsWith('---')) continue;\n    out.push({ path: 'md.block[' + i + ']', text: b, skipped: false });\n  }\n  return out;\n}\n\n// --- Metrik-Berechnung ---\nfunction splitSentences(text) {\n  return text.split(/(?<=[.!?])\\s+(?=[A-ZÄÖÜ])/).map(s => s.trim()).filter(Boolean);\n}\n\nfunction tokenize(text) {\n  return text.toLowerCase().replace(/[^a-zäöüß\\-\\s]/g, ' ').split(/\\s+/).filter(Boolean);\n}\n\nfunction morphemCount(word) {\n  // Basis: 1 + Anzahl Trennungs-Signale, die als Suffix vorkommen\n  let count = 1;\n  for (const sig of morphSignale) {\n    const s = sig.replace(/^-/, '');\n    if (word.endsWith(s) && word.length > s.length + 1) count += 1;\n  }\n  // Bindestrich-Komposita: jeder Bindestrich +1\n  count += (word.match(/-/g) || []).length;\n  return count;\n}\n\nfunction isNominalstilWord(word) {\n  for (const end of nominalEnd) {\n    const s = end.replace(/^-/, '');\n    if (word.endsWith(s) && word.length > s.length + 1) return true;\n  }\n  return false;\n}\n\nfunction isKonjSentence(s) {\n  const tokens = tokenize(s);\n  for (const t of tokens) if (konjForms.has(t)) return true;\n  return false;\n}\n\nfunction metrikFor(text) {\n  const sentences = splitSentences(text);\n  const sentenceLengths = sentences.map(s => tokenize(s).length);\n  const allTokens = tokenize(text);\n  const wordCount = allTokens.length;\n  const sentenceCount = Math.max(sentences.length, 1);\n\n  const avgLen = wordCount / sentenceCount;\n  const maxLen = sentenceLengths.length ? Math.max(...sentenceLengths) : 0;\n\n  // Fachwort-Dichte (Erstnennung pro Wort)\n  const seen = new Set();\n  let fachHits = 0;\n  for (const t of allTokens) {\n    if (fachwoerter.has(t) && !seen.has(t)) {\n      fachHits += 1;\n      seen.add(t);\n    }\n  }\n  const fachQuote = wordCount ? fachHits / wordCount : 0;\n\n  // Morpheme pro Wort (Maxima zaehlen)\n  let maxMorpheme = 0;\n  let avgMorpheme = 0;\n  if (wordCount) {\n    const morphs = allTokens.map(morphemCount);\n    maxMorpheme = Math.max(...morphs);\n    avgMorpheme = morphs.reduce((a, b) => a + b, 0) / wordCount;\n  }\n\n  // Nominalstil-Anteil\n  let nomCount = 0;\n  for (const t of allTokens) if (isNominalstilWord(t)) nomCount += 1;\n  const nomQuote = wordCount ? nomCount / wordCount : 0;\n\n  // Konjunktiv-Anteil\n  let konjCount = 0;\n  for (const s of sentences) if (isKonjSentence(s)) konjCount += 1;\n  const konjQuote = sentenceCount ? konjCount / sentenceCount : 0;\n\n  return {\n    word_count: wordCount,\n    sentence_count: sentences.length,\n    avg_sentence_length: round2(avgLen),\n    max_sentence_length: maxLen,\n    fachwort_quote: round3(fachQuote),\n    fachwort_hits_unique: fachHits,\n    morpheme_avg: round2(avgMorpheme),\n    morpheme_max: maxMorpheme,\n    nominalstil_quote: round3(nomQuote),\n    konjunktiv_quote: round3(konjQuote),\n  };\n}\n\nfunction round2(x) { return Math.round(x * 100) / 100; }\nfunction round3(x) { return Math.round(x * 1000) / 1000; }\n\n// --- Schwellen ---\nconst LIM = {\n  avg_sentence_length: 15,\n  max_sentence_length: 25,\n  fachwort_quote: 0.12,\n  morpheme_max: 4,\n  nominalstil_quote: 0.20,\n  konjunktiv_quote: 0.05,\n};\n\nfunction checkLimits(m) {\n  const fails = [];\n  if (m.avg_sentence_length > LIM.avg_sentence_length) fails.push({ metric: 'avg_sentence_length', value: m.avg_sentence_length, limit: LIM.avg_sentence_length });\n  if (m.max_sentence_length > LIM.max_sentence_length) fails.push({ metric: 'max_sentence_length', value: m.max_sentence_length, limit: LIM.max_sentence_length });\n  if (m.fachwort_quote > LIM.fachwort_quote) fails.push({ metric: 'fachwort_quote', value: m.fachwort_quote, limit: LIM.fachwort_quote });\n  if (m.morpheme_max > LIM.morpheme_max) fails.push({ metric: 'morpheme_max', value: m.morpheme_max, limit: LIM.morpheme_max });\n  if (m.nominalstil_quote > LIM.nominalstil_quote) fails.push({ metric: 'nominalstil_quote', value: m.nominalstil_quote, limit: LIM.nominalstil_quote });\n  if (m.konjunktiv_quote > LIM.konjunktiv_quote) fails.push({ metric: 'konjunktiv_quote', value: m.konjunktiv_quote, limit: LIM.konjunktiv_quote });\n  return fails;\n}\n\n// --- Run ---\nconst files = collectFiles(target);\nconst fileReports = [];\nlet aggFail = 0;\nlet aggChecked = 0;\n\nfor (const f of files) {\n  let raw;\n  try { raw = fs.readFileSync(f, 'utf8'); } catch (e) { continue; }\n  let fields = [];\n  if (f.toLowerCase().endsWith('.json')) {\n    let obj;\n    try { obj = JSON.parse(raw); } catch (e) { fileReports.push({ file: f, error: 'json-parse: ' + e.message }); continue; }\n    collectTextFields(obj, null, '', fields);\n  } else if (f.toLowerCase().endsWith('.md')) {\n    fields = collectFromMd(raw);\n  }\n  const fileFindings = [];\n  for (const fld of fields) {\n    if (fld.skipped) {\n      fileFindings.push({ path: fld.path, skipped: true, reason: fld.reason });\n      continue;\n    }\n    if (!fld.text || fld.text.trim().length < 10) continue;\n    const m = metrikFor(fld.text);\n    const fails = checkLimits(m);\n    aggChecked += 1;\n    if (fails.length) {\n      aggFail += 1;\n      fileFindings.push({ path: fld.path, metrik: m, fails: fails });\n    }\n  }\n  fileReports.push({ file: f, fields_total: fields.length, findings: fileFindings });\n}\n\nconst exitCode = aggFail > 0 ? 1 : 0;\nconsole.log(JSON.stringify({\n  scope: target,\n  files_total: files.length,\n  fields_checked: aggChecked,\n  fields_failed: aggFail,\n  pass: exitCode === 0,\n  reports: fileReports,\n  limits: LIM,\n}, null, 2));\nprocess.exit(exitCode);\n","structuredPatch":[],"originalFile":null,"userModified":false}}
{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01CnKbRj42qv3vG5SaB3trZ2","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01J34aT8iiNUX8sfAqUaLzNY","name":"Write","input":{"file_path":"/Users/paulad/escape-game-generator/tools/coverage-report.sh","content":"#!/usr/bin/env bash\n# tools/coverage-report.sh — F0b A1.5 (V15)\n#\n# Aggregiert material.perspektiv_tags[] pro Mappe aus\n# escape-games/<scope>/materialien/*.json (oder analoger Source-Ablage).\n#\n# Output:\n#   - JSON-Bericht auf stdout (pro Mappe Zaehlung dominant/nicht_dominant)\n#   - Erzeugt registry/perspektiv_inventar(_mappe_N).json pro Mappe\n#   - Bei aktiver Trigger-Kategorie (INHALTSBASIS.trigger_categories): QG-06-Check\n#     (>=2 Materialien aus pool=nicht_dominant pro Mappe)\n#\n# Kontrakt: F0B_PRIMING_INCLUDE.md §2/§5, perspektiv_enum.json, V15.\n#\n# Usage:\n#   tools/coverage-report.sh <scope>\n#\n#   <scope> = Slug, der entweder\n#     (a) escape-games/<scope> im weitergehts-online-Repo bezeichnet, oder\n#     (b) docs/agents/artefakte/<scope> im weitergehts-online-Repo bezeichnet.\n#\n# Exit-Codes:\n#   0 = PASS (QG-06 erfuellt oder Trigger nicht aktiv)\n#   1 = FAIL (QG-06 verletzt)\n#   2 = Script-Bug\n\nset -u\n\nerr() { echo \"ERROR: $*\" >&2; }\n\nif [[ $# -lt 1 ]]; then\n  err \"usage: $0 <scope>\"\n  exit 2\nfi\n\nSCOPE=\"$1\"\n\nSCRIPT_DIR=\"$(cd -- \"$(dirname -- \"${BASH_SOURCE[0]}\")\" &> /dev/null && pwd)\"\nGEN_ROOT=\"$(cd -- \"$SCRIPT_DIR/..\" &> /dev/null && pwd)\"\nENUM_FILE=\"$GEN_ROOT/architektur/perspektiv_enum.json\"\n\nWO_ROOT_CANDIDATES=(\n  \"${WEITERGEHTS_ONLINE_ROOT:-}\"\n  \"$GEN_ROOT/../weitergehts.online/weitergehts-online\"\n  \"$GEN_ROOT/../weitergehts-online\"\n  \"$HOME/weitergehts.online/weitergehts-online\"\n)\nWO_ROOT=\"\"\nfor c in \"${WO_ROOT_CANDIDATES[@]}\"; do\n  if [[ -n \"$c\" && -d \"$c\" ]]; then WO_ROOT=\"$(cd -- \"$c\" && pwd)\"; break; fi\ndone\nif [[ -z \"$WO_ROOT\" ]]; then\n  err \"weitergehts-online-Repo nicht gefunden.\"\n  exit 2\nfi\n\nif ! command -v python3 >/dev/null 2>&1; then\n  err \"python3 nicht verfuegbar.\"; exit 2\nfi\n\npython3 - \"$SCOPE\" \"$WO_ROOT\" \"$ENUM_FILE\" <<'PY'\nimport json, os, sys, glob, re, datetime\n\nscope, wo_root, enum_file = sys.argv[1], sys.argv[2], sys.argv[3]\n\nwith open(enum_file, 'r', encoding='utf-8') as f:\n    enum_data = json.load(f)\npool_of = {e['id']: e['pool'] for e in enum_data.get('enum', [])}\ntrigger_active_kategorien = enum_data.get('coverage_regel_qg06', {}).get('bei_trigger_kategorie', [])\nmin_required = enum_data.get('coverage_regel_qg06', {}).get('min_materialien_aus_pool_nicht_dominant_pro_mappe', 2)\n\n# --- Scope-Pfade ermitteln ---\ncandidates = [\n    os.path.join(wo_root, 'escape-games', scope),\n    os.path.join(wo_root, 'docs', 'agents', 'artefakte', scope),\n]\nscope_roots = [c for c in candidates if os.path.isdir(c)]\nif not scope_roots:\n    print(json.dumps({'scope': scope, 'error': 'Scope-Verzeichnis nicht gefunden', 'candidates': candidates}, ensure_ascii=False, indent=2), file=sys.stderr)\n    sys.exit(2)\n\n# --- INHALTSBASIS aufspueren (fuer trigger_categories) ---\ntrigger_categories = []\nib_paths = []\nfor sr in scope_roots:\n    for p in glob.glob(os.path.join(sr, 'INHALTSBASIS*'), recursive=False):\n        ib_paths.append(p)\n    for p in glob.glob(os.path.join(sr, '**', 'INHALTSBASIS*'), recursive=True):\n        ib_paths.append(p)\nfor ib in ib_paths:\n    if not os.path.isfile(ib):\n        continue\n    try:\n        if ib.endswith('.json'):\n            with open(ib, 'r', encoding='utf-8') as f:\n                d = json.load(f)\n            tc = (d.get('header') or {}).get('trigger_categories') or d.get('trigger_categories')\n            if isinstance(tc, list):\n                trigger_categories = tc\n                break\n        else:\n            with open(ib, 'r', encoding='utf-8') as f:\n                txt = f.read()\n            m = re.search(r'trigger_categories\\s*[:=]\\s*\\[([^\\]]*)\\]', txt, re.IGNORECASE)\n            if m:\n                items = re.findall(r'[a-z_]+', m.group(1).lower())\n                trigger_categories = items\n                break\n    except Exception:\n        continue\ntrigger_relevant = any(t in trigger_active_kategorien for t in trigger_categories)\n\n# --- Materialien pro Mappe sammeln ---\ndef find_mappe_dirs(roots):\n    mappes = {}  # mappe_n -> dir\n    for sr in roots:\n        for entry in os.listdir(sr):\n            mpath = os.path.join(sr, entry)\n            if not os.path.isdir(mpath):\n                continue\n            m = re.match(r'^mappe[-_]?([0-9]+)$', entry, re.IGNORECASE)\n            if m:\n                mappes.setdefault(int(m.group(1)), []).append(mpath)\n    return mappes\n\nmappe_map = find_mappe_dirs(scope_roots)\nresults = []\noverall_fail = False\n\nfor mappe_n in sorted(mappe_map.keys()):\n    dirs = mappe_map[mappe_n]\n    materialien = []\n    for d in dirs:\n        for jp in glob.glob(os.path.join(d, '**', '*.json'), recursive=True):\n            base = os.path.basename(jp).lower()\n            if not (base.startswith('mat-') or 'material' in base):\n                continue\n            try:\n                with open(jp, 'r', encoding='utf-8') as f:\n                    obj = json.load(f)\n            except Exception:\n                continue\n            if not isinstance(obj, dict):\n                continue\n            tags = obj.get('perspektiv_tags')\n            if tags is None:\n                # Legacy: _meta.perspektive single-string -> map to enum if known\n                meta = obj.get('_meta') or {}\n                persp = meta.get('perspektive') or obj.get('perspektive')\n                if isinstance(persp, str):\n                    if persp in pool_of:\n                        tags = [persp]\n            mat_id = obj.get('id') or os.path.basename(jp)\n            materialien.append({'id': mat_id, 'file': jp, 'perspektiv_tags': tags or []})\n\n    # Aggregat\n    tag_to_mats = {}\n    for m in materialien:\n        for t in m['perspektiv_tags']:\n            if t not in pool_of:\n                continue\n            tag_to_mats.setdefault(t, []).append(m['id'])\n    tags_aggregiert = []\n    for t in sorted(tag_to_mats.keys()):\n        tags_aggregiert.append({'enum_id': t, 'pool': pool_of[t], 'material_ids': sorted(set(tag_to_mats[t]))})\n\n    nicht_dominant_mats = set()\n    for m in materialien:\n        for t in m['perspektiv_tags']:\n            if pool_of.get(t) == 'nicht_dominant':\n                nicht_dominant_mats.add(m['id'])\n                break\n\n    qg06_pass = (len(nicht_dominant_mats) >= min_required) or (not trigger_relevant)\n    if not qg06_pass:\n        overall_fail = True\n\n    inventar = {\n        'scope_id': scope,\n        'mappe_n': mappe_n,\n        'schema_version': '1.0',\n        'trigger_kategorie_aktiv': trigger_relevant,\n        'tags_aggregiert': tags_aggregiert,\n        'nicht_dominant_count': len(nicht_dominant_mats),\n        'qg06_pass': qg06_pass,\n        'erzeugt': datetime.datetime.utcnow().isoformat(timespec='seconds') + 'Z',\n    }\n\n    # Schreibe registry/perspektiv_inventar(_mappe_N).json\n    target_dir = dirs[0]\n    out_dir = os.path.join(target_dir, 'registry')\n    os.makedirs(out_dir, exist_ok=True)\n    out_file = os.path.join(out_dir, f'perspektiv_inventar_mappe_{mappe_n}.json')\n    try:\n        with open(out_file, 'w', encoding='utf-8') as f:\n            json.dump(inventar, f, ensure_ascii=False, indent=2)\n            f.write('\\n')\n    except Exception as e:\n        print(f'WARN inventar-write fehlgeschlagen ({out_file}): {e}', file=sys.stderr)\n\n    results.append({\n        'mappe_n': mappe_n,\n        'materialien_total': len(materialien),\n        'nicht_dominant_count': len(nicht_dominant_mats),\n        'qg06_pass': qg06_pass,\n        'inventar_file': out_file,\n        'tags_aggregiert': tags_aggregiert,\n    })\n\nreport = {\n    'scope': scope,\n    'trigger_categories': trigger_categories,\n    'trigger_relevant': trigger_relevant,\n    'min_required_nicht_dominant': min_required,\n    'mappe_count': len(results),\n    'overall_pass': not overall_fail,\n    'mappen': results,\n}\nprint(json.dumps(report, ensure_ascii=False, indent=2))\nsys.exit(1 if overall_fail else 0)\nPY\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":5033,"cache_read_input_tokens":133671,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":5033},"output_tokens":56,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"7b48050f-9a71-4508-a0e9-cf74193b5dd7","uuid":"362defb7-700d-4d20-91a1-a438e9a1a6a7"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01J34aT8iiNUX8sfAqUaLzNY","type":"tool_result","content":"File created successfully at: /Users/paulad/escape-game-generator/tools/coverage-report.sh (file state is current in your context — no need to Read it back)"}]},"parent_tool_use_id":null,"session_id":"7b48050f-9a71-4508-a0e9-cf74193b5dd7","uuid":"baf5140c-7abc-4332-a76c-e99f35eef2e0","timestamp":"2026-04-19T19:58:25.878Z","tool_use_result":{"type":"create","filePath":"/Users/paulad/escape-game-generator/tools/coverage-report.sh","content":"#!/usr/bin/env bash\n# tools/coverage-report.sh — F0b A1.5 (V15)\n#\n# Aggregiert material.perspektiv_tags[] pro Mappe aus\n# escape-games/<scope>/materialien/*.json (oder analoger Source-Ablage).\n#\n# Output:\n#   - JSON-Bericht auf stdout (pro Mappe Zaehlung dominant/nicht_dominant)\n#   - Erzeugt registry/perspektiv_inventar(_mappe_N).json pro Mappe\n#   - Bei aktiver Trigger-Kategorie (INHALTSBASIS.trigger_categories): QG-06-Check\n#     (>=2 Materialien aus pool=nicht_dominant pro Mappe)\n#\n# Kontrakt: F0B_PRIMING_INCLUDE.md §2/§5, perspektiv_enum.json, V15.\n#\n# Usage:\n#   tools/coverage-report.sh <scope>\n#\n#   <scope> = Slug, der entweder\n#     (a) escape-games/<scope> im weitergehts-online-Repo bezeichnet, oder\n#     (b) docs/agents/artefakte/<scope> im weitergehts-online-Repo bezeichnet.\n#\n# Exit-Codes:\n#   0 = PASS (QG-06 erfuellt oder Trigger nicht aktiv)\n#   1 = FAIL (QG-06 verletzt)\n#   2 = Script-Bug\n\nset -u\n\nerr() { echo \"ERROR: $*\" >&2; }\n\nif [[ $# -lt 1 ]]; then\n  err \"usage: $0 <scope>\"\n  exit 2\nfi\n\nSCOPE=\"$1\"\n\nSCRIPT_DIR=\"$(cd -- \"$(dirname -- \"${BASH_SOURCE[0]}\")\" &> /dev/null && pwd)\"\nGEN_ROOT=\"$(cd -- \"$SCRIPT_DIR/..\" &> /dev/null && pwd)\"\nENUM_FILE=\"$GEN_ROOT/architektur/perspektiv_enum.json\"\n\nWO_ROOT_CANDIDATES=(\n  \"${WEITERGEHTS_ONLINE_ROOT:-}\"\n  \"$GEN_ROOT/../weitergehts.online/weitergehts-online\"\n  \"$GEN_ROOT/../weitergehts-online\"\n  \"$HOME/weitergehts.online/weitergehts-online\"\n)\nWO_ROOT=\"\"\nfor c in \"${WO_ROOT_CANDIDATES[@]}\"; do\n  if [[ -n \"$c\" && -d \"$c\" ]]; then WO_ROOT=\"$(cd -- \"$c\" && pwd)\"; break; fi\ndone\nif [[ -z \"$WO_ROOT\" ]]; then\n  err \"weitergehts-online-Repo nicht gefunden.\"\n  exit 2\nfi\n\nif ! command -v python3 >/dev/null 2>&1; then\n  err \"python3 nicht verfuegbar.\"; exit 2\nfi\n\npython3 - \"$SCOPE\" \"$WO_ROOT\" \"$ENUM_FILE\" <<'PY'\nimport json, os, sys, glob, re, datetime\n\nscope, wo_root, enum_file = sys.argv[1], sys.argv[2], sys.argv[3]\n\nwith open(enum_file, 'r', encoding='utf-8') as f:\n    enum_data = json.load(f)\npool_of = {e['id']: e['pool'] for e in enum_data.get('enum', [])}\ntrigger_active_kategorien = enum_data.get('coverage_regel_qg06', {}).get('bei_trigger_kategorie', [])\nmin_required = enum_data.get('coverage_regel_qg06', {}).get('min_materialien_aus_pool_nicht_dominant_pro_mappe', 2)\n\n# --- Scope-Pfade ermitteln ---\ncandidates = [\n    os.path.join(wo_root, 'escape-games', scope),\n    os.path.join(wo_root, 'docs', 'agents', 'artefakte', scope),\n]\nscope_roots = [c for c in candidates if os.path.isdir(c)]\nif not scope_roots:\n    print(json.dumps({'scope': scope, 'error': 'Scope-Verzeichnis nicht gefunden', 'candidates': candidates}, ensure_ascii=False, indent=2), file=sys.stderr)\n    sys.exit(2)\n\n# --- INHALTSBASIS aufspueren (fuer trigger_categories) ---\ntrigger_categories = []\nib_paths = []\nfor sr in scope_roots:\n    for p in glob.glob(os.path.join(sr, 'INHALTSBASIS*'), recursive=False):\n        ib_paths.append(p)\n    for p in glob.glob(os.path.join(sr, '**', 'INHALTSBASIS*'), recursive=True):\n        ib_paths.append(p)\nfor ib in ib_paths:\n    if not os.path.isfile(ib):\n        continue\n    try:\n        if ib.endswith('.json'):\n            with open(ib, 'r', encoding='utf-8') as f:\n                d = json.load(f)\n            tc = (d.get('header') or {}).get('trigger_categories') or d.get('trigger_categories')\n            if isinstance(tc, list):\n                trigger_categories = tc\n                break\n        else:\n            with open(ib, 'r', encoding='utf-8') as f:\n                txt = f.read()\n            m = re.search(r'trigger_categories\\s*[:=]\\s*\\[([^\\]]*)\\]', txt, re.IGNORECASE)\n            if m:\n                items = re.findall(r'[a-z_]+', m.group(1).lower())\n                trigger_categories = items\n                break\n    except Exception:\n        continue\ntrigger_relevant = any(t in trigger_active_kategorien for t in trigger_categories)\n\n# --- Materialien pro Mappe sammeln ---\ndef find_mappe_dirs(roots):\n    mappes = {}  # mappe_n -> dir\n    for sr in roots:\n        for entry in os.listdir(sr):\n            mpath = os.path.join(sr, entry)\n            if not os.path.isdir(mpath):\n                continue\n            m = re.match(r'^mappe[-_]?([0-9]+)$', entry, re.IGNORECASE)\n            if m:\n                mappes.setdefault(int(m.group(1)), []).append(mpath)\n    return mappes\n\nmappe_map = find_mappe_dirs(scope_roots)\nresults = []\noverall_fail = False\n\nfor mappe_n in sorted(mappe_map.keys()):\n    dirs = mappe_map[mappe_n]\n    materialien = []\n    for d in dirs:\n        for jp in glob.glob(os.path.join(d, '**', '*.json'), recursive=True):\n            base = os.path.basename(jp).lower()\n            if not (base.startswith('mat-') or 'material' in base):\n                continue\n            try:\n                with open(jp, 'r', encoding='utf-8') as f:\n                    obj = json.load(f)\n            except Exception:\n                continue\n            if not isinstance(obj, dict):\n                continue\n            tags = obj.get('perspektiv_tags')\n            if tags is None:\n                # Legacy: _meta.perspektive single-string -> map to enum if known\n                meta = obj.get('_meta') or {}\n                persp = meta.get('perspektive') or obj.get('perspektive')\n                if isinstance(persp, str):\n                    if persp in pool_of:\n                        tags = [persp]\n            mat_id = obj.get('id') or os.path.basename(jp)\n            materialien.append({'id': mat_id, 'file': jp, 'perspektiv_tags': tags or []})\n\n    # Aggregat\n    tag_to_mats = {}\n    for m in materialien:\n        for t in m['perspektiv_tags']:\n            if t not in pool_of:\n                continue\n            tag_to_mats.setdefault(t, []).append(m['id'])\n    tags_aggregiert = []\n    for t in sorted(tag_to_mats.keys()):\n        tags_aggregiert.append({'enum_id': t, 'pool': pool_of[t], 'material_ids': sorted(set(tag_to_mats[t]))})\n\n    nicht_dominant_mats = set()\n    for m in materialien:\n        for t in m['perspektiv_tags']:\n            if pool_of.get(t) == 'nicht_dominant':\n                nicht_dominant_mats.add(m['id'])\n                break\n\n    qg06_pass = (len(nicht_dominant_mats) >= min_required) or (not trigger_relevant)\n    if not qg06_pass:\n        overall_fail = True\n\n    inventar = {\n        'scope_id': scope,\n        'mappe_n': mappe_n,\n        'schema_version': '1.0',\n        'trigger_kategorie_aktiv': trigger_relevant,\n        'tags_aggregiert': tags_aggregiert,\n        'nicht_dominant_count': len(nicht_dominant_mats),\n        'qg06_pass': qg06_pass,\n        'erzeugt': datetime.datetime.utcnow().isoformat(timespec='seconds') + 'Z',\n    }\n\n    # Schreibe registry/perspektiv_inventar(_mappe_N).json\n    target_dir = dirs[0]\n    out_dir = os.path.join(target_dir, 'registry')\n    os.makedirs(out_dir, exist_ok=True)\n    out_file = os.path.join(out_dir, f'perspektiv_inventar_mappe_{mappe_n}.json')\n    try:\n        with open(out_file, 'w', encoding='utf-8') as f:\n            json.dump(inventar, f, ensure_ascii=False, indent=2)\n            f.write('\\n')\n    except Exception as e:\n        print(f'WARN inventar-write fehlgeschlagen ({out_file}): {e}', file=sys.stderr)\n\n    results.append({\n        'mappe_n': mappe_n,\n        'materialien_total': len(materialien),\n        'nicht_dominant_count': len(nicht_dominant_mats),\n        'qg06_pass': qg06_pass,\n        'inventar_file': out_file,\n        'tags_aggregiert': tags_aggregiert,\n    })\n\nreport = {\n    'scope': scope,\n    'trigger_categories': trigger_categories,\n    'trigger_relevant': trigger_relevant,\n    'min_required_nicht_dominant': min_required,\n    'mappe_count': len(results),\n    'overall_pass': not overall_fail,\n    'mappen': results,\n}\nprint(json.dumps(report, ensure_ascii=False, indent=2))\nsys.exit(1 if overall_fail else 0)\nPY\n","structuredPatch":[],"originalFile":null,"userModified":false}}
{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01VL14wJpE9TqZRk6CtKvQrn","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_011EuwyMhEMi8LhuAny4kazN","name":"Write","input":{"file_path":"/Users/paulad/escape-game-generator/tools/entity-scanner.js","content":"#!/usr/bin/env node\n/*\n * tools/entity-scanner.js — F0b A1.6 (V14 UEBERLEITUNG-01)\n *\n * Scant skript/*.md|*.json, materialien/*.json, hefteintrag/*.json,\n * aufgaben/*.json eines Game-Scopes nach Eigennamen + Datumsangaben.\n * Erzeugt/aktualisiert escape-games/<scope>/registry/entities.json.\n *\n * Cross-Mappe-Modus: --cross-mappe prueft Entity-Konsistenz ueber Mappen\n * (Treffer in Mappe N, der erst in Mappe M>N eingefuehrt wurde, = WARN/FAIL).\n *\n * Kontrakt: F0B_PRIMING_INCLUDE.md §4 (UEBERLEITUNG-01), V14, schema entities.json.\n *\n * Usage:\n *   node tools/entity-scanner.js <scope> [--cross-mappe]\n *\n * Exit-Codes:\n *   0 = PASS (Registry geschrieben/aktualisiert)\n *   1 = FAIL (Cross-Mappe-Verletzung)\n *   2 = Script-Bug\n */\n'use strict';\n\nconst fs = require('fs');\nconst path = require('path');\n\nfunction die(code, msg) { console.error('ERROR:', msg); process.exit(code); }\n\nconst argv = process.argv.slice(2);\nif (argv.length < 1) die(2, 'usage: entity-scanner.js <scope> [--cross-mappe]');\nconst scope = argv[0];\nconst crossMode = argv.includes('--cross-mappe');\n\nconst SCRIPT_DIR = __dirname;\nconst GEN_ROOT = path.resolve(SCRIPT_DIR, '..');\nconst woRootCands = [\n  process.env.WEITERGEHTS_ONLINE_ROOT,\n  path.resolve(GEN_ROOT, '..', 'weitergehts.online', 'weitergehts-online'),\n  path.resolve(GEN_ROOT, '..', 'weitergehts-online'),\n  path.join(process.env.HOME || '', 'weitergehts.online', 'weitergehts-online'),\n].filter(Boolean);\nlet WO_ROOT = null;\nfor (const c of woRootCands) {\n  if (fs.existsSync(c) && fs.statSync(c).isDirectory()) { WO_ROOT = c; break; }\n}\nif (!WO_ROOT) die(2, 'weitergehts-online-Repo nicht gefunden');\n\nconst scopeRoots = [\n  path.join(WO_ROOT, 'escape-games', scope),\n  path.join(WO_ROOT, 'docs', 'agents', 'artefakte', scope),\n].filter(p => fs.existsSync(p) && fs.statSync(p).isDirectory());\nif (scopeRoots.length === 0) die(2, 'Scope nicht gefunden: ' + scope);\n\n// --- Walk ---\nfunction walk(dir, out) {\n  for (const e of fs.readdirSync(dir, { withFileTypes: true })) {\n    const fp = path.join(dir, e.name);\n    if (e.isDirectory()) {\n      if (e.name === 'node_modules' || e.name.startsWith('.') || e.name === 'registry') continue;\n      walk(fp, out);\n    } else if (e.isFile()) {\n      const lower = e.name.toLowerCase();\n      if (lower.endsWith('.json') || lower.endsWith('.md')) out.push(fp);\n    }\n  }\n}\n\nconst files = [];\nfor (const sr of scopeRoots) walk(sr, files);\n\n// --- Mappe-Erkennung ---\nfunction mappeOfPath(p) {\n  const m = p.match(/mappe[-_]?([0-9]+)/i);\n  return m ? parseInt(m[1], 10) : null;\n}\n\n// --- Text-Sammlung ---\nconst TEXT_FIELDS = new Set([\n  'text', 'inhalt', 'beschreibung', 'kontext', 'kontextsatz', 'titel',\n  'merksatz', 'frage', 'stundenfrage', 'erwartungshorizont', 'feedback',\n  'erklaerung', 'satz', 'stem', 'chunk_text', 'ueberleitungssatz', 'reflexion_frage',\n]);\nfunction collectTexts(obj, out) {\n  if (typeof obj === 'string') return;\n  if (Array.isArray(obj)) { for (const v of obj) collectTexts(v, out); return; }\n  if (obj && typeof obj === 'object') {\n    for (const k of Object.keys(obj)) {\n      const v = obj[k];\n      if (typeof v === 'string') {\n        if (TEXT_FIELDS.has(k)) out.push(v);\n      } else if (typeof v === 'object' && v !== null) {\n        collectTexts(v, out);\n      }\n    }\n  }\n}\n\n// --- Entity-Extraktion ---\nconst STOPWORDS = new Set([\n  'Der', 'Die', 'Das', 'Ein', 'Eine', 'Einen', 'Einem', 'Den', 'Dem', 'Des',\n  'Im', 'Am', 'Zum', 'Zur', 'Beim', 'Vom', 'Aus', 'Bei', 'Mit', 'Nach', 'Von',\n  'Und', 'Oder', 'Aber', 'Doch', 'Sondern', 'Weil', 'Wenn', 'Wie', 'Was', 'Wer',\n  'Hier', 'Dort', 'Heute', 'Gestern', 'Morgen', 'Damals', 'Spaeter', 'Frueher',\n  'Wir', 'Sie', 'Er', 'Es', 'Ihr', 'Ich', 'Du',\n  'Mappe', 'Aufgabe', 'Material', 'Hefteintrag', 'Skript',\n]);\n\nconst PERSON_HINT = /(K(ö|oe)nig|Kaiser|F(ü|ue)rst|General|Kanzler|Pr(ä|ae)sident|Gouverneur|Bischof|Papst|Herzog|Graf|Reichsleiter|Dr\\.|Frau|Herr)\\s+([A-ZÄÖÜ][\\wäöüß\\-]+(?:\\s+[A-ZÄÖÜ][\\wäöüß\\-]+){0,3})/g;\nconst PERSON_NAME = /\\b([A-ZÄÖÜ][a-zäöüß]+(?:\\s+(?:von|zu|de|del|van|der)\\s+)?(?:[A-ZÄÖÜ][a-zäöüß]+))\\b/g;\nconst PLACE_HINT = /(in|bei|nach|aus|von|aus dem|aus der)\\s+([A-ZÄÖÜ][\\wäöüß\\-]+(?:\\s+[A-ZÄÖÜ][\\wäöüß\\-]+){0,2})/g;\nconst DATE_PATTERN = /\\b(\\d{1,2}\\.\\s*\\d{1,2}\\.\\s*\\d{2,4}|\\d{4}(?:[-\\u2013]\\d{2,4})?)\\b/g;\nconst EVENT_HINT = /\\b(Krieg|Vertrag|Revolution|Konferenz|Aufstand|Schlacht|Erkl(ä|ae)rung|Abkommen|Verfassung|Friede)\\s+(?:von|um|bei|in|zu)?\\s*([A-ZÄÖÜ][\\wäöüß\\-]+(?:\\s+[A-ZÄÖÜ][\\wäöüß\\-]+){0,3})/g;\n\nfunction extractFromText(text, mappeN, results) {\n  let m;\n  PERSON_HINT.lastIndex = 0;\n  while ((m = PERSON_HINT.exec(text)) !== null) {\n    const name = (m[1] + ' ' + m[3]).trim();\n    addEntity(results.personen, name, mappeN, 'titulier-Hinweis');\n  }\n  // Iconic name pattern (Vor- + Nachname mit Adelspartikel)\n  PERSON_NAME.lastIndex = 0;\n  while ((m = PERSON_NAME.exec(text)) !== null) {\n    const name = m[1].trim();\n    if (STOPWORDS.has(name.split(/\\s+/)[0])) continue;\n    if (!/\\s/.test(name)) continue; // mind. zwei Tokens\n    addEntity(results.personen, name, mappeN, 'name-pattern');\n  }\n  PLACE_HINT.lastIndex = 0;\n  while ((m = PLACE_HINT.exec(text)) !== null) {\n    const name = m[2].trim();\n    if (STOPWORDS.has(name.split(/\\s+/)[0])) continue;\n    addEntity(results.orte, name, mappeN, 'praeposition');\n  }\n  EVENT_HINT.lastIndex = 0;\n  while ((m = EVENT_HINT.exec(text)) !== null) {\n    const name = (m[1] + ' ' + m[3]).trim();\n    addEntity(results.ereignisse, name, mappeN, 'event-hint');\n  }\n  DATE_PATTERN.lastIndex = 0;\n  while ((m = DATE_PATTERN.exec(text)) !== null) {\n    addEntity(results.daten, m[1].trim(), mappeN, 'datum');\n  }\n}\n\nfunction addEntity(arr, name, mappeN, source) {\n  const key = name.toLowerCase();\n  let existing = arr.find(e => (e.name || e.datum || '').toLowerCase() === key);\n  if (!existing) {\n    if (arr === resultsRoot.daten) {\n      existing = { datum: name, erste_mappe: mappeN || 0, sources: [] };\n    } else {\n      existing = { name: name, variants: [], erste_mappe: mappeN || 0, kontext: '', sources: [] };\n    }\n    arr.push(existing);\n  } else {\n    if (mappeN && (!existing.erste_mappe || mappeN < existing.erste_mappe)) {\n      existing.erste_mappe = mappeN;\n    }\n  }\n  if (!existing.sources.includes(source)) existing.sources.push(source);\n}\n\nconst resultsRoot = { personen: [], orte: [], ereignisse: [], daten: [] };\nconst occurrences = []; // fuer cross-mappe\n\nfor (const f of files) {\n  let raw;\n  try { raw = fs.readFileSync(f, 'utf8'); } catch (_) { continue; }\n  const mappeN = mappeOfPath(f);\n  let texts = [];\n  if (f.toLowerCase().endsWith('.json')) {\n    try { collectTexts(JSON.parse(raw), texts); } catch (_) { continue; }\n  } else if (f.toLowerCase().endsWith('.md')) {\n    texts = [raw];\n  }\n  for (const t of texts) {\n    extractFromText(t, mappeN, resultsRoot);\n    if (crossMode && mappeN) {\n      const local = { personen: [], orte: [], ereignisse: [], daten: [] };\n      const tmpRoot = local;\n      // separater Lauf fuer occurrence-tracking nicht noetig — wir nutzen erste_mappe\n      occurrences.push({ file: f, mappe: mappeN });\n    }\n  }\n}\n\n// --- Cross-Mappe-Check: Entity-Mention ohne Registry-Eintrag aus Vor-Sequenz ---\nlet crossViolations = [];\nif (crossMode) {\n  for (const arr of [resultsRoot.personen, resultsRoot.orte, resultsRoot.ereignisse]) {\n    for (const e of arr) {\n      // Wenn erste_mappe groesser als 1, pruefe ob in Mappe N-1 oder frueher Mention war\n      // (Heuristik: hier nur Stichprobe — vollstaendiger Cross-Check waere persistent)\n      if (e.erste_mappe && e.erste_mappe > 1 && (e.sources || []).includes('praeposition')) {\n        // Belasse als WARN (eigentliche Cross-Mappe-Pruefung erfolgt in V14 auf Rueckkopplungs-Texten)\n      }\n    }\n  }\n}\n\n// --- Bestehende Registry mergen (idempotent) ---\nconst targetDir = scopeRoots[0];\nconst registryDir = path.join(targetDir, 'registry');\nif (!fs.existsSync(registryDir)) fs.mkdirSync(registryDir, { recursive: true });\nconst registryPath = path.join(registryDir, 'entities.json');\n\nlet existing = null;\nif (fs.existsSync(registryPath)) {\n  try { existing = JSON.parse(fs.readFileSync(registryPath, 'utf8')); } catch (_) { existing = null; }\n}\n\nfunction mergeArrays(into, from, keyFn) {\n  for (const e of from) {\n    const k = keyFn(e).toLowerCase();\n    const idx = into.findIndex(x => keyFn(x).toLowerCase() === k);\n    if (idx === -1) {\n      into.push(e);\n    } else {\n      const cur = into[idx];\n      // erste_mappe = min, variants = union\n      if (e.erste_mappe && (!cur.erste_mappe || e.erste_mappe < cur.erste_mappe)) cur.erste_mappe = e.erste_mappe;\n      if (Array.isArray(e.variants)) {\n        cur.variants = Array.from(new Set([...(cur.variants || []), ...e.variants]));\n      }\n      if (!cur.kontext && e.kontext) cur.kontext = e.kontext;\n    }\n  }\n}\n\nconst merged = existing && typeof existing === 'object' ? {\n  scope_id: existing.scope_id || scope,\n  schema_version: '1.0',\n  letzte_aktualisierung: new Date().toISOString(),\n  personen: existing.personen || [],\n  orte: existing.orte || [],\n  ereignisse: existing.ereignisse || [],\n  daten: existing.daten || [],\n} : {\n  scope_id: scope,\n  schema_version: '1.0',\n  letzte_aktualisierung: new Date().toISOString(),\n  personen: [],\n  orte: [],\n  ereignisse: [],\n  daten: [],\n};\n\nmergeArrays(merged.personen, resultsRoot.personen, e => e.name);\nmergeArrays(