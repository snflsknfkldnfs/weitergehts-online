\n27\t      \"alternativen\": [\"nicht-industrialisiert\", \"vorindustriell\", \"anders organisiert\", \"andere Lebensweise\"]\n28\t    },\n29\t    {\n30\t      \"id\": \"zivilisationsmission\",\n31\t      \"muster\": [\"zivilisationsmission\", \"zivilisatorische mission\", \"zivilisierung\"],\n32\t      \"kategorie\": \"kolonial_rechtfertigung\",\n33\t      \"begruendung\": \"Uebernimmt kolonialistische Selbstlegitimation als neutralen Begriff.\",\n34\t      \"alternativen\": [\"koloniale Legitimations-Ideologie\", \"ideologische Rechtfertigung der Kolonialherrschaft\", \"sogenannte Zivilisationsmission (kritisch)\"]\n35\t    },\n36\t    {\n37\t      \"id\": \"entdeckung\",\n38\t      \"muster\": [\"entdeckung amerikas\", \"entdeckung afrikas\", \"entdeckung der welt\"],\n39\t      \"kategorie\": \"kolonial_eurozentrismus\",\n40\t      \"begruendung\": \"Setzt europaeische Perspektive als Nullpunkt; ignoriert Praeexistenz besiedelter Raeume.\",\n41\t      \"alternativen\": [\"europaeische Ankunft in Amerika\", \"Beginn der transatlantischen Kolonisierung\", \"erste dokumentierte Ueberfahrt von Columbus\", \"europaeische Expansion\"]\n42\t    },\n43\t    {\n44\t      \"id\": \"neger\",\n45\t      \"muster\": [\"neger\"],\n46\t      \"kategorie\": \"rassistische_bezeichnung\",\n47\t      \"begruendung\": \"Rassistisch diskriminierende Fremdbezeichnung. Auch historisch belastet.\",\n48\t      \"alternativen\": [\"Schwarze Menschen\", \"afrikanische Bevoelkerung (kontextspezifisch)\", \"versklavte Menschen (bei Sklaverei-Kontext)\"]\n49\t    },\n50\t    {\n51\t      \"id\": \"rothaeute_wilde\",\n52\t      \"muster\": [\"rothaeute\", \"rothaut\", \"wilde\", \"wilder\"],\n53\t      \"kategorie\": \"rassistische_bezeichnung\",\n54\t      \"begruendung\": \"Rassistische Fremdbezeichnungen; delegitimieren indigene Selbstbezeichnung.\",\n55\t      \"alternativen\": [\"indigene Bevoelkerung Nordamerikas\", \"First Nations (CA)\", \"Native Americans (US)\", \"konkrete Gruppenbezeichnung wenn bekannt (z.B. Sioux, Apache)\"]\n56\t    },\n57\t    {\n58\t      \"id\": \"stamm_pauschal\",\n59\t      \"muster\": [\"afrikanische staemme\", \"indianische staemme\", \"stammesgesellschaft\"],\n60\t      \"kategorie\": \"kolonial_pauschalisierung\",\n61\t      \"begruendung\": \"Pauschale Stammes-Kategorie ist kolonialkonstruiert; impliziert entwicklungs-hierarchische Dichotomie zu Staat/Volk.\",\n62\t      \"alternativen\": [\"Gemeinschaft/Bevoelkerungsgruppe/Volk\", \"konkrete Eigenbezeichnung wenn belegt\", \"Gesellschaft\"]\n63\t    },\n64\t    {\n65\t      \"id\": \"schwarzer_kontinent\",\n66\t      \"muster\": [\"schwarzer kontinent\", \"dunkler kontinent\"],\n67\t      \"kategorie\": \"kolonial_eurozentrismus\",\n68\t      \"begruendung\": \"Eurozentrische Projektion von Unkenntnis als Eigenschaft Afrikas.\",\n69\t      \"alternativen\": [\"Afrika\", \"afrikanischer Kontinent\"]\n70\t    },\n71\t    {\n72\t      \"id\": \"mutterland_pauschal\",\n73\t      \"muster\": [\"mutterland\"],\n74\t      \"kategorie\": \"kolonial_rechtfertigung\",\n75\t      \"begruendung\": \"Reproduziert kolonialismus-ideologische Familienmetapher zwischen Kolonialmacht und Kolonie.\",\n76\t      \"alternativen\": [\"Kolonialmacht\", \"Metropolstaat\", \"Imperialmacht\", \"herrschendes Heimatland\"]\n77\t    },\n78\t    {\n79\t      \"id\": \"schutzgebiet\",\n80\t      \"muster\": [\"schutzgebiet\"],\n81\t      \"kategorie\": \"kolonial_euphemismus\",\n82\t      \"begruendung\": \"Beschoenigender Kolonialbegriff des Deutschen Reiches; verbirgt Gewaltverhaeltnis.\",\n83\t      \"alternativen\": [\"Kolonie (Deutsches Reich)\", \"deutsche Kolonie [Land]\", \"von Deutschland besetztes Gebiet\"],\n84\t      \"hinweis\": \"Bei Zitaten/Quellen der Zeit: Originalbegriff belassen + kritische Einordnung pflicht.\"\n85\t    },\n86\t    {\n87\t      \"id\": \"unterentwickelt\",\n88\t      \"muster\": [\"unterentwickelt\", \"entwicklungsland_pauschal\"],\n89\t      \"kategorie\": \"kolonial_hierarchisierung\",\n90\t      \"begruendung\": \"Impliziert linearen Entwicklungspfad mit Europa als Zielpunkt.\",\n91\t      \"alternativen\": [\"mit weniger industrieller Infrastruktur\", \"mit anderen Wirtschaftsformen\", \"nicht-industrialisiert\", \"vor der Industrialisierung\"]\n92\t    }\n93\t  ],\n94\t  \"primaerquellen_ausnahme_kontext\": {\n95\t    \"regel\": \"Originalzitat aus historischer Quelle (Reden, Briefe, Zeitungsartikel, Gesetzestexte der Zeit) darf kolonialsprachliche Begriffe enthalten. Bedingungen: (a) Zitat eindeutig als solches markiert (Anfuehrungszeichen + Quellenangabe), (b) Kontextualisierungs-Kopfzeile erklaert die problematische Terminologie in R7-Sprache, (c) Glossar-Einblendung oder Fussnote bietet Alternativ-Begriff.\",\n96\t    \"durchsetzung\": \"Scanner erkennt Anfuehrungszeichen + Quellenangabe via Struktur-Marker in Schema (material_source.json: is_original_zitat=true). Ohne Marker = kein Ausnahme-Schutz.\"\n97\t  },\n98\t  \"wartungs_hinweis\": \"Muster themen-unspezifisch halten — keine laenderspezifischen Proprietaer-Begriffe. Alternativen muessen R7-faehig sein (keine komplizierten Ersatz-Worte). Erweiterung via Pull-Request mit Fundstelle (historischer Standardtext) und didaktischer Begruendung.\"\n99\t}\n100\t"}]},"parent_tool_use_id":null,"session_id":"7b48050f-9a71-4508-a0e9-cf74193b5dd7","uuid":"90dd73a4-3f20-4b76-a0b9-259cbb4e7bc1","timestamp":"2026-04-19T19:50:44.636Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/paulad/escape-game-generator/architektur/kolonial_terminologie_blacklist.json","content":"{\n  \"$schema\": \"https://json-schema.org/draft/2020-12/schema\",\n  \"version\": \"1.0\",\n  \"erstellt\": \"2026-04-19\",\n  \"zweck\": \"Themen-unspezifische Blacklist fuer TERMINOLOGIE-01 (F0b M6, QG-07). Scanner: scripts/terminologie-scanner.sh (V18). Case-insensitive Wortstamm-Match auf Text-Artefakte (material.text, scpl.knoten, aufgaben.stem/feedback, skript.chunk).\",\n  \"scan_z