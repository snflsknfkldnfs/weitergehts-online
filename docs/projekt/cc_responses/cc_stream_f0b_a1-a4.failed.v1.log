{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01WeikUx6APu2M26LJvAxcX1","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01FQtZ4bUBarv4p6yUFSwsNx","name":"Write","input":{"file_path":"/Users/paulad/escape-game-generator/tools/multiperspektiv-sanity.js","content":"#!/usr/bin/env node\n/*\n * tools/multiperspektiv-sanity.js — F0b A1.8 (V19 / QG-06 Synthese-Side)\n *\n * Liest perspektiv_inventar(_mappe_N).json + mappenabschluss_mappe_<N>.json\n * (oder mappenabschluss.json einer Mappe). Prueft: Bei aktiver Trigger-Kategorie\n * MUSS mindestens 1 reflexion_frage der Mappe explizit eine Nicht-Dominant-Perspektive\n * aus dem perspektiv_inventar adressieren.\n *\n * Match-Logik: Keyword-Match auf Enum-Label-Tokens (oder enum_id) + Pool=nicht_dominant.\n *\n * Kontrakt: F0B_PRIMING_INCLUDE.md §5, V19, perspektiv_enum.json.\n *\n * Usage:\n *   node tools/multiperspektiv-sanity.js <scope> <mappe-n>\n *\n * Exit-Codes:\n *   0 = PASS\n *   1 = FAIL (keine Nicht-Dominant-Adressierung im Mappenabschluss bei aktiver Kategorie)\n *   2 = Script-Bug\n */\n'use strict';\n\nconst fs = require('fs');\nconst path = require('path');\n\nfunction die(code, msg) { console.error('ERROR:', msg); process.exit(code); }\n\nconst argv = process.argv.slice(2);\nif (argv.length < 2) die(2, 'usage: multiperspektiv-sanity.js <scope> <mappe-n>');\nconst scope = argv[0];\nconst mappeN = parseInt(argv[1], 10);\nif (Number.isNaN(mappeN) || mappeN < 1) die(2, 'mappe-n muss positive Integer sein');\n\nconst SCRIPT_DIR = __dirname;\nconst GEN_ROOT = path.resolve(SCRIPT_DIR, '..');\nconst ENUM_FILE = path.join(GEN_ROOT, 'architektur', 'perspektiv_enum.json');\n\nconst woRootCands = [\n  process.env.WEITERGEHTS_ONLINE_ROOT,\n  path.resolve(GEN_ROOT, '..', 'weitergehts.online', 'weitergehts-online'),\n  path.resolve(GEN_ROOT, '..', 'weitergehts-online'),\n  path.join(process.env.HOME || '', 'weitergehts.online', 'weitergehts-online'),\n].filter(Boolean);\nlet WO_ROOT = null;\nfor (const c of woRootCands) {\n  if (fs.existsSync(c) && fs.statSync(c).isDirectory()) { WO_ROOT = c; break; }\n}\nif (!WO_ROOT) die(2, 'weitergehts-online-Repo nicht gefunden');\n\nconst enumData = JSON.parse(fs.readFileSync(ENUM_FILE, 'utf8'));\nconst poolOf = {};\nconst labelOf = {};\nfor (const e of enumData.enum || []) {\n  poolOf[e.id] = e.pool;\n  labelOf[e.id] = e.label;\n}\n\n// --- Inventar lokalisieren ---\nconst candidateInventarPaths = [];\nconst scopeRoots = [\n  path.join(WO_ROOT, 'escape-games', scope),\n  path.join(WO_ROOT, 'docs', 'agents', 'artefakte', scope),\n];\nfor (const sr of scopeRoots) {\n  if (!fs.existsSync(sr)) continue;\n  candidateInventarPaths.push(\n    path.join(sr, 'mappe-' + mappeN, 'registry', `perspektiv_inventar_mappe_${mappeN}.json`),\n    path.join(sr, 'mappe-' + mappeN, 'registry', 'perspektiv_inventar.json'),\n    path.join(sr, 'mappe_' + mappeN, 'registry', `perspektiv_inventar_mappe_${mappeN}.json`),\n    path.join(sr, 'registry', `perspektiv_inventar_mappe_${mappeN}.json`),\n  );\n}\nconst inventarFile = candidateInventarPaths.find(p => fs.existsSync(p));\nif (!inventarFile) die(2, 'perspektiv_inventar nicht gefunden. Kandidaten: ' + candidateInventarPaths.join(', '));\n\nconst inventar = JSON.parse(fs.readFileSync(inventarFile, 'utf8'));\nconst triggerActive = !!inventar.trigger_kategorie_aktiv;\n\nconst nichtDomTags = (inventar.tags_aggregiert || []).filter(t => t.pool === 'nicht_dominant').map(t => t.enum_id);\n\n// --- Mappenabschluss lokalisieren ---\nconst candidateMappenabschluss = [];\nfor (const sr of scopeRoots) {\n  if (!fs.existsSync(sr)) continue;\n  candidateMappenabschluss.push(\n    path.join(sr, 'mappe-' + mappeN, `mappenabschluss_mappe_${mappeN}.json`),\n    path.join(sr, 'mappe-' + mappeN, 'mappenabschluss.json'),\n    path.join(sr, 'mappe-' + mappeN, 'rahmen', 'mappenabschluss_zone.json'),\n    path.join(sr, 'mappe_' + mappeN, `mappenabschluss_mappe_${mappeN}.json`),\n  );\n}\nconst maFile = candidateMappenabschluss.find(p => fs.existsSync(p));\nif (!maFile) die(2, 'mappenabschluss nicht gefunden. Kandidaten: ' + candidateMappenabschluss.join(', '));\n\nconst ma = JSON.parse(fs.readFileSync(maFile, 'utf8'));\n\n// --- Reflexion-Fragen extrahieren ---\nfunction collectReflexionFragen(obj, acc) {\n  if (Array.isArray(obj)) { for (const v of obj) collectReflexionFragen(v, acc); return; }\n  if (obj && typeof obj === 'object') {\n    for (const k of Object.keys(obj)) {\n      const v = obj[k];\n      if (k === 'reflexion_fragen' && Array.isArray(v)) {\n        for (const item of v) {\n          if (typeof item === 'string') acc.push(item);\n          else if (item && typeof item === 'object' && typeof item.frage === 'string') acc.push(item.frage);\n        }\n      } else if (k === 'reflexion_frage' && typeof v === 'string') {\n        acc.push(v);\n      } else if (typeof v === 'object' && v !== null) {\n        collectReflexionFragen(v, acc);\n      }\n    }\n  }\n}\nconst reflexionFragen = [];\ncollectReflexionFragen(ma, reflexionFragen);\n\n// --- Match: Adressiert eine reflexion_frage eine Nicht-Dominant-Perspektive? ---\nfunction tokenize(label) {\n  return label.toLowerCase().replace(/[\\(\\)\\/]/g, ' ').split(/\\s+/).filter(t => t.length > 3);\n}\n\nconst matchedTags = [];\nfor (const tag of nichtDomTags) {\n  const tokens = tokenize(labelOf[tag] || tag.replace(/_/g, ' '));\n  for (const frage of reflexionFragen) {\n    const fl = frage.toLowerCase();\n    if (tokens.some(t => fl.includes(t)) || fl.includes(tag.replace(/_/g, ' '))) {\n      matchedTags.push({ tag, label: labelOf[tag], frage: frage.slice(0, 200) });\n      break;\n    }\n  }\n}\n\nconst requiresMatch = triggerActive;\nconst pass = !requiresMatch || matchedTags.length >= 1;\n\nconst report = {\n  scope: scope,\n  mappe_n: mappeN,\n  inventar_file: inventarFile,\n  mappenabschluss_file: maFile,\n  trigger_kategorie_aktiv: triggerActive,\n  nicht_dominant_tags_im_inventar: nichtDomTags,\n  reflexion_fragen_count: reflexionFragen.length,\n  matched_tags: matchedTags,\n  pass: pass,\n  fail_reason: pass ? null : 'Trigger-Kategorie aktiv, aber keine reflexion_frage adressiert eine Nicht-Dominant-Perspektive aus dem Inventar.',\n};\nconsole.log(JSON.stringify(report, null, 2));\nprocess.exit(pass ? 0 : 1);\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":2364,"cache_read_input_tokens":148131,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":2364},"output_tokens":56,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"7b48050f-9a71-4508-a0e9-cf74193b5dd7","uuid":"187602d6-8871-42d4-aa50-bb8efa58d706"}
