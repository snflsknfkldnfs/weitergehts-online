{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_015CZMR9fkGLSQWdUEpJAWtQ","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_017fPy95Pg4AmbXU14k9ASQf","name":"Write","input":{"file_path":"/Users/paulad/escape-game-generator/tools/source-deploy-parity.sh","content":"#!/usr/bin/env bash\n# tools/source-deploy-parity.sh — DEPLOY-07 (F0b A1.1)\n#\n# Hash-Vergleich (SHA256) zwischen Source-data.json im weitergehts-online-Repo\n# und einem optional gerenderten Deploy-Build-Output. Ergaenzend zum bestehenden\n# Caption-Parity-Check in weitergehts-online/tools/source-deploy-parity.sh.\n#\n# Kontrakt: VERTRAG_PHASE_3-1_DEPLOY.md §2.2 DEPLOY-07.\n#\n# Usage:\n#   tools/source-deploy-parity.sh <game-id> [--deploy-path <path-or-url>]\n#\n# Exit-Codes:\n#   0 = PASS (Hashes identisch)\n#   1 = FAIL (Hash-Drift erkannt)\n#   2 = Script-Bug / fehlende Inputs\n#\n# Output (stdout):\n#   SOURCE_SHA256=...\n#   DEPLOY_SHA256=...\n#   MATCH=yes|no\n\nset -u\n\nerr() { echo \"ERROR: $*\" >&2; }\n\nif [[ $# -lt 1 ]]; then\n  err \"usage: $0 <game-id> [--deploy-path <path-or-url>]\"\n  exit 2\nfi\n\nGAME_ID=\"$1\"; shift\nDEPLOY_PATH=\"\"\nwhile [[ $# -gt 0 ]]; do\n  case \"$1\" in\n    --deploy-path) DEPLOY_PATH=\"$2\"; shift 2 ;;\n    *) err \"unbekannter Arg: $1\"; exit 2 ;;\n  esac\ndone\n\n# Repo-Roots: Script liegt in escape-game-generator/tools/, Source-data.json\n# liegt im parallel-Repo weitergehts-online/escape-games/<game-id>/data.json.\nSCRIPT_DIR=\"$(cd -- \"$(dirname -- \"${BASH_SOURCE[0]}\")\" &> /dev/null && pwd)\"\nGEN_ROOT=\"$(cd -- \"$SCRIPT_DIR/..\" &> /dev/null && pwd)\"\nWO_ROOT_CANDIDATES=(\n  \"${WEITERGEHTS_ONLINE_ROOT:-}\"\n  \"$GEN_ROOT/../weitergehts.online/weitergehts-online\"\n  \"$GEN_ROOT/../weitergehts-online\"\n  \"$HOME/weitergehts.online/weitergehts-online\"\n)\nWO_ROOT=\"\"\nfor c in \"${WO_ROOT_CANDIDATES[@]}\"; do\n  if [[ -n \"$c\" && -d \"$c/escape-games\" ]]; then\n    WO_ROOT=\"$(cd -- \"$c\" &> /dev/null && pwd)\"\n    break\n  fi\ndone\nif [[ -z \"$WO_ROOT\" ]]; then\n  err \"weitergehts-online-Repo nicht gefunden. Setze WEITERGEHTS_ONLINE_ROOT.\"\n  exit 2\nfi\n\nSOURCE_DATA=\"$WO_ROOT/escape-games/$GAME_ID/data.json\"\nif [[ ! -f \"$SOURCE_DATA\" ]]; then\n  err \"Source-data.json nicht gefunden: $SOURCE_DATA\"\n  exit 2\nfi\n\nif ! command -v shasum >/dev/null 2>&1 && ! command -v sha256sum >/dev/null 2>&1; then\n  err \"Weder shasum noch sha256sum verfuegbar.\"\n  exit 2\nfi\n\nsha256_of_file() {\n  if command -v shasum >/dev/null 2>&1; then\n    shasum -a 256 \"$1\" | awk '{print $1}'\n  else\n    sha256sum \"$1\" | awk '{print $1}'\n  fi\n}\n\nSOURCE_SHA256=\"$(sha256_of_file \"$SOURCE_DATA\")\"\n\n# Deploy-Pfad-Resolution:\n#   - Kein --deploy-path: Source-Repo ist der deploy-Ort (Live-Site-Repo).\n#     In diesem Fall ist SOURCE == DEPLOY trivialerweise. Script liefert\n#     dann die Identitaet zurueck (fuer Smoke-Test-Zwecke).\n#   - Pfad: lokales File, Hash direkt.\n#   - URL (http/https): per curl ziehen (nur verfuegbar wenn curl da).\nif [[ -z \"$DEPLOY_PATH\" ]]; then\n  DEPLOY_SHA256=\"$SOURCE_SHA256\"\n  DEPLOY_SRC_DESC=\"(kein --deploy-path, Source ist Live-Repo)\"\nelif [[ \"$DEPLOY_PATH\" =~ ^https?:// ]]; then\n  if ! command -v curl >/dev/null 2>&1; then\n    err \"curl nicht verfuegbar fuer URL-Deploy-Fetch.\"\n    exit 2\n  fi\n  TMP=\"$(mktemp -t cc_deploy_XXXXXX.json)\"\n  trap 'rm -f \"$TMP\"' EXIT\n  if ! curl -fsSL --max-time 20 \"$DEPLOY_PATH\" -o \"$TMP\"; then\n    err \"Deploy-URL nicht erreichbar: $DEPLOY_PATH\"\n    exit 2\n  fi\n  DEPLOY_SHA256=\"$(sha256_of_file \"$TMP\")\"\n  DEPLOY_SRC_DESC=\"$DEPLOY_PATH\"\nelse\n  if [[ ! -f \"$DEPLOY_PATH\" ]]; then\n    err \"Deploy-Datei nicht gefunden: $DEPLOY_PATH\"\n    exit 2\n  fi\n  DEPLOY_SHA256=\"$(sha256_of_file \"$DEPLOY_PATH\")\"\n  DEPLOY_SRC_DESC=\"$DEPLOY_PATH\"\nfi\n\necho \"SOURCE_SHA256=$SOURCE_SHA256\"\necho \"DEPLOY_SHA256=$DEPLOY_SHA256\"\nif [[ \"$SOURCE_SHA256\" == \"$DEPLOY_SHA256\" ]]; then\n  echo \"MATCH=yes\"\n  echo \"GAME=$GAME_ID SOURCE=$SOURCE_DATA DEPLOY=$DEPLOY_SRC_DESC\"\n  exit 0\nelse\n  echo \"MATCH=no\"\n  echo \"GAME=$GAME_ID SOURCE=$SOURCE_DATA DEPLOY=$DEPLOY_SRC_DESC\"\n  exit 1\nfi\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1301,"cache_read_input_tokens":124047,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1301},"output_tokens":72,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"7b48050f-9a71-4508-a0e9-cf74193b5dd7","uuid":"dc5400f6-9cf1-4463-9491-6a6894d655f0"}
