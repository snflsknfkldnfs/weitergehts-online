{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01JXo2DyD3FWxFhyJWkFEbLX","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01P11xZyHy3VWw2cBAJc5VjJ","name":"Write","input":{"file_path":"/Users/paulad/escape-game-generator/architektur/schemata/material_source.json","content":"{\n  \"$schema\": \"https://json-schema.org/draft/2020-12/schema\",\n  \"$id\": \"material_source.json\",\n  \"title\": \"Material-Source (Primaerquellen-Scope)\",\n  \"description\": \"Schema-Erweiterung fuer Quellen-Materialien (mat-PQ, mat-PT etc.). Markiert Originalzitate via is_original_zitat=true und macht damit die Primaerquellen-Ausnahme aus F0B_PRIMING_INCLUDE.md §1/§3 explizit. Enforcement: terminologie-scanner.sh (V18) + sprachniveau-gate.js (QG-08) skippen Felder, wenn is_original_zitat=true. Ohne Marker = kein Ausnahme-Schutz.\",\n  \"type\": \"object\",\n  \"required\": [\n    \"is_original_zitat\",\n    \"quellenangabe\",\n    \"perspektiv_tags\"\n  ],\n  \"properties\": {\n    \"is_original_zitat\": {\n      \"type\": \"boolean\",\n      \"description\": \"true = wortgetreues Originalzitat aus historischer Quelle. Aktiviert Primaerquellen-Ausnahme. false = aufbereiteter/vereinfachter Text, alle R7-Gates greifen normal.\"\n    },\n    \"quellenangabe\": {\n      \"type\": \"string\",\n      \"minLength\": 5,\n      \"description\": \"Vollstaendige Quellenangabe (Autor, Werk, Jahr, ggf. Archiv/Signatur). Pflicht-Feld auch ausserhalb der Primaerquellen-Ausnahme, weil Lehrkraft-Sicht.\"\n    },\n    \"perspektiv_tags\": {\n      \"type\": \"array\",\n      \"minItems\": 1,\n      \"maxItems\": 3,\n      \"items\": {\n        \"type\": \"string\",\n        \"enum\": [\n          \"herrscher_elite\",\n          \"macht_ausuebend\",\n          \"wohlhabende_buergerschaft\",\n          \"aussen_zeitgenoessisch\",\n          \"betroffen_sus\",\n          \"alltag_unterschicht\",\n          \"frauenperspektive\",\n          \"kinder_jugendliche\",\n          \"randstaendig_regional\",\n          \"opposition_widerstand\"\n        ]\n      },\n      \"description\": \"Perspektiv-Tags pro perspektiv_enum.json. Min 1, max 3. Validation gegen Enum-Pool. coverage-report.sh aggregiert daraus QG-06.\"\n    },\n    \"kontextualisierung\": {\n      \"type\": \"object\",\n      \"description\": \"Pflicht wenn is_original_zitat=true (siehe required-Allof). Setzt das Zitat in einen R7-konformen Rahmen.\",\n      \"required\": [\n        \"vorwort\",\n        \"glossar\",\n        \"kritische_einordnung\"\n      ],\n      \"properties\": {\n        \"vorwort\": {\n          \"type\": \"string\",\n          \"minLength\": 30,\n          \"description\": \"Kontextualisierungs-Kopfzeile in R7-Sprache. Markiert die Quellensprache als historisch und ordnet die abweichenden Register ein.\"\n        },\n        \"glossar\": {\n          \"type\": \"array\",\n          \"items\": {\n            \"$ref\": \"glossar_template.json\"\n          },\n          \"description\": \"Glossar-Eintraege fuer Begriffe, die R7-fern sind oder kolonialsprachlich (Pflicht bei Blacklist-Treffer).\"\n        },\n        \"kritische_einordnung\": {\n          \"type\": \"string\",\n          \"minLength\": 30,\n          \"description\": \"Kurze didaktische Einordnung: warum ist diese Quelle relevant, was zeigt sie ueber die Sicht der Verfasser, welche Begriffe sind heute problematisch.\"\n        }\n      }\n    }\n  },\n  \"allOf\": [\n    {\n      \"if\": {\n        \"properties\": {\n          \"is_original_zitat\": {\n            \"const\": true\n          }\n        },\n        \"required\": [\n          \"is_original_zitat\"\n        ]\n      },\n      \"then\": {\n        \"required\": [\n          \"kontextualisierung\"\n        ]\n      }\n    }\n  ]\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1992,"cache_read_input_tokens":112190,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1992},"output_tokens":47,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"7b48050f-9a71-4508-a0e9-cf74193b5dd7","uuid":"f4abd3b9-c1f1-409e-8b16-f1bc08468ba4"}
