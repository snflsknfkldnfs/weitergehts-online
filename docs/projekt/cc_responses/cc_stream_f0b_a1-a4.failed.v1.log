.compile(r'(?<![\\w])' + re.escape(muster.lower()) + r'\\w*', re.IGNORECASE),\n        })\n\ndef collect_files(p):\n    if os.path.isfile(p):\n        return [p]\n    out = []\n    for root, dirs, files in os.walk(p):\n        dirs[:] = [d for d in dirs if not d.startswith('.') and d != 'node_modules']\n        for f in files:\n            if f.endswith('.json') or f.endswith('.md'):\n                out.append(os.path.join(root, f))\n    return out\n\nTEXT_FIELDS = {\n    'text', 'inhalt', 'beschreibung', 'legende', 'bildunterschrift', 'kontext',\n    'kontextsatz', 'satz', 'frage', 'merksatz', 'stem', 'stundenfrage',\n    'erwartungshorizont', 'feedback', 'loesung', 'erklaerung', 'erklaerung_r7',\n    'titel', 'chunk_text', 'ueberleitungssatz', 'reflexion_frage',\n    'distraktoren', 'quelle', 'quellenangabe',\n}\n\ndef collect_text_fields(obj, parent_is_zitat, jp, acc):\n    if isinstance(obj, list):\n        for i, v in enumerate(obj):\n            collect_text_fields(v, parent_is_zitat, f'{jp}[{i}]', acc)\n        return\n    if isinstance(obj, dict):\n        is_zitat = parent_is_zitat or obj.get('is_original_zitat') is True\n        for k, v in obj.items():\n            np = f'{jp}.{k}' if jp else k\n            if isinstance(v, str):\n                if k in TEXT_FIELDS:\n                    acc.append({'path': np, 'text': v, 'skipped': is_zitat})\n            elif isinstance(v, (dict, list)):\n                collect_text_fields(v, is_zitat, np, acc)\n\nfiles = collect_files(target)\nreport = {'scope': target, 'files_total': len(files), 'findings': [], 'skipped_zitate': 0}\nfail_count = 0\n\nfor f in files:\n    try:\n        raw = open(f, 'r', encoding='utf-8').read()\n    except Exception:\n        continue\n    fields = []\n    if f.endswith('.json'):\n        try:\n            obj = json.loads(raw)\n        except Exception as e:\n            report['findings'].append({'file': f, 'error': f'json-parse: {e}'})\n            continue\n        collect_text_fields(obj, False, '', fields)\n    else:\n        # Markdown: einfacher Block-Scan, ohne Primaerquellen-Erkennung\n        fields.append({'path': 'md.body', 'text': raw, 'skipped': False})\n\n    file_hits = []\n    for fld in fields:\n        if fld.get('skipped'):\n            report['skipped_zitate'] += 1\n            continue\n        text_low = fld['text'].lower()\n        for p in patterns:\n            for m in p['regex'].finditer(text_low):\n                start = max(0, m.start() - 30)\n                end = min(len(text_low), m.end() + 30)\n                snippet = fld['text'][start:end]\n                file_hits.append({\n                    'path': fld['path'],\n                    'blacklist_id': p['id'],\n                    'kategorie': p['kategorie'],\n                    'muster': p['muster'],\n                    'fundstelle': snippet.strip(),\n                    'alternativen': p['alternativen'],\n                })\n                fail_count += 1\n    if file_hits:\n        report['findings'].append({'file': f, 'hits': file_hits})\n\nreport['fail_count'] = fail_count\nreport['pass'] = fail_count == 0\nprint(json.dumps(report, ensure_ascii=False, indent=2))\nsys.exit(0 if fail_count == 0 else 1)\nPY\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":5585,"cache_read_input_tokens":142546,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":5585},"output_tokens":56,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"7b48050f-9a71-4508-a0e9-cf74193b5dd7","uuid":"e59bb582-6907-4f69-919f-5dbc2d1bc3ac"}
