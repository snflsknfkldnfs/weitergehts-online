{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_012ZZDcuXBi3C3BS9koVzkrQ","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01MMyHMjwTjUawJuCGJyetQ6","name":"Write","input":{"file_path":"/Users/paulad/escape-game-generator/tools/titel-validator.js","content":"#!/usr/bin/env node\n/*\n * tools/titel-validator.js — F0b A1.3\n *\n * Prueft Inhaltsbasis-Titel + LP-Anker auf:\n *   R-TITEL-1: Praezision (LB-kanonischer Terminus, keine Marketing-Keywords)\n *   R-TITEL-2: LP-Anbindung (lp_anker enthaelt LB-ID + Kompetenzerwartung)\n *   R-TITEL-3: Perspektiv-Neutralitaet (kein Blacklist-Treffer, keine Herrscher-Vokabel-Dominanz)\n *\n * Kontrakt: VERTRAG_PHASE_0-2_INHALT.md §3.4 (M7 Titel-Validierung).\n *\n * Usage:\n *   node tools/titel-validator.js <inhaltsbasis-path>\n *\n * Exit-Codes:\n *   0 = PASS\n *   1 = FAIL\n *   2 = Script-Bug / fehlende Inputs\n */\n'use strict';\n\nconst fs = require('fs');\nconst path = require('path');\n\nfunction die(code, msg) { console.error('ERROR:', msg); process.exit(code); }\n\nconst argv = process.argv.slice(2);\nif (argv.length < 1) die(2, 'usage: titel-validator.js <inhaltsbasis-path>');\nconst ibPath = argv[0];\nif (!fs.existsSync(ibPath)) die(2, 'INHALTSBASIS nicht gefunden: ' + ibPath);\n\nconst SCRIPT_DIR = __dirname;\nconst GEN_ROOT = path.resolve(SCRIPT_DIR, '..');\nconst BLACKLIST_FILE = path.join(GEN_ROOT, 'architektur', 'kolonial_terminologie_blacklist.json');\nconst WORTSCHATZ_FILE = path.join(GEN_ROOT, 'architektur', 'wortschatz_r7_core.json');\n\nlet blacklist = { blacklist: [] };\nlet wortschatz = { r7_fachwoerter_lexikon: {} };\ntry { blacklist = JSON.parse(fs.readFileSync(BLACKLIST_FILE, 'utf8')); } catch (e) { die(2, 'blacklist laden: ' + e.message); }\ntry { wortschatz = JSON.parse(fs.readFileSync(WORTSCHATZ_FILE, 'utf8')); } catch (e) { die(2, 'wortschatz laden: ' + e.message); }\n\n// --- Inhaltsbasis laden (JSON oder Markdown) ---\nconst raw = fs.readFileSync(ibPath, 'utf8');\nlet ib = null;\nlet format = 'md';\ntry {\n  ib = JSON.parse(raw);\n  format = 'json';\n} catch (_) {\n  // Fallback Markdown\n  const lines = raw.split(/\\r?\\n/);\n  let title = '';\n  for (const l of lines) {\n    if (l.trim().startsWith('#')) { title = l.replace(/^#+\\s*/, '').trim(); break; }\n  }\n  ib = { title: title, lp_anker: raw, sachanalyse: { text: raw } };\n}\n\nconst title = (ib.title || '').trim();\nconst lp_anker = typeof ib.lp_anker === 'string' ? ib.lp_anker : JSON.stringify(ib.lp_anker || '');\nconst findings = [];\n\n// --- R-TITEL-1: Praezision ---\nconst MARKETING_BLACKLIST = ['spannend', 'cool', 'super', 'mega', 'krass', 'unglaublich', 'episch', 'awesome', 'fantastisch', 'aufregend'];\nconst titleLow = title.toLowerCase();\nfor (const m of MARKETING_BLACKLIST) {\n  if (new RegExp('\\\\b' + m + '\\\\w*', 'i').test(titleLow)) {\n    findings.push({ rule: 'R-TITEL-1', severity: 'FAIL', detail: 'Marketing-Keyword im Titel: \"' + m + '\"' });\n  }\n}\n\n// LB-kanonischer Terminus: Pruefe Praesenz mind. eines Fachbegriffs aus r7_fachwoerter_lexikon\nconst fachLex = wortschatz.r7_fachwoerter_lexikon || {};\nlet allFach = [];\nfor (const lb of Object.keys(fachLex)) {\n  if (lb === 'hinweis') continue;\n  const arr = fachLex[lb];\n  if (Array.isArray(arr)) allFach = allFach.concat(arr);\n}\nconst titleHasFach = allFach.some(f => titleLow.includes(f.toLowerCase()));\nif (!titleHasFach) {\n  findings.push({ rule: 'R-TITEL-1', severity: 'WARN', detail: 'Kein LB-kanonischer Terminus im Titel gefunden. Pruefe LP-QM-Anbindung.' });\n}\n\n// --- R-TITEL-2: LP-Anbindung ---\n// Mindestens 1 LB-ID-Referenz (z.B. \"LB1\", \"LB 4\", \"Lernbereich 7\")\n// + 1 Kompetenzerwartungs-Referenz (z.B. \"GPG7 6.X\", \"6.4.1\", \"Kompetenzerwartung\")\nconst lpaLow = lp_anker.toLowerCase();\nconst hasLbRef = /lb\\s*\\d|lernbereich\\s*\\d/i.test(lpaLow);\nconst hasKompRef = /kompetenz|gpg\\s*\\d|\\b\\d+\\.\\d+(\\.\\d+)?\\b/i.test(lpaLow);\nif (!hasLbRef) {\n  findings.push({ rule: 'R-TITEL-2', severity: 'FAIL', detail: 'lp_anker enthaelt keine LB-ID-Referenz (LBn / Lernbereich n).' });\n}\nif (!hasKompRef) {\n  findings.push({ rule: 'R-TITEL-2', severity: 'FAIL', detail: 'lp_anker enthaelt keine Kompetenzerwartungs-Referenz (z.B. GPG7 6.X.Y oder Kompetenzerwartung).' });\n}\n\n// --- R-TITEL-3: Perspektiv-Neutralitaet ---\n// (a) Blacklist-Match im Titel\nconst blEntries = blacklist.blacklist || [];\nfor (const entry of blEntries) {\n  for (const muster of entry.muster || []) {\n    if (titleLow.includes(muster.toLowerCase())) {\n      findings.push({\n        rule: 'R-TITEL-3',\n        severity: 'FAIL',\n        detail: 'Blacklist-Treffer im Titel: \"' + muster + '\" (Kategorie: ' + entry.kategorie + ', ID: ' + entry.id + ')',\n        alternativen: entry.alternativen,\n      });\n    }\n  }\n}\n// (b) Heuristische Herrscher-Vokabel-Dominanz: wenn Titel Herrscher-Wort enthaelt OHNE Gegenpol\nconst HERRSCHER = ['kaiser', 'koenig', 'fuerst', 'kanzler', 'general', 'gouverneur', 'herrscher'];\nconst GEGENPOL = ['volk', 'arbeiter', 'frauen', 'opfer', 'opposition', 'widerstand', 'kolonisierte', 'minderheit', 'kritik'];\nconst hasHerrscher = HERRSCHER.some(h => new RegExp('\\\\b' + h + '\\\\w*', 'i').test(titleLow));\nconst hasGegenpol = GEGENPOL.some(g => new RegExp('\\\\b' + g + '\\\\w*', 'i').test(titleLow));\nif (hasHerrscher && !hasGegenpol) {\n  findings.push({ rule: 'R-TITEL-3', severity: 'WARN', detail: 'Herrscher-Vokabel-Dominanz im Titel (kein erkennbarer Gegenpol).' });\n}\n\n// --- Ausgabe ---\nconst fails = findings.filter(f => f.severity === 'FAIL');\nconst warns = findings.filter(f => f.severity === 'WARN');\nconst report = {\n  inhaltsbasis: ibPath,\n  format: format,\n  title: title,\n  pass: fails.length === 0,\n  fail_count: fails.length,\n  warn_count: warns.length,\n  findings: findings,\n};\nconsole.log(JSON.stringify(report, null, 2));\nprocess.exit(fails.length === 0 ? 0 : 1);\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":2677,"cache_read_input_tokens":127843,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":2677},"output_tokens":59,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"7b48050f-9a71-4508-a0e9-cf74193b5dd7","uuid":"4ba98a66-3831-4c75-b786-87f785e98278"}
