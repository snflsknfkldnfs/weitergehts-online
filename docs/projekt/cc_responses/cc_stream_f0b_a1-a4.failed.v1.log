{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XJBQ41JgBxfFXCbbgWGT3c","type":"tool_result","content":"The file /Users/paulad/escape-game-generator/tools/trigger-detector.sh has been updated successfully. (file state is current in your context — no need to Read it back)"}]},"parent_tool_use_id":null,"session_id":"7b48050f-9a71-4508-a0e9-cf74193b5dd7","uuid":"42f35731-4506-4ff8-8a49-e9cdaca12ea8","timestamp":"2026-04-19T20:01:59.980Z","tool_use_result":{"filePath":"/Users/paulad/escape-game-generator/tools/trigger-detector.sh","oldString":"    'erzeugt': datetime.datetime.utcnow().isoformat(timespec='seconds') + 'Z',","newString":"    'erzeugt': datetime.datetime.now(datetime.timezone.utc).isoformat(timespec='seconds').replace('+00:00','Z'),","originalFile":"#!/usr/bin/env bash\n# tools/trigger-detector.sh — F0b A1.2 (QI-TD)\n#\n# Liest INHALTSBASIS-JSON, scant title + lp_anker + sachanalyse.text gegen\n# architektur/trigger_keywords.json. Gibt JSON-Array trigger_categories[]\n# auf stdout aus. Mit --write wird der INHALTSBASIS-Header in-place ergaenzt\n# (idempotent).\n#\n# Kontrakt: VERTRAG_PHASE_0-2_INHALT.md §3.4 QI-TD.\n#\n# Usage:\n#   tools/trigger-detector.sh <inhaltsbasis-path> [--write]\n#\n# Exit-Codes:\n#   0 = PASS (Scan erfolgreich, ggf. Kategorien gefunden)\n#   1 = FAIL (Scan erfolgreich, aber Schreib-Versuch fehlgeschlagen)\n#   2 = Script-Bug / fehlende Inputs / Inhaltsbasis nicht parsebar\n\nset -u\n\nerr() { echo \"ERROR: $*\" >&2; }\n\nif [[ $# -lt 1 ]]; then\n  err \"usage: $0 <inhaltsbasis-path> [--write]\"\n  exit 2\nfi\n\nIB_PATH=\"$1\"; shift\nWRITE_MODE=\"no\"\nwhile [[ $# -gt 0 ]]; do\n  case \"$1\" in\n    --write) WRITE_MODE=\"yes\"; shift ;;\n    *) err \"unbekannter Arg: $1\"; exit 2 ;;\n  esac\ndone\n\nif [[ ! -f \"$IB_PATH\" ]]; then\n  err \"INHALTSBASIS nicht gefunden: $IB_PATH\"\n  exit 2\nfi\n\nSCRIPT_DIR=\"$(cd -- \"$(dirname -- \"${BASH_SOURCE[0]}\")\" &> /dev/null && pwd)\"\nGEN_ROOT=\"$(cd -- \"$SCRIPT_DIR/..\" &> /dev/null && pwd)\"\nKW_FILE=\"$GEN_ROOT/architektur/trigger_keywords.json\"\nif [[ ! -f \"$KW_FILE\" ]]; then\n  err \"trigger_keywords.json nicht gefunden: $KW_FILE\"\n  exit 2\nfi\n\nif ! command -v python3 >/dev/null 2>&1; then\n  err \"python3 nicht verfuegbar.\"\n  exit 2\nfi\n\npython3 - \"$IB_PATH\" \"$KW_FILE\" \"$WRITE_MODE\" <<'PY'\nimport json, sys, re, datetime\n\nib_path, kw_path, write_mode = sys.argv[1], sys.argv[2], sys.argv[3]\n\n# --- Inhaltsbasis laden (JSON oder Markdown mit JSON-Header) ---\ndef load_inhaltsbasis(p):\n    raw = open(p, 'r', encoding='utf-8').read()\n    s = raw.lstrip()\n    if s.startswith('{'):\n        try:\n            return json.loads(raw), 'json', raw\n        except json.JSONDecodeError as e:\n            print(f\"FAIL JSON-Parse: {e}\", file=sys.stderr)\n            sys.exit(2)\n    # Markdown-Heuristik: extrahiere title (h1), suche lp_anker / sachanalyse-Blocks textuell\n    title = ''\n    for line in raw.splitlines():\n        line = line.strip()\n        if line.startswith('#') and not title:\n            title = line.lstrip('#').strip()\n            break\n    return ({'title': title, 'lp_anker': raw, 'sachanalyse': {'text': raw}}, 'md', raw)\n\nib, fmt, raw = load_inhaltsbasis(ib_path)\n\n# --- Scan-Felder zusammensetzen ---\ndef get_path(d, *keys):\n    cur = d\n    for k in keys:\n        if isinstance(cur, dict) and k in cur:\n            cur = cur[k]\n        else:\n            return ''\n    return cur if isinstance(cur, str) else (json.dumps(cur, ensure_ascii=False) if cur else '')\n\nscan_text_parts = [\n    get_path(ib, 'title'),\n    get_path(ib, 'lp_anker'),\n    get_path(ib, 'sachanalyse', 'text'),\n]\n# Fallback fuer alternative Header-Strukturen\nif not any(scan_text_parts):\n    scan_text_parts = [json.dumps(ib, ensure_ascii=False)]\n\nscan_text = '\\n'.join(p for p in scan_text_parts if p).lower()\n\n# --- Keywords laden ---\ntry:\n    kw = json.load(open(kw_path, 'r', encoding='utf-8'))\nexcept Exception as e:\n    print(f\"FAIL keywords laden: {e}\", file=sys.stderr)\n    sys.exit(2)\n\ncategories = kw.get('kategorien', [])\n\n# --- Match-Logik: case-insensitive Wortstamm-Match ---\ndef matches(text, keyword):\n    k = keyword.lower().strip()\n    if not k:\n        return False\n    if ' ' in k:\n        # Multi-Token: phrase match\n        return k in text\n    # Single-Token: Wortgrenze, suffix-tolerant (Wortstamm)\n    pat = r'\\b' + re.escape(k) + r'\\w*'\n    return re.search(pat, text) is not None\n\nhits = []\nfor cat in categories:\n    cid = cat.get('id', '')\n    keywords = cat.get('keywords', [])\n    matched = []\n    for kw_word in keywords:\n        if matches(scan_text, kw_word):\n            matched.append(kw_word)\n    if matched:\n        hits.append({'id': cid, 'matched_keywords': sorted(set(matched))})\n\ntrigger_ids = [h['id'] for h in hits]\n\n# --- Output ---\nout = {\n    'trigger_categories': trigger_ids,\n    'detail': hits,\n    'scan_ziel_felder': ['title', 'lp_anker', 'sachanalyse.text'],\n    'erzeugt': datetime.datetime.utcnow().isoformat(timespec='seconds') + 'Z',\n}\nprint(json.dumps(out, ensure_ascii=False, indent=2))\n\n# --- Optional: Write-Mode (nur fuer JSON-Format) ---\nif write_mode == 'yes':\n    if fmt != 'json':\n        print(f\"WARN --write nur fuer JSON-Inhaltsbasis unterstuetzt (gefunden: {fmt}). Header NICHT geschrieben.\", file=sys.stderr)\n        sys.exit(1)\n    header = ib.get('header', {}) if isinstance(ib.get('header'), dict) else {}\n    header['trigger_categories'] = trigger_ids\n    header['trigger_detector_run_at'] = out['erzeugt']\n    ib['header'] = header\n    try:\n        with open(ib_path, 'w', encoding='utf-8') as f:\n            json.dump(ib, f, ensure_ascii=False, indent=2)\n            f.write('\\n')\n    except Exception as e:\n        print(f\"FAIL write: {e}\", file=sys.stderr)\n        sys.exit(1)\nPY\n","structuredPatch":[{"oldStart":138,"oldLines":7,"newStart":138,"newLines":7,"lines":["     'trigger_categories': trigger_ids,","     'detail': hits,","     'scan_ziel_felder': ['title', 'lp_anker', 'sachanalyse.text'],","-    'erzeugt': datetime.datetime.utcnow().isoformat(timespec='seconds') + 'Z',","+    'erzeugt': datetime.datetime.now(datetime.timezone.utc).isoformat(timespec='seconds').replace('+00:00','Z'),"," }"," print(json.dumps(out, ensure_ascii=False, indent=2))"," "]}],"userModified":false,"replaceAll":false}}
